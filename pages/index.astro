---
// Minimal homepage - bypasses all lib imports that cause build failures
import BaseLayout from '../layouts/BaseLayout.astro';
import { ARTICLES } from '../data/articles';

const meta = {
  title: 'Cubical Golfer — Golf Gear Reviews & Guides for Weekend Golfers',
  description: 'Independent golf gear reviews, buying guides, and tips for weekend golfers. Rangefinders, GPS watches, balls, and more — tested on real courses.',
  canonical: 'https://www.cubicalgolfer.com/',
  ogImage: 'https://www.cubicalgolfer.com/images/og-image.jpg',
  ogType: 'website',
  robots: 'index,follow',
  breadcrumbs: [{ label: 'Home', href: '/' }],
};

const schemas = [{
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Cubical Golfer',
  url: 'https://www.cubicalgolfer.com',
}];

const articles = ARTICLES.filter(a => a?.slug).slice(0, 6);
---

<BaseLayout {meta} {schemas} activeNav="home">
  <main style="max-width:960px;margin:0 auto;padding:60px clamp(1rem,4vw,2rem)">
    <h1 style="font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,48px);color:var(--green);margin-bottom:16px">
      Golf Gear Reviews for Weekend Golfers
    </h1>
    <p style="font-size:18px;color:var(--muted);margin-bottom:48px;max-width:640px">
      Independent reviews, buying guides, and tips — tested on real courses by real weekend golfers.
    </p>

    <h2 style="font-family:'Playfair Display',serif;font-size:24px;margin-bottom:24px">Latest Guides</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px">
      {articles.map(a => (
        <a href={a.slug} style="display:block;background:#fff;border:1px solid var(--border);border-radius:12px;padding:24px;text-decoration:none;color:inherit;transition:box-shadow .2s" onmouseover="this.style.boxShadow='0 4px 12px rgba(0,0,0,.1)'" onmouseout="this.style.boxShadow=''">
          <span style="font-size:11px;font-weight:700;letter-spacing:.08em;color:var(--gold-dark);text-transform:uppercase">{a.tag}</span>
          <h3 style="font-family:'Playfair Display',serif;font-size:17px;margin:8px 0;line-height:1.35;color:var(--text)">{a.titleDisplay}</h3>
          <p style="font-size:14px;color:var(--muted);line-height:1.6;margin:0">{a.excerpt}</p>
        </a>
      ))}
    </div>

    <div style="margin-top:48px;display:flex;gap:16px;flex-wrap:wrap">
      <a href="/gear-reviews/" style="padding:12px 24px;background:var(--green);color:#fff;border-radius:8px;font-weight:700;font-size:14px;text-decoration:none">Gear Reviews →</a>
      <a href="/golf-tech/" style="padding:12px 24px;background:var(--cream-dark);color:var(--text);border-radius:8px;font-weight:700;font-size:14px;text-decoration:none">Golf Tech →</a>
      <a href="/improve-your-golf-game/" style="padding:12px 24px;background:var(--cream-dark);color:var(--text);border-radius:8px;font-weight:700;font-size:14px;text-decoration:none">Improve Your Game →</a>
    </div>
  </main>
</BaseLayout>
