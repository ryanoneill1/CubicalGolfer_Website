    { slug: '/golf-practice-drills-at-home/', label: '15-Min Morning Practice Routine' },
    { slug: '/how-to-sneak-in-more-golf-rounds/', label: 'How to Sneak In More Golf Rounds With a Day Job' },
  ],
  'golf-accessories': [
    { slug: '/office-to-golf-course-playbook/', label: 'Office-to-Course Playbook' },
    { slug: '/golf-practice-drills-at-home/', label: '7 Practice Drills You Can Do at Home in 15 Minutes' },
    { slug: '/best-golf-gear-under-100/', label: 'Best Golf Gear Under $100 for Weekend Golfers' },
    { slug: '/golf-practice-drills-at-home/', label: 'How to Practice Golf at Home' },
