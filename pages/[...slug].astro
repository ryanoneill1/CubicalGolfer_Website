---
// src/pages/[...slug].astro — Consistency System v2.0 — April 2026

import BaseLayout    from '../layouts/BaseLayout.astro';
import ProductCard   from '../components/ProductCard.astro';
import AffiliateCTA  from '../components/AffiliateCTA.astro';
import StickyBar     from '../components/StickyBar.astro';
import ProductCTA    from '../components/ProductCTA.astro';
import CGScore       from '../components/CGScore.astro';
import AuthorByline  from '../components/AuthorByline.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedLinks  from '../components/RelatedLinks.astro';
import BackToTop     from '../components/BackToTop.astro';
import SocialShare   from '../components/SocialShare.astro';
import ExitIntent    from '../components/ExitIntent.astro';
import EmailCapture  from '../components/EmailCapture.astro';
import TrustCard     from '../components/TrustCard.astro';
import { getSkipIf } from '../lib/skip-if';
import { ARTICLES }  from '../data/articles';
import { articleMeta } from '../lib/seo';
import { articleSchema, faqSchema, breadcrumbSchema, howToSchema, buyingGuideProductSchema, reviewSchema, roundupItemListSchema } from '../lib/schema';
import { getMergedRelated } from '../lib/linking';
import { getAffiliateLink } from '../data/affiliate-links';
import type { Article } from '../data/types';

export async function getStaticPaths() {
  return ARTICLES
    .filter(article => article.slug !== '/golf-ball-compression-chart/' && article.slug !== '/golf-simulator-complete-guide/' && article.slug !== '/launch-monitor-buying-guide/' && article.slug !== '/golf-ball-complete-guide/' && article.slug !== '/golf-simulator-cost-calculator/' && article.slug !== '/golf-club-distance-chart/' && article.slug !== '/golf-equipment-budget-planner/') // standalone page
    .map(article => ({
    params: { slug: article.slug.replace(/^\/|\/$/g, '') },
    props: { article },
  }));
}

interface Props { article: Article }
const { article } = Astro.props;

const meta    = articleMeta(article);
const related = getMergedRelated(article, 6);
const wordCount = parseInt((article.words ?? '0').replace(/,/g, ''), 10);
const showBackToTop = wordCount >= 1500;

const schemas: object[] = [
  articleSchema(article),
  breadcrumbSchema(meta.breadcrumbs),
];
if (article.faq && article.faq.length > 0) {
  schemas.push(faqSchema(article.faq));
}
if (article.pageType === 'tutorial' && article.toc && article.toc.length > 0) {
  // FIX: Pass actual article object — howToSchema needs article.sections and article.pageType
  const howTo = howToSchema(article);
  if (howTo) schemas.push(howTo); // FIX: null guard prevents <script>null</script>
}
// Review schema — enables star rating rich snippets in Google SERPs
if (article.pageType === 'review' && article.rating) {
  const revSchema = reviewSchema(article);
  if (revSchema) schemas.push(revSchema);
}

const TAG_CLASS: Record<string, string> = {
  'BUYING GUIDE': 'tag-buy', 'COMPARISON': 'tag-cmp', 'TUTORIAL': 'tag-tut',
  'LISTICLE': 'tag-list', 'LIFESTYLE': 'tag-life', 'GUIDE': 'tag-rev',
};
const CAT_LABEL: Record<string, string> = {
  'gear-reviews': 'Golf Gear Reviews', 'golf-tech': 'Golf Tech',
  'golf-accessories': 'Golf Accessories', 'improve-game': 'Improve Your Golf Game',
  'golf-lifestyle': 'Golf Lifestyle', 'indoor-golf': 'Golf Tech',
};
const CAT_SLUG: Record<string, string> = {
  'gear-reviews': 'gear-reviews', 'golf-tech': 'golf-tech',
  'golf-accessories': 'golf-accessories', 'improve-game': 'improve-your-golf-game',
  'golf-lifestyle': 'golf-lifestyle', 'indoor-golf': 'golf-tech',
};

const sameCategory = ARTICLES.filter(
  a => a.category === article.category && a.id !== article.id
).slice(0, 3);

// ── Prev / Next navigation within same category ──────────────────────────
const categoryArticles = ARTICLES
  .filter(a => a.category === article.category)
  .sort((a, b) => a.datePublished.localeCompare(b.datePublished));
const currentIdx = categoryArticles.findIndex(a => a.id === article.id);
const prevArticle = currentIdx > 0 ? categoryArticles[currentIdx - 1] : null;
const nextArticle = currentIdx < categoryArticles.length - 1 ? categoryArticles[currentIdx + 1] : null;

const isBuyingGuide = article.pageType === 'buying-guide' || article.pageType === 'comparison' || article.pageType === 'review';
const isCommercial  = isBuyingGuide || article.pageType === 'listicle';

// Generate ToC items from article sections (for articles with 4+ sections)
const tocItems = (() => {
  const sections = article.sections || [];
  if (sections.length < 5) return [];
  // For buying guides with many products, only show guide-level sections (not individual products)
  let items = sections
    .filter((s: any) => s.h2)
    .map((s: any) => ({
      label: s.h2.replace(/🥇|🥈|🥉|⭐|🏆/g, '').trim(),
      anchor: s.h2.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''),
      indent: false,
    }));
  // Add FAQ if article has faq
  if (article.faq?.length > 0) {
    items.push({ label: 'FAQ', anchor: 'faq', indent: false });
  }
  // Cap at 10 items to prevent sidebar overflow
  if (items.length > 10) {
    items = items.slice(0, 9);
    items.push({ label: 'FAQ', anchor: 'faq', indent: false });
  }
  return items;
})();

// Sticky mobile CTA bar — first product for buying guides
const stickyProduct = (() => {
  if (!isBuyingGuide) return null;
  const key = article.quickAnswerProduct
    || article.comparisonTable?.rows?.find((r: any) => r.affiliateKey)?.affiliateKey
    || null;
  if (!key) return null;
  const aff = getAffiliateLink(key);
  if (!aff?.url) return null;
  const name = article.comparisonTable?.rows?.find((r: any) => r.affiliateKey === key)?.name ?? key;
  return { name, price: aff.price, url: aff.url, retailer: aff.retailer };
})();

// FIX #1: Single named author replaces rotating fake personas (Chief Bogey Officer, etc.)
import { AUTHOR_BYLINE, AUTHOR_PROFILE } from '../data/author';

