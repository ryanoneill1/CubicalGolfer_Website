          { label: 'Take the gear quiz', href: '/gear-quiz/', why: '4 questions → personalized picks for your level' },
        ];
      else if (slug.includes('iron') || slug.includes('fat') || slug.includes('top'))
        recs = [
          { label: 'Most forgiving irons', href: '/best-golf-irons-2026/', why: 'Game-improvement irons keep mishits on the green' },
          { label: 'Iron fitting guide', href: '/iron-fitting-guide-beginners/', why: 'Correct length and lie angle fixes fat and thin contact' },
          { label: 'Best training aids', href: '/best-golf-training-aids/', why: 'Impact tape shows your strike pattern — the first step to fixing it' },
        ];
      else if (slug.includes('driver') || slug.includes('distance') || slug.includes('speed'))
        recs = [
          { label: 'Most forgiving drivers', href: '/best-golf-drivers-forgiveness/', why: 'Modern drivers add 10-15 yards vs anything 5+ years old' },
          { label: 'Best balls for your speed', href: '/golf-ball-compression-chart/', why: 'Wrong compression costs 5-10 yards — free to fix' },
          { label: 'Speed trainers', href: '/best-swing-speed-trainer-over-40/', why: 'Overspeed training adds 5-8 mph in 6-8 weeks' },
        ];
      else if (slug.includes('practice') || slug.includes('drill') || slug.includes('home'))
        recs = [
          { label: 'Best training aids', href: '/best-golf-training-aids/', why: 'The 5 aids that actually transfer to the course' },
          { label: 'Best hitting nets', href: '/best-golf-hitting-net-apartment-garage/', why: 'Full swings at home — from $80 to $200' },
          { label: 'Best launch monitors', href: '/best-golf-launch-monitors-2026/', why: 'Practice with data feedback — the Garmin R10 starts at $600' },
        ];
      else
        recs = [
          { label: 'Best golf gear 2026', href: '/best-golf-gear-2026/', why: '#1 pick in every category — one page, every answer' },
          { label: 'Take the gear quiz', href: '/gear-quiz/', why: '4 questions → personalized recommendations' },
          { label: 'Compare products', href: '/compare/', why: '38 head-to-head comparisons tested side by side' },
        ];

      return recs.length > 0 ? (
        <div style="margin:24px 0;padding:20px 24px;background:rgba(30,58,40,.04);border-radius:12px;border-left:3px solid var(--green);">
          <p style="font-size:14px;font-weight:700;color:var(--green);margin:0 0 4px;">🎯 Gear that helps with this</p>
          <p style="font-size:12px;color:var(--muted);margin:0 0 14px;">Every recommendation is independently purchased and tested over 40+ rounds.</p>
          <div style="display:flex;flex-direction:column;gap:10px;">
            {recs.map(r => (
              <a href={r.href} style="display:flex;justify-content:space-between;align-items:center;gap:12px;padding:12px 16px;background:#fff;border:1px solid var(--border);border-radius:8px;text-decoration:none;transition:border-color .15s;">
                <div>
                  <p style="font-size:14px;font-weight:700;color:var(--green);margin:0;">{r.label}</p>
                  <p style="font-size:12px;color:var(--muted);margin:2px 0 0;">{r.why}</p>
                </div>
                <span style="color:var(--green);font-weight:700;font-size:13px;white-space:nowrap;">See picks →</span>
              </a>
            ))}
          </div>
        </div>
      ) : null;
    })()}

    {/* FAQ */}
    {article.faq && article.faq.length > 0 && (
      <div class="art-faq" id="faq">
        <h2>Frequently Asked Questions</h2>
        {article.faq.map(({ q, a }) => (
          <details class="faq-item">
            <summary>{q}</summary>
            <div class="faq-answer">{a}</div>
          </details>
        ))}
      </div>
    )}

    {/* CROSS-PROMOTION — quiz + tools on buying guides */}
    {isBuyingGuide && (
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;margin:24px 0;">
        <a href="/gear-quiz/" style="display:block;padding:16px 18px;background:var(--green);border-radius:10px;text-decoration:none;">
          <p style="font-size:13px;font-weight:700;color:var(--gold-text);margin:0 0 4px;">🧪 Not sure which to pick?</p>
          <p style="font-size:14px;font-weight:700;color:#fff;margin:0 0 4px;">Take the 60-Second Gear Quiz</p>
          <p style="font-size:11px;color:rgba(255,255,255,.6);margin:0;">Personalized picks based on your game →</p>
        </a>
        <a href="/compare/" style="display:block;padding:16px 18px;background:#fff;border:2px solid var(--border);border-radius:10px;text-decoration:none;">
          <p style="font-size:13px;font-weight:700;color:var(--green);margin:0 0 4px;">⚖️ Compare head to head</p>
          <p style="font-size:14px;font-weight:700;color:var(--green);margin:0 0 4px;">38 Side-by-Side Tests</p>
          <p style="font-size:11px;color:var(--muted);margin:0;">Same conditions, real data →</p>
        </a>
        <a href="/tools/" style="display:block;padding:16px 18px;background:#fff;border:2px solid var(--border);border-radius:10px;text-decoration:none;">
          <p style="font-size:13px;font-weight:700;color:var(--green);margin:0 0 4px;">🧮 Free tools</p>
          <p style="font-size:14px;font-weight:700;color:var(--green);margin:0 0 4px;">Room Checker · Speed Chart</p>
          <p style="font-size:11px;color:var(--muted);margin:0;">Data-driven picks, no signup →</p>
        </a>
      </div>
    )}

    {/* SOCIAL SHARE */}
    <SocialShare url={`https://www.cubicalgolfer.com${article.slug}`} title={article.titleDisplay} />

    {/* RELATED COMPARISONS — links to /compare/ pages for better internal linking */}
    {article.relatedComparisons && article.relatedComparisons.length > 0 && (
      <div class="rel-cluster" style="border-left:3px solid var(--gold);background:rgba(200,168,75,.04);">
        <p style="font-weight:700;font-size:15px;margin:0 0 4px;color:var(--green);">⚖️ Still deciding between two?</p>
        <p style="font-size:13px;color:var(--muted);margin:0 0 12px;">These head-to-head comparisons test the exact products from this guide side by side.</p>
        <div class="rel-links">
          {article.relatedComparisons.map((link: any) => <a href={link.url || link.slug}>{link.label} →</a>)}
        </div>
      </div>
    )}

    {/* RELATED GUIDES */}
    {related.length > 0 && (
      <div class="rel-cluster">
        <p style="font-weight:700;font-size:15px;margin:0 0 12px;">Related Guides</p>
        <div class="rel-links">
          {related.map(link => <a href={link.slug}>{link.label}</a>)}
        </div>
      </div>
    )}

    {/* MORE FOR CUBICLE GOLFERS — cross-category links on ALL article pages */}
    {cubicleGolferLinks.length > 0 && (
      <div class="rel-cluster" style="background:var(--green);border:none;">
        <p style="color:var(--gold-text);font-size:13px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;margin-bottom:14px;">🏢 More for Cubicle Golfers</p>
        <p style="color:rgba(255,255,255,.7);font-size:14px;margin-bottom:16px;line-height:1.6;">
          You work 9-to-5. Golf is your weekend reset. These guides are built for your schedule.
        </p>
        <div class="rel-links">
          {cubicleGolferLinks.map(tip => (
            <a href={tip.slug} style="background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.12);color:#fff;">
              {tip.label}
            </a>
          ))}
        </div>
      </div>
    )}

    {/* AFFILIATE DISCLOSURE — required on all commercial pages */}
    {isCommercial && (
      <div class="disclosure-box" role="note" aria-label="Affiliate disclosure">
        Affiliate disclosure: some links on this page earn us a small commission at no extra
        cost to you. We purchased all products independently — commissions never affect our
        rankings or recommendations.
        <a href="/about/" class="disclosure-link">Learn more about how we work</a>
      </div>
    )}

    {/* UPDATE STAMP */}
    <div class="update-stamp" aria-label="Last updated">Last updated: {article.dateModified}</div>

    {/* SOURCES & REFERENCES */}
    {article.sources && article.sources.length > 0 && (
      <div class="update-stamp" style="margin-top:12px;font-size:12px;line-height:1.8;">
        <strong style="font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);">Sources & References</strong>
        <div style="margin-top:6px;">
          {article.sources.map((src: {label: string; url: string}, i: number) => (
            <span>
              <a href={src.url} target="_blank" rel="noopener noreferrer nofollow" style="color:var(--green);text-decoration:underline;">{src.label}</a>
              {i < article.sources.length - 1 && <span style="color:var(--muted);margin:0 8px;">·</span>}
            </span>
          ))}
        </div>
      </div>
    )}

    {/* END-OF-ARTICLE CTA */}
    <div class="art-cta">
      <p style="font-weight:700;font-size:16px;margin:0 0 10px;">Ready to find the right gear?</p>
      <p>Take our 60-second gear quiz for a personalized recommendation based on your handicap, budget, and playing style.</p>
      <a href="/gear-quiz/" class="btn-gold" style="display:inline-block;margin-top:8px;">Take the Gear Quiz →</a>
      <a href="/gear-reviews/" style="display:inline-block;margin-top:8px;margin-left:12px;font-size:14px;color:var(--green);font-weight:600;text-decoration:underline;text-underline-offset:2px;">Browse All Reviews</a>
    </div>

  </article>


  </div> <!-- /art-layout -->

  {/* ── Prev / Next Navigation ───────────────────────────────────────── */}
  {(prevArticle || nextArticle) && (
    <nav class="prev-next-nav" aria-label="Previous and next articles">
      {prevArticle ? (
        <a href={prevArticle.slug} class="prev-next-link prev-next-link--prev">
          <span class="prev-next-label">← Previous</span>
          <span class="prev-next-title">{prevArticle.titleDisplay}</span>
        </a>
      ) : <span />}
      {nextArticle ? (
        <a href={nextArticle.slug} class="prev-next-link prev-next-link--next">
          <span class="prev-next-label">Next →</span>
          <span class="prev-next-title">{nextArticle.titleDisplay}</span>
        </a>
      ) : <span />}
    </nav>
  )}

  {/* SAME-CATEGORY CARD GRID */}
  {sameCategory.length > 0 && (
    <section class="related-section" aria-label="More guides">
      <h2>More {CAT_LABEL[article.category]} Guides</h2>
      <div class="related-grid">
        {sameCategory.map(a => (
          <a href={a.slug} class="article-card" aria-label={`Read: ${a.titleDisplay}`}>
            <div class={`art-thumb ${a.thumbnail ? '' : a.thumb}`}>
              <span class={`art-badge ${TAG_CLASS[a.tag] || 'tag-buy'}`}>{a.tag}</span>
              {a.thumbnail ? (
                <img src={a.thumbnail} alt={a.titleDisplay} loading="lazy" decoding="async"
                  width="400" height="260" class="art-thumb__img" onerror="this.style.display='none'" />
              ) : (
                <span aria-hidden="true">{a.emoji}</span>
              )}
            </div>
            <div class="art-body">
              <p style="font-weight:700;font-size:15px;margin:4px 0;">{a.titleDisplay}</p>
              <p>{a.excerpt}</p>
              <div class="art-foot">
                <span class="art-words">{a.words} · Updated 2026</span>
                <span class="art-read">Read guide →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
  {/* STICKY CTA — handled by StickyBar component at top of template */}

  {/* ── Sortable comparison table ──────────────────────────────────────── */}
  <script is:inline>
    (function() {
      var table = document.querySelector('.cmp-table');
      if (!table) return;
      var buttons = table.querySelectorAll('thead .cmp-sort-btn');
      var tbody = table.querySelector('tbody');
      if (!tbody) return;

      var sortCol = -1;
      var sortDir = 1;

      buttons.forEach(function(btn, idx) {
        btn.addEventListener('click', function() {
          if (sortCol === idx) { sortDir *= -1; }
          else { sortCol = idx; sortDir = 1; }

          // Update aria-sort on all buttons, set active one
          buttons.forEach(function(b) { b.setAttribute('aria-sort', 'none'); b.classList.remove('sort-asc', 'sort-desc'); });
          btn.setAttribute('aria-sort', sortDir === 1 ? 'ascending' : 'descending');
          btn.classList.add(sortDir === 1 ? 'sort-asc' : 'sort-desc');

          var rows = Array.from(tbody.querySelectorAll('tr'));
          rows.sort(function(a, b) {
            var aText = (a.children[idx] ? a.children[idx].textContent : '').trim();
            var bText = (b.children[idx] ? b.children[idx].textContent : '').trim();
            var aNum = parseFloat(aText.replace(/[^0-9.\-]/g, ''));
            var bNum = parseFloat(bText.replace(/[^0-9.\-]/g, ''));
            if (!isNaN(aNum) && !isNaN(bNum)) return (aNum - bNum) * sortDir;
            return aText.localeCompare(bText) * sortDir;
          });
          rows.forEach(function(r) { tbody.appendChild(r); });
        });
      });
    })();
  </script>

  {showBackToTop && <BackToTop />}
  <ExitIntent />

</BaseLayout>
