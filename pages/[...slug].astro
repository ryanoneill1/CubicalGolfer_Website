};

// Product schema for buying-guide sections with badges + affiliate links
if (isBuyingGuide) {
  for (const section of article.sections) {
    if (!section.badge) continue;
    const sectionAffKey = section.affiliateKey;
    const pid = (sectionAffKey !== undefined)
      ? sectionAffKey
      : (BADGE_TO_PRODUCT[article.id]?.[section.badge || ''] ?? '');
    if (!pid) continue;
    const aff = getAffiliateLink(pid);
    if (!aff?.url) continue;
    // FIX: Pass price, retailer, image — required by Google Product schema
    schemas.push(buyingGuideProductSchema(
      section, aff.url, section.price || aff.price, aff.retailer,
      aff.imgSrc ? `https://www.cubicalgolfer.com${aff.imgSrc}` : undefined,
      pid
    ));
  }

  // ItemList schema for roundup pages (ranked product list)
  const rankedProducts = article.sections
    ?.filter((s: any) => s.badge && s.affiliateKey)
    .map((s: any, i: number) => ({
      name: s.h2.replace(/^[^\w]+/, '').replace(/^(Best Overall:|Best Budget:|Best Premium:|Best Value:|Budget Runner-Up:|Best GPS\+Laser Hybrid:|Best for Sim:|Best Mid-Range:|Best Splurge:|Best for Mid-Handicappers:|Editor.s Pick:|🥇|🥈|🥉|🏆)\s*/gi, '').trim(),
      position: i + 1,
      affiliateKey: s.affiliateKey,
    })) || [];
  if (rankedProducts.length >= 2) {
    schemas.push(roundupItemListSchema(article, rankedProducts));
  }
}
---

<BaseLayout {meta} {schemas} activeNav={article.category}>

  {/* Sticky bar for buying guides */}
  {isBuyingGuide && (() => {
    const topRow = article.comparisonTable?.rows?.find((r: any) => r.affiliateKey);
    const topAff = topRow ? getAffiliateLink(topRow.affiliateKey) : null;
    if (!topAff) return null;
    return (
      <StickyBar
        name={topRow.name}
        price={topAff.price ?? ''}
        url={topAff.url}
        retailer={topAff.retailer}
        badge={article.stickyLabel || (topRow.winner ? 'BEST PICK' : topRow.bestFor)}
      />
    );
  })()}

  {/* ── HERO ───────────────────────────────────────────────────────────────── */}
  <header class="art-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <a href={`/${CAT_SLUG[article.category]}/`}>{CAT_LABEL[article.category]}</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">{article.titleDisplay}</span>
    </nav>

    <span class={`art-tag-lg ${TAG_CLASS[article.tag] || 'tag-buy'}`}>{article.tag}</span>
    <h1>{article.titleDisplay}</h1>

    <div class="author-box">
      <a href="/about/" style="flex-shrink:0" aria-label="About Ryan O. — Cubical Golfer">
        <img src={AUTHOR_BYLINE.avatar} alt="Ryan O., Cubical Golfer founder and gear editor" class="author-avatar-img" width="44" height="44" />
      </a>
      <div style="flex:1">
        <span class="author-name">
          <a href="/about/">{AUTHOR_BYLINE.name}</a>
          <span style="font-size:12px;font-weight:400;color:#556B5C;margin-left:6px">{AUTHOR_BYLINE.tagline}</span>
        </span>
        <span class="author-meta">
          📖 {article.words} words &nbsp;·&nbsp;
          📅 Updated: {article.dateModified} &nbsp;·&nbsp;
          ⛳ <a href="/how-we-test/">How we test →</a>
        </span>
      </div>
      <span class="verified-badge">Independently tested</span>
    </div>
  </header>

  {/* ── WHY TRUST THIS GUIDE — E-E-A-T trust section (buying guides + reviews + listicles) ── */}
  {(isBuyingGuide || article.pageType === 'listicle') && (
    <div class="trust-card">
      <p class="trust-card__heading">Why Trust This Guide</p>
      <ul class="trust-card__list">
        <li><strong>Every product purchased</strong> — bought with our own money, no manufacturer loans or freebies</li>
        <li><strong>{AUTHOR_PROFILE.testingLabel}</strong> — tested on actual courses, not a simulator or fitting bay</li>
        <li><strong>12-handicap perspective</strong> — written for weekend golfers, not scratch players or tour pros</li>
        <li><strong>Updated {article.dateModified}</strong> — prices and picks reviewed regularly</li>
      </ul>
      <a href="/how-we-test/" class="trust-card__link">See full testing methodology →</a>
    </div>
  )}

  {/* ── ENHANCED AUTHOR BYLINE — per-article testing data (EEAT) ── */}
  {article.authorByline && (
    <AuthorByline
      roundsTested={article.authorByline.roundsTested}
      lastTested={article.authorByline.lastTested}
      courseTested={article.authorByline.courseTested}
    />
  )}

  {/* ── AFFILIATE DISCLOSURE — top-of-article trust signal ── */}
  {isCommercial && (
    <AffiliateDisclosure />
  )}

  {/* ── ARTICLE BODY ────────────────────────────────────────────────────────── */}
  <div class="art-layout">
  <article class="art-content">

    {/* TABLE OF CONTENTS — mobile accordion (inline in flow) */}
    {tocItems.length > 0 && (
      <TableOfContents items={tocItems} heading={isBuyingGuide ? 'In this review' : 'In this guide'} />
    )}

    {/* QUICK ANSWER BOX — buying guides only */}
    {article.quickAnswerProduct && article.bottomLine && (() => {
      const qaAff = getAffiliateLink(article.quickAnswerProduct);
      const productCount = article.comparisonTable?.rows?.length ?? article.sections?.filter((s: any) => s.affiliateKey)?.length ?? 0;
      if (!qaAff?.url) return null;
      return (
        <div class="quick-answer-box">
          <div class="quick-answer-header">⚡ Quick Answer</div>
          <p class="quick-answer-text" set:html={article.bottomLine} />
          <a href={qaAff.url} class="quick-answer-cta" target="_blank"
            rel="nofollow noopener sponsored"
            aria-label={`Check price for our #1 pick`}>
            Our #1 Pick: {qaAff.price} at {qaAff.retailer} — Check Today's Price →
          </a>
          <p class="quick-answer-more">Read the full guide below for all {productCount} products tested.</p>
        </div>
      );
    })()}

    {/* BOTTOM LINE — shows as "Our Verdict" ONLY when Quick Answer box is NOT rendered */}

    {/* ── ABOVE-THE-FOLD PRODUCT CTA — buying guides only ── */}
    {isBuyingGuide && (() => {
      const ctaKey = article.quickAnswerProduct;
      if (!ctaKey) return null;
      const ctaAff = getAffiliateLink(ctaKey);
      if (!ctaAff?.url) return null;
      const ctaRow = article.comparisonTable?.rows?.find((r: any) => r.affiliateKey === ctaKey);
      const ctaName = ctaRow?.name ?? ctaKey.replace(/-/g, ' ');
      const ctaBadge = ctaRow?.badge ?? 'Our Top Pick';
      return (
        <ProductCTA
          productName={ctaName}
          amazonUrl={ctaAff.url}
          amazonPrice={ctaAff.price}
          altUrl={ctaAff.golfGalaxyUrl || undefined}
          altLabel={ctaAff.golfGalaxyUrl
            ? (ctaAff.golfGalaxyUrl.includes('amazon') ? 'Amazon' :
               ctaAff.golfGalaxyUrl.includes('playbetter') ? 'PlayBetter' : 'Golf Galaxy')
            : undefined}
          badge={ctaBadge}
          rating={article.quickPickRating || undefined}
          imageUrl={ctaAff.imgSrc || undefined}
          why={article.quickPickWhy || undefined}
