  <script is:inline>
    (function () {
      var toggle = document.getElementById('nav-toggle');
      var links  = document.getElementById('nav-links');
      if (!toggle || !links) return;
      toggle.addEventListener('click', function () {
        var open = links.classList.toggle('open');
        toggle.classList.toggle('open', open);
        toggle.setAttribute('aria-expanded', String(open));
      });
      document.addEventListener('click', function (e) {
        if (!toggle.contains(e.target) && !links.contains(e.target)) {
          links.classList.remove('open');
          toggle.classList.remove('open');
          toggle.setAttribute('aria-expanded', 'false');
        }
      });
    })();

    // Email capture — Kit.com (ConvertKit) V3 API
    // FIX: Supports multiple forms on the same page via ID suffixes
    (function () {
      var suffixes = ['', '-inline'];
      suffixes.forEach(function (sfx) {
        var btn = document.getElementById('email-submit-btn' + sfx);
        var input = document.getElementById('strip-email' + sfx);
        var field = document.getElementById('email-field' + sfx);
        var disclaimer = document.getElementById('email-disclaimer' + sfx);
        var thanks = document.getElementById('strip-thanks' + sfx);
        if (!btn || !input || !thanks) return;

        btn.addEventListener('click', function () {
          var email = input.value.trim();
          if (!email || email.indexOf('@') === -1 || email.indexOf('.') === -1) {
            input.style.borderColor = '#d63b2f';
            input.focus();
            return;
          }
          input.style.borderColor = '';
          btn.textContent = 'Sending\u2026';
          btn.disabled = true;

          fetch('https://api.convertkit.com/v3/forms/9359554/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json; charset=utf-8' },
            body: JSON.stringify({
              api_key: 'GODQuWrlCrC__lqMOglU1Q',
              email: email
            })
          })
          .then(function (res) {
            if (!res.ok) throw new Error(res.status);
            return res.json();
          })
          .then(function (data) {
            if (data && data.subscription) {
              if (field) field.setAttribute('hidden', '');
              if (disclaimer) disclaimer.setAttribute('hidden', '');
              thanks.removeAttribute('hidden');
            } else {
              throw new Error('no subscription');
            }
          })
          .catch(function () {
            btn.textContent = 'Send Me the PDF \u2192';
            btn.disabled = false;
            input.style.borderColor = '#d63b2f';
          });
        });

        input.addEventListener('keydown', function (e) {
          if (e.key === 'Enter') { e.preventDefault(); btn.click(); }
        });
      });
    })();
  </script>

  <CookieBanner />

  <!-- Cloudflare Web Analytics — privacy-respecting, no cookies, GDPR-friendly -->
  {import.meta.env.PUBLIC_ANALYTICS_TOKEN && (
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon={`{"token": "${import.meta.env.PUBLIC_ANALYTICS_TOKEN}"}`}></script>
  )}

  <!-- Affiliate click + email conversion tracking -->
  <script is:inline>
    (function() {
      // Track affiliate link clicks (any sponsored link)
      document.addEventListener('click', function(e) {
        var link = e.target.closest('a[rel*="sponsored"]');
        if (!link) return;
        var product = link.getAttribute('aria-label') || link.textContent || 'unknown';
        var url = link.href || '';
        // Log to console in dev; Cloudflare WA tracks navigation automatically
        if (typeof console !== 'undefined') {
          console.log('[CG Analytics] Affiliate click:', product.substring(0, 60), url.substring(0, 80));
        }
        // If Plausible or GA4 is added later, fire event here:
        // if (window.plausible) plausible('Affiliate Click', { props: { product: product } });
      });

      // Track email-capture conversion (thanks message becomes visible)
      var observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(m) {
          if (m.target.classList && m.target.classList.contains('email-strip__thanks')) {
            if (typeof console !== 'undefined') {
              console.log('[CG Analytics] Email capture conversion');
            }
          }
        });
      });
      var strip = document.querySelector('.email-strip');
      if (strip) observer.observe(strip, { childList: true, subtree: true });
    })();
  </script>
</body>
</html>
