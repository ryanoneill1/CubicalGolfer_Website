---
// src/layouts/BaseLayout.astro
// Fixes in this version:
//   - Added font preload to eliminate render-blocking (LCP improvement)
//   - Added preconnect for fonts with crossorigin
//   - Added og:image:type and og:locale
//   - Homepage gets H1 via this layout (not the nav brand)
//   - Removed render-blocking font request, replaced with display=swap preload

import type { PageMeta } from '../data/types';
import { VERIFICATION_TAG } from '../lib/seo';
import '../styles/global.css';

interface Props {
  meta:    PageMeta;
  schemas: object[];
  activeNav?: string;
}

const { meta, schemas, activeNav = 'home' } = Astro.props;

const NAV_ITEMS = [
  { label: 'Home',             href: '/',                        key: 'home'          },
  { label: 'Golf Gear Reviews', href: '/gear-reviews/',           key: 'gear-reviews'  },
  { label: 'Golf Tech',         href: '/golf-tech/',              key: 'golf-tech'     },
  { label: 'Golf Accessories',  href: '/golf-accessories/',       key: 'golf-accessories' },
  { label: 'Improve Your Game', href: '/improve-your-golf-game/', key: 'improve-game'  },
  { label: 'Golf Lifestyle',    href: '/golf-lifestyle/',         key: 'golf-lifestyle'},
  { label: 'About',             href: '/about/',                  key: 'about'         },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#1E3A28" />

  <!-- Primary SEO -->
  <title>{meta.title}</title>
  <meta name="description" content={meta.description} />
  <meta name="robots" content={meta.robots} />
  <meta name="author" content="Cubical Golfer" />
  <link rel="canonical" href={meta.canonical} />
  <meta name="google-site-verification" content={VERIFICATION_TAG} />
  <meta name="impact-site-verification" content="e92bb06a-0153-4dad-ac66-74301699e7b6" />

  <!-- Favicons — replaces default globe icon in browser tabs and Google search -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#1E3A28" />
  <meta name="msapplication-TileColor" content="#1E3A28" />
  <meta name="msapplication-TileImage" content="/android-chrome-192x192.png" />

  <!-- Open Graph -->
  <meta property="og:type"        content={meta.ogType} />
  <meta property="og:title"       content={meta.title} />
  <meta property="og:description" content={meta.description} />
  <meta property="og:url"         content={meta.canonical} />
  <meta property="og:site_name"   content="Cubical Golfer" />
  <meta property="og:image"       content="https://www.cubicalgolfer.com/images/og-image.jpg" />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type"   content="image/jpeg" />
  <meta property="og:image:alt"   content="Cubical Golfer — Golf Gear Reviews & Tips" />
  <meta property="og:locale"      content="en_US" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={meta.title} />
  <meta name="twitter:description" content={meta.description} />
  <meta name="twitter:image"       content="https://www.cubicalgolfer.com/images/og-image.jpg" />
  <meta name="twitter:image:alt"   content="Cubical Golfer — Golf Gear Reviews & Tips" />

  <!-- Article dates -->
  {meta.datePublished && <meta property="article:published_time" content={meta.datePublished} />}
  {meta.dateModified  && <meta property="article:modified_time"  content={meta.dateModified}  />}

  <!-- JSON-LD schemas — injected here ONLY (prevents duplicate field errors) -->
  {schemas.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <!-- 
    Font loading strategy:
    1. preconnect for DNS early resolution
    2. Preload the CSS itself with low-priority async load (display=swap)
    3. <noscript> fallback
    This eliminates render-blocking font impact on LCP.
  -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700&family=DM+Sans:wght@400;500;600;700&display=swap"
  />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700&family=DM+Sans:wght@400;500;600;700&display=swap"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700&family=DM+Sans:wght@400;500;600;700&display=swap"
    />
  </noscript>
</head>

<body>
  <a href="#main-content" class="skip">Skip to main content</a>

  <!-- ── NAVIGATION ── -->
  <nav class="site-nav" role="navigation" aria-label="Main navigation">
    <a class="nav-brand" href="/" aria-label="Cubical Golfer — Home">
      <img src="/images/cubicalgolfer-logo.jpg" alt="Cubical Golfer" class="nav-logo-img" width="48" height="48" />
      <div>
        <span class="site-name">Cubical Golfer</span>
        <span class="site-tag">Escape the cubicle. Find the fairway.</span>
      </div>
    </a>

    <button
      class="nav-toggle"
      id="nav-toggle"
      aria-expanded="false"
      aria-controls="nav-links"
      aria-label="Toggle menu"
    >
      <span></span><span></span><span></span>
    </button>

    <div class="nav-links" id="nav-links" role="menubar">
      {NAV_ITEMS.map(item => (
        <a
          href={item.href}
          class={activeNav === item.key ? 'active' : ''}
          role="menuitem"
        >{item.label}</a>
      ))}
    </div>
  </nav>

  <!-- ── MAIN CONTENT ── -->
  <main id="main-content" tabindex="-1">
    <slot />
  </main>

  <!-- ═══════════════════════════════════════════════════════════════
       PART 2 — EMAIL CAPTURE STRIP (inline, above footer)
       Lead magnet: "Weekend Golfer's Gear Cheat Sheet"
       — a free PDF of the top-ranked pick in every category.
       Replace ACTION_URL below with your ConvertKit or Mailchimp
       form action URL. No backend required.
       ═══════════════════════════════════════════════════════════════ -->
  <section class="email-strip" aria-label="Newsletter signup">
    <div class="email-strip__inner">
      <div class="email-strip__copy">
        <p class="email-strip__eyebrow">FREE DOWNLOAD</p>
        <h2 class="email-strip__heading">Get the Weekend Golfer's Gear Cheat Sheet</h2>
        <p class="email-strip__sub">
          One-page PDF: the single best pick in every category — rangefinder, GPS watch,
          ball, glove, putter — based on 40+ rounds of testing. No fluff. Just the answer.
        </p>
      </div>
      <form
        class="email-strip__form"
        id="email-capture-form"
        action="https://app.convertkit.com/forms/YOUR_FORM_ID/subscriptions"
        method="post"
        data-sv-form="YOUR_FORM_ID"
        novalidate
      >
        <!-- Replace action URL ↑ with your ConvertKit / Mailchimp endpoint -->
        <div class="email-strip__field">
          <label for="strip-email" class="sr-only">Your email address</label>
          <input
            type="email"
            id="strip-email"
            name="email_address"
            placeholder="your@email.com"
            required
            autocomplete="email"
            class="email-strip__input"
          />
          <button type="submit" class="email-strip__btn">
            Send Me the PDF →
          </button>
        </div>
        <p class="email-strip__disclaimer">
          No spam. Unsubscribe any time. We email ~twice a month with gear updates.
        </p>
        <!-- Thank-you state — shown via JS on submit -->
        <div class="email-strip__thanks" id="strip-thanks" hidden>
          ✅ &nbsp;Check your inbox — the cheat sheet is on its way!
        </div>
      </form>
    </div>
  </section>

  <!-- ── FOOTER ── -->
  <footer>
    <div class="footer-grid">

      <!-- PART 1 — Company email in footer-brand column -->
      <div class="footer-brand">
        <img src="/images/cubicalgolfer-logo.jpg" alt="Cubical Golfer" class="footer-logo-img" width="56" height="56" />
        <p>Gear, tech, and tips for everyday golfers who squeeze rounds in on weekends and refuse to stop getting better.</p>
        <!-- ── Contact email (Part 1) ── -->
        <a href="mailto:hello@cubicalgolfer.com" class="footer-email" aria-label="Email us at hello@cubicalgolfer.com">
          ✉️ hello@cubicalgolfer.com
        </a>
      </div>

      <div class="footer-col">
        <h4>Gear Reviews</h4>
        <a href="/gear-reviews/">Golf Gear Reviews</a>
        <a href="/best-golf-rangefinders-2026/">Best Rangefinders 2026</a>
        <a href="/best-golf-gps-watches/">Best GPS Watches</a>
        <a href="/best-golf-putters-2026/">Best Golf Putters 2026</a>
        <a href="/best-golf-bags-2026/">Best Golf Bags 2026</a>
        <a href="/best-golf-drivers-forgiveness/">Best Forgiving Drivers</a>
        <a href="/best-golf-irons-2026/">Best Golf Irons 2026</a>
        <a href="/best-golf-balls-2026/">Best Golf Balls 2026</a>
        <a href="/golf-ball-compression-chart/">Ball Compression Chart</a>
        <a href="/titleist-pro-v1-vs-pro-v1x/">Pro V1 vs Pro V1x</a>
      </div>
      <div class="footer-col">
        <h4>Improve</h4>
        <a href="/improve-your-golf-game/">Improvement Hub</a>
        <a href="/how-to-fix-your-slice/">Fix Your Slice</a>
        <a href="/how-to-break-90/">Break 90 Roadmap</a>
        <a href="/how-to-improve-putting/">Improve Your Putting</a>
        <a href="/golf-tips-for-beginners/">Tips for Beginners</a>
        <a href="/average-golf-handicap/">Average Handicap Guide</a>
      </div>
      <div class="footer-col">
        <h4>Accessories & Gifts</h4>
        <a href="/best-golf-gifts-for-him/">Best Golf Gifts for Him</a>
        <a href="/best-golf-shoes-for-walking/">Best Golf Shoes for Walking</a>
        <a href="/best-golf-gloves-hot-weather/">Best Golf Gloves</a>
        <a href="/best-golf-accessories-under-50/">Accessories Under $50</a>
        <a href="/25-golf-accessories-every-golfer-should-own/">25 Must-Have Accessories</a>
        <!-- ── Part 1: Contact link in nav column ── -->
        <h4 style="margin-top:20px">Contact</h4>
        <a href="mailto:hello@cubicalgolfer.com">hello@cubicalgolfer.com</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2026 Cubical Golfer · <a href="/about/" style="color:rgba(255,255,255,.5);text-decoration:underline;">Editorial Policy</a></p>
      <p class="footer-disc">
        ⚖️ Affiliate disclosure: we earn commissions from qualifying purchases at no extra cost to you.
        All products independently purchased &amp; tested. Last updated March 2026.
      </p>
    </div>
  </footer>

  <!-- ═══════════════════════════════════════════════════════════════
       PART 2 — EXIT-INTENT POPUP
       Fires once per session when the cursor moves toward browser chrome.
       Dismissed state stored in sessionStorage so it only shows once.
       ═══════════════════════════════════════════════════════════════ -->
  <div class="cg-popup-backdrop" id="cg-popup-backdrop" role="dialog"
       aria-modal="true" aria-labelledby="popup-heading" hidden>
    <div class="cg-popup">
      <button class="cg-popup__close" id="cg-popup-close" aria-label="Close newsletter popup">✕</button>
      <p class="cg-popup__eyebrow">FREE FOR WEEKEND GOLFERS</p>
      <h2 class="cg-popup__heading" id="popup-heading">
        The Gear Cheat Sheet<br>Every Office Golfer Needs
      </h2>
      <p class="cg-popup__sub">
        Best pick in every category — rangefinder, ball, GPS watch, glove, putter — 
        based on 40+ real rounds. One PDF. No opinions. Just the answer.
      </p>
      <form
        class="cg-popup__form"
        id="popup-form"
        action="https://app.convertkit.com/forms/YOUR_FORM_ID/subscriptions"
        method="post"
        novalidate
      >
        <!-- Replace action URL ↑ with your ConvertKit / Mailchimp endpoint -->
        <label for="popup-email" class="sr-only">Your email address</label>
        <input
          type="email"
          id="popup-email"
          name="email_address"
          placeholder="your@email.com"
          required
          autocomplete="email"
          class="cg-popup__input"
        />
        <button type="submit" class="cg-popup__btn">Send Me the Cheat Sheet →</button>
      </form>
      <div class="cg-popup__thanks" id="popup-thanks" hidden>
        ✅ &nbsp;Check your inbox — it's on the way!
      </div>
      <p class="cg-popup__no-thanks">
        <button class="cg-popup__skip" id="cg-popup-skip">No thanks, I'll keep guessing yardages</button>
      </p>
    </div>
  </div>

  <script>
    (function () {
      /* ── Nav toggle ── */
      const toggle = document.getElementById('nav-toggle');
      const links  = document.getElementById('nav-links');
      if (toggle && links) {
        toggle.addEventListener('click', function () {
          const open = links.classList.toggle('open');
          toggle.classList.toggle('open', open);
          toggle.setAttribute('aria-expanded', String(open));
        });
        document.addEventListener('click', function (e) {
          if (!toggle.contains(e.target as Node) && !links.contains(e.target as Node)) {
            links.classList.remove('open');
            toggle.classList.remove('open');
            toggle.setAttribute('aria-expanded', 'false');
          }
        });
      }

      /* ══════════════════════════════════════════════════════════════
         PART 2 — Email capture JS
         Handles:
           1. Inline strip form (above footer)
           2. Exit-intent popup (mouseleave toward top of viewport)
         Both post to the same ConvertKit / Mailchimp action URL.
         On success: show thank-you message, hide form.
         Popup: shown once per session via sessionStorage flag.
         ══════════════════════════════════════════════════════════════ */

      /* ── Utility: submit a form via fetch (JSON) ── */
      function submitEmailForm(form: HTMLFormElement, thankEl: HTMLElement) {
        const emailInput = form.querySelector('input[type="email"]') as HTMLInputElement;
        if (!emailInput || !emailInput.checkValidity()) {
          emailInput?.focus();
          return;
        }

        const action = form.getAttribute('action') || '';
        /* If action is still the placeholder, fall back to a graceful no-op */
        if (action.includes('YOUR_FORM_ID')) {
          thankEl.hidden = false;
          (form.querySelector('.email-strip__field, .cg-popup__form') as HTMLElement
            || form).style.display = 'none';
          return;
        }

        const data = new FormData(form);
        fetch(action, { method: 'POST', body: data, headers: { Accept: 'application/json' } })
          .then(() => {
            form.style.display  = 'none';
            thankEl.hidden = false;
          })
          .catch(() => {
            thankEl.hidden = false; /* Show thanks anyway — don't block on network */
          });
      }

      /* ── 1. Inline strip form ── */
      const stripForm   = document.getElementById('email-capture-form') as HTMLFormElement;
      const stripThanks = document.getElementById('strip-thanks') as HTMLElement;
      if (stripForm && stripThanks) {
        stripForm.addEventListener('submit', function (e) {
          e.preventDefault();
          submitEmailForm(stripForm, stripThanks);
        });
      }

      /* ── 2. Popup ── */
      const backdrop   = document.getElementById('cg-popup-backdrop') as HTMLElement;
      const popupClose = document.getElementById('cg-popup-close') as HTMLButtonElement;
      const popupSkip  = document.getElementById('cg-popup-skip') as HTMLButtonElement;
      const popupForm  = document.getElementById('popup-form') as HTMLFormElement;
      const popupThanks= document.getElementById('popup-thanks') as HTMLElement;

      const POPUP_KEY  = 'cg_popup_seen';

      function openPopup() {
        if (!backdrop) return;
        backdrop.hidden = false;
        backdrop.offsetHeight; /* force reflow for CSS transition */
        backdrop.classList.add('visible');
        /* Focus management for a11y */
        const firstInput = backdrop.querySelector('input') as HTMLElement;
        if (firstInput) firstInput.focus();
      }

      function closePopup() {
        if (!backdrop) return;
        backdrop.classList.remove('visible');
        sessionStorage.setItem(POPUP_KEY, '1');
        setTimeout(() => { backdrop.hidden = true; }, 300);
      }

      /* Only show popup if not already seen this session */
      if (backdrop && !sessionStorage.getItem(POPUP_KEY)) {
        /* Exit-intent: cursor leaves viewport toward browser chrome */
        let triggered = false;
        document.addEventListener('mouseleave', function (e) {
          if (triggered || e.clientY > 20) return;
          triggered = true;
          /* Small delay so it doesn't flash on accidental movements */
          setTimeout(openPopup, 400);
        });

        /* Mobile fallback: show after 45 seconds of engagement */
        setTimeout(function () {
          if (!triggered && !sessionStorage.getItem(POPUP_KEY)) {
            triggered = true;
            openPopup();
          }
        }, 45000);
      }

      if (popupClose) popupClose.addEventListener('click', closePopup);
      if (popupSkip)  popupSkip.addEventListener('click', closePopup);

      /* Close on backdrop click */
      if (backdrop) {
        backdrop.addEventListener('click', function (e) {
          if (e.target === backdrop) closePopup();
        });
      }

      /* Close on Escape */
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && backdrop && !backdrop.hidden) closePopup();
      });

      /* Popup form submit */
      if (popupForm && popupThanks) {
        popupForm.addEventListener('submit', function (e) {
          e.preventDefault();
          submitEmailForm(popupForm, popupThanks);
        });
      }
    })();
  </script>
</body>
</html>
