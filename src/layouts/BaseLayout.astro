---
// src/layouts/BaseLayout.astro
// Fixes in this version:
//   - Added font preload to eliminate render-blocking (LCP improvement)
//   - Added preconnect for fonts with crossorigin
//   - Added og:image:type and og:locale
//   - Homepage gets H1 via this layout (not the nav brand)
//   - Removed render-blocking font request, replaced with display=swap preload

import type { PageMeta } from '../data/types';
import { ViewTransitions } from 'astro:transitions';
import EmailCapture from '../components/EmailCapture.astro';
import CookieBanner from '../components/CookieBanner.astro';
import SiteSearch from '../components/SiteSearch.astro';
import { VERIFICATION_TAG } from '../lib/seo';
import '../styles/global.css';

interface Props {
  meta:    PageMeta;
  schemas: object[];
  activeNav?: string;
}

const { meta, schemas, activeNav = 'home' } = Astro.props;

const NAV_ITEMS = [
  { label: 'Home',              href: '/',                            key: 'home'          },
  { label: 'Gear Reviews',      href: '/gear-reviews/',               key: 'gear-reviews'  },
  { label: 'Golf Tech',         href: '/golf-tech/',                  key: 'golf-tech'     },
  { label: 'Improve',           href: '/improve-your-golf-game/',     key: 'improve-game'  },
  { label: 'Compare',           href: '/compare/',                    key: 'compare'       },
  { label: 'Tools',             href: '/tools/',                      key: 'tools'        },
  { label: 'Gear Quiz',         href: '/gear-quiz/',                  key: 'quiz', cta: true },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#1E3A28" />

  <!-- Primary SEO -->
  <title>{meta.title}</title>
  <meta name="description" content={meta.description} />
  <meta name="robots" content={meta.robots} />
  <meta name="fo-verify" content="3d7887f1-9713-48df-a0e1-f71e58629594" />
  <meta name="author" content="Ryan O." />
  <link rel="canonical" href={meta.canonical} />
  <link rel="help" type="text/plain" href="/llms.txt" title="LLM content index" />
  {VERIFICATION_TAG && <meta name="google-site-verification" content={VERIFICATION_TAG} />}
  <meta name="impact-site-verification" content="e92bb06a-0153-4dad-ac66-74301699e7b6" />

  <!-- Favicons — replaces default globe icon in browser tabs and Google search -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#1E3A28" />
  <meta name="msapplication-TileColor" content="#1E3A28" />
  <meta name="msapplication-TileImage" content="/android-chrome-192x192.png" />

  <!-- Open Graph -->
  <meta property="og:type"        content={meta.ogType} />
  <meta property="og:title"       content={meta.title} />
  <meta property="og:description" content={meta.description} />
  <meta property="og:url"         content={meta.canonical} />
  <meta property="og:site_name"   content="Cubical Golfer" />
  <meta property="og:image"       content="https://www.cubicalgolfer.com/images/og-image.jpg" />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type"   content="image/jpeg" />
  <meta property="og:image:alt"   content="Cubical Golfer — Golf Gear Reviews & Tips" />
  <meta property="og:locale"      content="en_US" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@CubicalGolfer" />
  <meta name="p:domain_verify"     content="ac1e06862e5e2cd3174f40abc780a371" />
  <meta name="twitter:title"       content={meta.title} />
  <meta name="twitter:description" content={meta.description} />
  <meta name="twitter:image"       content="https://www.cubicalgolfer.com/images/og-image.jpg" />
  <meta name="twitter:image:alt"   content="Cubical Golfer — Golf Gear Reviews & Tips" />

  <!-- Article dates -->
  {meta.datePublished && <meta property="article:published_time" content={meta.datePublished} />}
  {meta.dateModified  && <meta property="article:modified_time"  content={meta.dateModified}  />}

  <!-- JSON-LD schemas — injected here ONLY (prevents duplicate field errors) -->
  {schemas.filter(Boolean).map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <!-- Self-hosted fonts — no third-party DNS/round-trip needed -->
  <link rel="preload" href="/fonts/dm-sans-latin-500-normal.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/playfair-display-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Preconnect to external domains for faster affiliate/image loads -->

  <!-- View Transitions — smooth page-to-page animations -->
  <ViewTransitions />

  <!-- Plausible Analytics — privacy-friendly, no cookies, GDPR compliant -->
  <script defer data-domain="cubicalgolfer.com" src="https://plausible.io/js/plausible.js"></script>
</head>

<body>
  <a href="#main-content" class="skip">Skip to main content</a>

  <!-- ── NAVIGATION ── -->
  <nav class="site-nav" role="navigation" aria-label="Main navigation">
    <button
      class="nav-toggle"
      id="nav-toggle"
      aria-expanded="false"
      aria-controls="nav-links"
      aria-label="Toggle menu"
    >
      <span></span><span></span><span></span>
    </button>

    <div class="nav-links" id="nav-links" role="menubar">
      {NAV_ITEMS.map(item => (
        <a
          href={item.href}
          class:list={[
            activeNav === item.key ? 'active' : '',
            (item as any).cta ? 'nav-cta' : '',
          ]}
          role="menuitem"
        >{item.label}</a>
      ))}
    </div>
    <SiteSearch />
  </nav>

  <!-- ── MAIN CONTENT ── -->
  <main id="main-content" tabindex="-1">
    <slot />
  </main>

  <!-- ── EMAIL CAPTURE ── -->
  <section class="email-strip" id="free-guide" aria-label="Newsletter signup">
    <EmailCapture heading="Download the Compression Cheat Sheet + Weekly Gear Deals" variant="footer" />
  </section>

  <!-- ── FOOTER ── -->
  <footer>
    <div class="footer-grid">
      <div class="footer-brand">
        <img src="/images/cubicalgolfer-logo.webp" alt="Cubical Golfer" class="footer-logo-img" width="56" height="56" />
        <p>Gear, tech, and tips for everyday golfers who squeeze rounds in on weekends and refuse to stop getting better.</p>
        <p style="margin-top:24px;font-weight:700;font-size:14px;color:var(--gold)">About &amp; Trust</p>
        <a href="/how-we-test/">How We Test</a>
        <a href="/about/">About / Editorial Policy</a>
        <a href="/affiliate-disclosure/">Affiliate Disclosure</a>
        <a href="/contact/">Contact Us</a>
