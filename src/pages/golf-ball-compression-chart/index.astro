<script>
  const ss = document.getElementById('speed-slider') as HTMLInputElement;
  const sn = document.getElementById('speed-number') as HTMLInputElement;
  const dkb = document.getElementById('dont-know-btn')!;
  const ih = document.getElementById('iron-helper')!;
  const rb = document.getElementById('finder-result')!;
  const cf = document.getElementById('cover-filter') as HTMLSelectElement;
  const pf = document.getElementById('price-filter') as HTMLInputElement;
  const pd = document.getElementById('price-display')!;
  const tb = document.querySelector('#compression-table tbody')!;

  function update() {
    const speed = parseInt(ss.value, 10);
    const rows = Array.from(tb.rows);
    const matches = rows.filter(r => speed >= parseInt(r.dataset.minMph!) && speed <= parseInt(r.dataset.maxMph!))
      .map(r => ({ name: r.dataset.name!, compression: parseInt(r.dataset.compression!), price: parseFloat(r.dataset.price!), cover: r.dataset.cover!, href: (r.querySelector('a') as HTMLAnchorElement).href }));

    if (!matches.length) { rb.innerHTML = '<p>No exact matches — adjust ±5 mph.</p>'; return; }

    const sorted = [...matches].sort((a, b) => a.price - b.price);
    const budget = sorted[0];
    const premium = matches.filter(m => m.cover === 'Urethane').sort((a, b) => b.price - a.price)[0] || sorted[sorted.length - 1];
    const balanced = sorted[Math.floor(sorted.length / 2)];
    const avg = Math.round(matches.reduce((s, m) => s + m.compression, 0) / matches.length / 5) * 5;
    const picks = [budget, balanced, premium].filter(Boolean).filter((v, i, a) => a.findIndex(t => t.name === v.name) === i);

    rb.innerHTML = `<h3 style="margin-top:0;">For ${speed} mph — play compression ${avg}±10</h3>
      <div class="finder-picks">${picks.map((p, i) => `
        <div class="pick-card ${i === 0 ? 'budget' : i === picks.length - 1 ? 'premium' : 'balanced'}">
          <span class="pick-label">${i === 0 ? '💰 Budget' : i === picks.length - 1 ? '⭐ Premium' : '🎯 Best Balance'}</span>
          <strong>${p.name}</strong>
          <span>Compression ${p.compression} · ${p.cover} · ~$${p.price}/dz</span>
          <a href="${p.href}" rel="sponsored nofollow noopener" target="_blank">Check today's price →</a>
        </div>`).join('')}</div>`;
  }

  ss.addEventListener('input', () => { sn.value = ss.value; update(); });
  sn.addEventListener('input', () => { ss.value = sn.value; update(); });
  dkb.addEventListener('click', () => { ih.hidden = !ih.hidden; });
  ih.querySelectorAll('.iron-btn').forEach(btn => {
    btn.addEventListener('click', () => { ss.value = btn.dataset.mph!; sn.value = btn.dataset.mph!; ih.hidden = true; update(); });
  });

  function applyFilters() {
    const cover = cf.value;
    const max = parseFloat(pf.value);
    pd.textContent = `$${max}`;
    Array.from(tb.rows).forEach(r => {
      r.style.display = (!cover || r.dataset.cover === cover) && parseFloat(r.dataset.price!) <= max ? '' : 'none';
    });
  }
  cf.addEventListener('change', applyFilters);
  pf.addEventListener('input', applyFilters);

  document.querySelectorAll('th[data-sort]').forEach(th => {
    let asc = true;
    th.addEventListener('click', () => {
      const key = th.dataset.sort!;
      const rows = Array.from(tb.rows);
      rows.sort((a, b) => {
        const av = key === 'name' || key === 'cover' ? a.dataset[key]! : parseFloat(a.dataset[key]!);
        const bv = key === 'name' || key === 'cover' ? b.dataset[key]! : parseFloat(b.dataset[key]!);
        return asc ? (av > bv ? 1 : -1) : (av < bv ? 1 : -1);
      });
      rows.forEach(r => tb.appendChild(r));
      asc = !asc;
    });
  });
  update();

    // Brand filter
    var brandFilter = document.getElementById('brand-filter');
    if (brandFilter) {
      brandFilter.addEventListener('change', function() {
        var brand = this.value.toLowerCase();
        document.querySelectorAll('#compression-table tbody tr').forEach(function(row) {
          var name = (row.getAttribute('data-name') || '').toLowerCase();
          if (!brand || name.includes(brand.toLowerCase())) {
            row.style.display = '';
          } else {
            row.style.display = 'none';
          }
        });
      });
    }
  </script>

