  .pick-card a { background: var(--green); color: #fff; padding: 8px 14px; text-decoration: none; border-radius: 6px; text-align: center; margin-top: 6px; font-size: 13px; font-weight: 600; }
  .chart-filters { display: flex; gap: 24px; margin: 12px 0; flex-wrap: wrap; align-items: center; }
  @media (max-width: 600px) { .speed-input-group { flex-direction: column; align-items: stretch; } .finder-picks { grid-template-columns: 1fr; } }
