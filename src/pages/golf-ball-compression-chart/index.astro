  { name: 'Wilson DUO Soft+', compression: 40, cover: 'Ionomer', price: 22, minMph: 0, maxMph: 80, search: 'Wilson+DUO+Soft%2B+golf+balls', brand: 'Wilson' },
  { name: 'Titleist TruFeel', compression: 45, cover: 'Ionomer', price: 25, minMph: 65, maxMph: 85, search: 'Titleist+TruFeel+golf+balls', brand: 'Titleist' },
  { name: 'TaylorMade Soft Response', compression: 50, cover: 'Ionomer', price: 25, minMph: 70, maxMph: 85, search: 'TaylorMade+Soft+Response+golf+balls', brand: 'TaylorMade' },
  { name: 'Bridgestone e12 Contact', compression: 50, cover: 'Ionomer', price: 28, minMph: 70, maxMph: 90, asin: 'B09HYNRQJQ', brand: 'Bridgestone' },
  { name: 'Vice Drive', compression: 55, cover: 'Ionomer', price: 17, minMph: 70, maxMph: 90, search: 'Vice+Drive+golf+balls', brand: 'Vice', badge: 'BUDGET PICK' },
  { name: 'Srixon Soft Feel', compression: 60, cover: 'Ionomer', price: 27, minMph: 75, maxMph: 95, asin: 'B0CYDVBYQY', brand: 'Srixon', badge: 'BEST VALUE' },
  { name: 'Vice Pro Soft', compression: 65, cover: 'Urethane', price: 28, minMph: 80, maxMph: 95, search: 'Vice+Pro+Soft+golf+balls', brand: 'Vice' },
  { name: 'Titleist Tour Soft', compression: 65, cover: 'Ionomer', price: 35, minMph: 80, maxMph: 95, search: 'Titleist+Tour+Soft+golf+balls', brand: 'Titleist' },
  { name: 'Titleist Velocity', compression: 65, cover: 'Ionomer', price: 30, minMph: 85, maxMph: 110, search: 'Titleist+Velocity+golf+balls', brand: 'Titleist' },
  { name: 'Callaway Warbird', compression: 68, cover: 'Ionomer', price: 22, minMph: 80, maxMph: 100, search: 'Callaway+Warbird+golf+balls', brand: 'Callaway' },
  { name: 'Bridgestone Tour B RX', compression: 68, cover: 'Urethane', price: 45, minMph: 85, maxMph: 100, search: 'Bridgestone+Tour+B+RX+golf+balls', brand: 'Bridgestone' },
  { name: 'Wilson Chaos', compression: 70, cover: 'Ionomer', price: 28, minMph: 85, maxMph: 100, search: 'Wilson+Chaos+golf+balls', brand: 'Wilson' },
  { name: 'Pinnacle Rush', compression: 72, cover: 'Ionomer', price: 22, minMph: 85, maxMph: 105, search: 'Pinnacle+Rush+golf+balls', brand: 'Pinnacle' },
  { name: 'Srixon Q-Star Tour', compression: 72, cover: 'Urethane', price: 35, minMph: 85, maxMph: 100, asin: 'B09TQXQRMH', brand: 'Srixon' },
  { name: 'Callaway Chrome Soft', compression: 75, cover: 'Urethane', price: 40, minMph: 88, maxMph: 105, asin: 'B0BPMCSNQF', brand: 'Callaway' },
  { name: 'Kirkland Signature', compression: 75, cover: 'Urethane', price: 28, minMph: 85, maxMph: 100, search: 'Kirkland+Signature+golf+balls', brand: 'Kirkland', badge: 'VALUE KING' },
  { name: 'Titleist AVX', compression: 77, cover: 'Urethane', price: 50, minMph: 90, maxMph: 110, search: 'Titleist+AVX+golf+balls', brand: 'Titleist' },
