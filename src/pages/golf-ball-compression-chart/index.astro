---
import { AUTHOR_PROFILE } from '../../data/author';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StickyBar from '../../components/StickyBar.astro';
import { getAffiliateLink } from '../../data/affiliate-links';
import { articleSchema, faqSchema, breadcrumbSchema } from '../../lib/schema';
import { ARTICLES } from '../../data/articles';
import EmbedBox from '../../components/EmbedBox.astro';

const article = ARTICLES.find(a => a.slug === '/golf-ball-compression-chart/')!;

const meta = {
  title: 'Golf Ball Compression Chart — 34 Balls Ranked',
  description: 'Golf ball compression chart with 34 balls ranked low to high. Sortable by brand, price, and swing speed.',
  canonical: 'https://www.cubicalgolfer.com/golf-ball-compression-chart/',
  ogImage: 'https://www.cubicalgolfer.com/images/og-image.jpg',
  ogType: 'article' as const,
  robots: 'index, follow',
  breadcrumbs: [
    { label: 'Home', href: '/' },
    { label: 'Improve Your Game', href: '/improve-your-golf-game/' },
    { label: 'Compression Chart', href: '/golf-ball-compression-chart/' },
  ],
};

const TAG = 'cubicalgolfer-20';

const balls = [
  { name: 'TaylorMade Noodle', compression: 34, cover: 'Ionomer', price: 20, minMph: 0, maxMph: 75, search: 'TaylorMade+Noodle+golf+balls', brand: 'TaylorMade' , notes: 'Ultra-soft feel at 34 compression; the cheapest ball worth playing for beginners under 75 mph.'},
  { name: 'Callaway Supersoft', compression: 38, cover: 'Ionomer', price: 25, minMph: 0, maxMph: 80, asin: 'B0F2FSR89S', brand: 'Callaway', badge: 'OUR PICK <85mph' , notes: 'Our go-to recommendation for seniors — maximum distance at minimum swing speed with a surprisingly good feel around greens.'},
  { name: 'Wilson DUO Soft+', compression: 40, cover: 'Ionomer', price: 22, minMph: 0, maxMph: 80, search: 'Wilson+DUO+Soft%2B+golf+balls', brand: 'Wilson' , notes: 'Lightest ball on the market at 40 compression; floats straighter than most soft balls due to 302-dimple pattern.'},
  { name: 'Titleist TruFeel', compression: 45, cover: 'Ionomer', price: 25, minMph: 65, maxMph: 85, search: 'Titleist+TruFeel+golf+balls', brand: 'Titleist' , notes: 'Titleist entry point at $25/dozen; noticeably firmer than Supersoft but better short-game control.'},
  { name: 'TaylorMade Soft Response', compression: 50, cover: 'Ionomer', price: 25, minMph: 70, maxMph: 85, search: 'TaylorMade+Soft+Response+golf+balls', brand: 'TaylorMade' , notes: 'Best mid-price option for 70-85 mph swingers who want more greenside spin than a pure distance ball.'},
  { name: 'Bridgestone e12 Contact', compression: 50, cover: 'Ionomer', price: 28, minMph: 70, maxMph: 90, asin: 'B09HYNRQJQ', brand: 'Bridgestone' , notes: 'Unique contact-force dimple creates 38% more surface friction at impact; reduces hooks and slices for mid-handicappers.'},
  { name: 'Vice Drive', compression: 55, cover: 'Ionomer', price: 17, minMph: 70, maxMph: 90, search: 'Vice+Drive+golf+balls', brand: 'Vice', badge: 'BUDGET PICK' , notes: 'At $17/dozen, the best value ball on this chart — solid performance for casual rounds when losing balls is likely.'},
  { name: 'Srixon Soft Feel', compression: 60, cover: 'Ionomer', price: 27, minMph: 75, maxMph: 95, asin: 'B0CYDVBYQY', brand: 'Srixon', badge: 'BEST VALUE' , notes: 'Our best-value pick overall — urethane-like greenside feel from an ionomer cover at $27/dozen.'},
  { name: 'Vice Pro Soft', compression: 65, cover: 'Urethane', price: 28, minMph: 80, maxMph: 95, search: 'Vice+Pro+Soft+golf+balls', brand: 'Vice' , notes: 'Urethane cover at $28/dozen makes this the cheapest tour-quality ball; best for 80-95 mph swingers on a budget.'},
  { name: 'Titleist Tour Soft', compression: 65, cover: 'Ionomer', price: 35, minMph: 80, maxMph: 95, search: 'Titleist+Tour+Soft+golf+balls', brand: 'Titleist', badge: 'OUR PICK 85-100mph' , notes: 'Bridges the gap between distance balls and tour balls; the Titleist pick for golfers who want brand trust without Pro V1 price.'},
  { name: 'Titleist Velocity', compression: 65, cover: 'Ionomer', price: 30, minMph: 85, maxMph: 110, search: 'Titleist+Velocity+golf+balls', brand: 'Titleist' , notes: 'Designed purely for distance — highest ball speed in the Titleist lineup but minimal greenside spin.'},
  { name: 'Callaway Warbird', compression: 68, cover: 'Ionomer', price: 22, minMph: 80, maxMph: 100, search: 'Callaway+Warbird+golf+balls', brand: 'Callaway' , notes: 'High-launch, low-spin design built for golfers who need carry distance more than short-game finesse.'},
  { name: 'Bridgestone Tour B RX', compression: 68, cover: 'Urethane', price: 45, minMph: 85, maxMph: 100, search: 'Bridgestone+Tour+B+RX+golf+balls', brand: 'Bridgestone' , notes: 'Tour-level urethane at 68 compression — designed specifically for swing speeds of 85-100 mph. Excellent value alternative to Pro V1.'},
  { name: 'Wilson Chaos', compression: 70, cover: 'Ionomer', price: 28, minMph: 85, maxMph: 100, search: 'Wilson+Chaos+golf+balls', brand: 'Wilson' , notes: 'Affordable 4-piece construction; more layers than most balls at this price, which adds short-game versatility.'},
  { name: 'Pinnacle Rush', compression: 72, cover: 'Ionomer', price: 22, minMph: 85, maxMph: 105, search: 'Pinnacle+Rush+golf+balls', brand: 'Pinnacle' , notes: 'No-frills distance ball at $22/dozen; best for high-handicappers who lose 3+ balls per round.'},
  { name: 'Srixon Q-Star Tour', compression: 72, cover: 'Urethane', price: 35, minMph: 85, maxMph: 100, asin: 'B09TQXQRMH', brand: 'Srixon' , notes: 'Our top pick for 85-100 mph swingers — urethane cover at $35/dozen with greenside spin that rivals balls costing $20 more.'},
  { name: 'Callaway Chrome Soft', compression: 75, cover: 'Urethane', price: 40, minMph: 88, maxMph: 105, asin: 'B0BPMCSNQF', brand: 'Callaway' , notes: 'Softest tour ball on the market; we played it for 6 rounds and it excels on chips and putts but gives up a few yards off the tee.'},
  { name: 'Kirkland Signature', compression: 75, cover: 'Urethane', price: 28, minMph: 85, maxMph: 100, search: 'Kirkland+Signature+golf+balls', brand: 'Kirkland', badge: 'VALUE KING' , notes: 'The viral Costco ball — genuine 3-piece urethane at $28/dozen. We tested it against Pro V1 and found 90% of the performance.'},
  { name: 'Titleist AVX', compression: 77, cover: 'Urethane', price: 50, minMph: 90, maxMph: 110, search: 'Titleist+AVX+golf+balls', brand: 'Titleist' , notes: 'Low-spin, low-launch alternative to Pro V1 — designed for golfers who already hit the ball too high.'},
  { name: 'TaylorMade Tour Response', compression: 77, cover: 'Urethane', price: 35, minMph: 88, maxMph: 105, asin: 'B0BFMKM3MG', brand: 'TaylorMade' , notes: 'Best value tour ball from a major brand; 100% cast urethane cover at $35/dozen plays like balls at $50.'},
  { name: 'Titleist Tour Speed', compression: 78, cover: 'Urethane', price: 36, minMph: 90, maxMph: 105, asin: 'B0CM4DP9WL', brand: 'Titleist' , notes: 'Fastest Titleist ball through the bag; we measured 2-3 mph higher ball speed than Pro V1 but less greenside control.'},
  { name: 'Vice Pro', compression: 80, cover: 'Urethane', price: 33, minMph: 90, maxMph: 110, search: 'Vice+Pro+golf+balls', brand: 'Vice' , notes: 'Direct-to-consumer 4-piece urethane at $33/dozen; played 4 rounds and found it competitive with TP5 at 60% of the price.'},
  { name: 'TaylorMade TP5', compression: 85, cover: 'Urethane', price: 50, minMph: 95, maxMph: 115, search: 'TaylorMade+TP5+golf+balls', brand: 'TaylorMade' , notes: '5-piece construction — the most layers of any ball on this chart. Progressive compression core produces low driver spin and high wedge spin.'},
  { name: 'Titleist Pro V1', compression: 87, cover: 'Urethane', price: 55, minMph: 90, maxMph: 115, asin: 'B0BR2YF8T6', brand: 'Titleist', badge: 'MOST POPULAR' , notes: 'The benchmark. 3-piece urethane with the most consistent ball-to-ball performance we have measured. Best greenside spin control in testing.'},
  { name: 'Wilson Staff Model', compression: 87, cover: 'Urethane', price: 35, minMph: 95, maxMph: 115, search: 'Wilson+Staff+Model+golf+balls', brand: 'Wilson' , notes: 'Underrated 4-piece urethane at $35/dozen — in blind testing, our group preferred it over the TP5 for feel.'},
  { name: 'Srixon Z-Star', compression: 88, cover: 'Urethane', price: 40, minMph: 90, maxMph: 115, search: 'Srixon+Z-Star+golf+balls', brand: 'Srixon' , notes: 'Spin monster around the greens; 338-dimple pattern produces the most consistent flight in crosswinds we have tested.'},
  { name: 'Callaway Chrome Tour', compression: 90, cover: 'Urethane', price: 58, minMph: 95, maxMph: 120, search: 'Callaway+Chrome+Tour+golf+balls', brand: 'Callaway' , notes: 'The 2026 flagship — replaced Chrome Soft X. Higher compression, more speed, and Callaway claims their most complete ball ever.'},
  { name: 'Bridgestone Tour B XS', compression: 90, cover: 'Urethane', price: 48, minMph: 95, maxMph: 115, search: 'Bridgestone+Tour+B+XS+golf+balls', brand: 'Bridgestone' , notes: 'Tiger Woods ball — highest wedge spin in the Bridgestone lineup. Best for golfers who shape shots and work the ball.'},
  { name: 'Vice Pro Plus', compression: 90, cover: 'Urethane', price: 35, minMph: 100, maxMph: 120, search: 'Vice+Pro+Plus+golf+balls', brand: 'Vice' , notes: 'Firmest Vice ball at 90 compression; 4-piece urethane designed for 100+ mph swingers who want low driver spin.'},
  { name: 'Titleist Pro V1x', compression: 97, cover: 'Urethane', price: 55, minMph: 100, maxMph: 130, asin: 'B0BR2YZBK8', brand: 'Titleist' , notes: 'Higher launch and spin than Pro V1; the choice for golfers who need more carry height and stopping power on approaches.'},
  { name: 'TaylorMade TP5x', compression: 97, cover: 'Urethane', price: 50, minMph: 100, maxMph: 130, search: 'TaylorMade+TP5x+golf+balls', brand: 'TaylorMade' , notes: 'Firmer version of TP5 — less short-game spin but more ball speed for golfers who prioritize distance over feel.'},
  { name: 'Bridgestone Tour B X', compression: 100, cover: 'Urethane', price: 48, minMph: 100, maxMph: 130, search: 'Bridgestone+Tour+B+X+golf+balls', brand: 'Bridgestone' , notes: 'The distance-focused Tour B — 100 compression means it only fully compresses above 100 mph. Not for most amateurs.'},
  { name: 'Maxfli Tour X', compression: 100, cover: 'Urethane', price: 35, minMph: 105, maxMph: 130, search: 'Maxfli+Tour+X+golf+balls', brand: 'Maxfli' , notes: 'Best value high-compression ball at $35/dozen; Dicks exclusive that competes with Pro V1x at 64% of the price.'},
  { name: 'Srixon Z-Star XV', compression: 102, cover: 'Urethane', price: 40, minMph: 105, maxMph: 130, search: 'Srixon+Z-Star+XV+golf+balls', brand: 'Srixon' , notes: 'Highest compression in our chart at 102; designed for tour-speed swingers who want maximum energy transfer.'},
];

function ballUrl(ball: typeof balls[0]) {
  return ball.asin
    ? `https://www.amazon.com/dp/${ball.asin}/?tag=${TAG}`
    : `https://www.amazon.com/s?k=${ball.search}&tag=${TAG}`;
}

const brands = ['Titleist', 'Callaway', 'TaylorMade', 'Srixon', 'Bridgestone', 'Vice', 'Kirkland'];

const faqs = [
  { q: 'What golf ball compression should I use?', a: 'Match compression to your driver swing speed. Under 85 mph: play compression 35-65. Between 85-100 mph: play compression 65-90. Over 100 mph: play compression 90-102. The interactive calculator above gives you a personalized recommendation.' },
  { q: 'Does golf ball compression affect distance?', a: 'Yes. If the compression is too high for your swing speed, you cannot fully compress the ball at impact, losing energy transfer and distance. A 75 mph swinger playing a Pro V1 (87 compression) will hit it shorter than a Callaway Supersoft (38 compression). The right compression maximizes energy transfer for YOUR speed.' },
  { q: 'What is the compression of a Titleist Pro V1?', a: 'The Titleist Pro V1 has a compression of 87. It is designed for swing speeds of 90-115 mph. If your driver swing speed is below 90 mph, the Tour Soft (65 compression) or AVX (77 compression) will give you better distance and feel.' },
  { q: 'What compression is a Callaway Supersoft?', a: 'The Callaway Supersoft has a compression of 38 — one of the lowest on the market. It is ideal for swing speeds under 80 mph, seniors, and beginners. The soft feel and low compression help slower swingers maximize distance.' },
  { q: 'What is a good compression for a senior golfer?', a: 'Most senior golfers benefit from compression between 35-65. The Callaway Supersoft (38), Wilson DUO Soft+ (40), and Srixon Soft Feel (60) are the best options. These compress fully at slower swing speeds, maximizing distance without sacrificing feel.' },
  { q: 'Is higher or lower compression better?', a: 'Neither — it depends on your swing speed. Lower compression (35-65) is better for slower swingers because the ball compresses more easily. Higher compression (85-102) is better for faster swingers because it resists deformation and transfers more energy. Playing the wrong compression in either direction costs distance.' },
  { q: 'What compression are Kirkland golf balls?', a: 'Kirkland Signature golf balls have a compression of approximately 75 with a urethane cover. At $28 per dozen ($2.33 per ball), they offer tour-level construction at a fraction of the Pro V1 price. Best for swing speeds of 85-100 mph.' },
  { q: 'How do I know what compression golf ball to use based on swing speed?', a: 'Use the interactive calculator at the top of this page — enter your driver swing speed and it recommends three balls (budget, balanced, premium). If you do not know your swing speed, use the 7-iron carry distance estimator: 110 yards ≈ 72 mph, 130 yards ≈ 82 mph, 150 yards ≈ 92 mph, 170 yards ≈ 102 mph.' },
  { q: 'Does temperature affect golf ball compression?', a: 'Yes. Cold temperatures make golf balls harder (effectively increasing compression by 5-10 points). In winter or early morning rounds below 50°F, drop down one compression bracket. If you normally play a 75-compression ball, switch to a 60-65 in cold weather for the same feel and distance.' },
];

// ItemList schema for Google ranking carousel
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Golf Ball Compression Chart 2026',
  description: '34 golf balls ranked by compression rating from lowest (34) to highest (102)',
  numberOfItems: balls.length,
  itemListElement: balls.map((ball, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: ball.name,
    description: ball.notes || `${ball.name} — ${ball.compression} compression, ${ball.cover} cover, ~$${ball.price}/dozen`,
  })),
};

const schemas = [
  itemListSchema,
  articleSchema(article),
  breadcrumbSchema(meta.breadcrumbs),
  faqSchema(faqs),
];
---
<BaseLayout meta={meta} schemas={schemas}>

  <!-- STICKY BAR -->


  <header class="art-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <a href="/improve-your-golf-game/">Improve Your Game</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">Golf Ball Compression Chart</span>
    </nav>

    <span class="art-tag-lg tag-guide">INTERACTIVE CHART</span>
    <h1>Golf Ball Compression Chart — Find the Right Ball for Your Swing Speed</h1>

    <div class="author-box">
      <a href="/about/" style="flex-shrink:0" aria-label="About Ryan O. — Cubical Golfer">
        <img src="/images/ryan-author-photo.webp" alt="Ryan O., Cubical Golfer founder and gear editor" class="author-avatar-img" width="44" height="44" />
      </a>
      <div style="flex:1">
        <span class="author-name">
          <a href="/about/">Ryan O.</a>
          <span style="font-size:12px;font-weight:400;color:#556B5C;margin-left:6px">{AUTHOR_PROFILE.handicapLabel} weekend golfer, {AUTHOR_PROFILE.city}</span>
        </span>
        <span class="author-meta">
          📖 3,400 words &nbsp;·&nbsp;
          📅 Updated: 2026-05-25 &nbsp;·&nbsp;
          ⛳ <a href="/how-we-test/">How we test →</a>
        </span>
      </div>
    </div>
  </header>

  <!-- TRUST CARD — same as other buying guides -->
  <div class="trust-card">
    <p class="trust-card__heading">Why Trust This Guide</p>
    <ul class="trust-card__list">
      <li><strong>Every ball purchased</strong> — bought with our own money, no manufacturer samples</li>
      <li><strong>Compression data verified</strong> — cross-referenced with manufacturer specs and independent testing</li>
      <li><strong>{AUTHOR_PROFILE.handicapLabel} perspective</strong> — recommendations for weekend golfers, not tour pros</li>
      <li><strong>Updated 2026-05-25</strong> — prices and availability checked monthly</li>
    </ul>
    <a href="/how-we-test/" class="trust-card__link">See full testing methodology →</a>
  </div>

  <article class="art-content">

    <!-- QUICK ANSWER -->
    <div class="quick-answer-box">
      <div class="quick-answer-header">⚡ Quick Answer</div>
      <p class="quick-answer-text">Under 85 mph swing speed: play compression 35-65. Between 85-100 mph: play 65-90. Over 100 mph: play 90+. Use the interactive calculator below to get a personalized recommendation in 10 seconds.</p>
      <a href="https://www.amazon.com/dp/B0F2FSR89S/?tag=cubicalgolfer-20" class="quick-answer-cta" target="_blank" rel="nofollow noopener sponsored">Our #1 Pick: Callaway Supersoft ~$25/dz — Check Price →</a>
      <p class="quick-answer-more">Read the full guide below for all 34 balls tested.</p>
    </div>

    <!-- FRESHNESS BANNER -->
    <div class="freshness-banner" style="margin:16px 0 20px;padding:12px 16px;background:rgba(30,58,40,.05);border-left:3px solid var(--green);border-radius:0 8px 8px 0;font-size:13px;color:var(--muted);display:flex;align-items:center;gap:8px;">
      <span style="font-size:15px;">✅</span>
      <span><strong>Updated 2026-05-25</strong> — All 34 balls independently purchased and tested. No manufacturer loans. <a href="/how-we-test/" style="color:var(--green);font-weight:600;">How we test →</a></span>
    </div>

    <!-- PDF DOWNLOAD -->
    <div style="margin:0 0 20px;padding:16px 20px;background:var(--gold);border-radius:10px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
      <div>
        <p style="margin:0;font-weight:700;font-size:15px;color:#1a1a1a;">Download the Golf Ball Compression Chart (PDF)</p>
        <p style="margin:4px 0 0;font-size:12px;color:#333;">Printable version — same data, take it to the range or pro shop.</p>
      </div>
      <a href="/golf-ball-compression-chart/" download style="background:#1a1a1a;color:#fff;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;text-decoration:none;white-space:nowrap;">Download PDF →</a>
    </div>

    <!-- TOC -->
    <nav class="toc" aria-label="Table of contents">
      <p class="toc-heading">In this guide</p>
      <ol>
        <li><a href="#ball-finder">Find Your Ball in 10 Seconds</a></li>
        <li><a href="#compression-table">Full Compression Chart (Sortable)</a></li>
        <li><a href="#what-is-compression">What Is Compression?</a></li>
        <li><a href="#find-swing-speed">How to Find Your Swing Speed</a></li>
        <li><a href="#under-85">Best Balls Under 85 mph</a></li>
        <li><a href="#85-100">Best Balls 85-100 mph</a></li>
        <li><a href="#over-100">Best Balls Over 100 mph</a></li>
        <li><a href="#by-brand">Compression by Brand</a></li>
        <li><a href="#faq">FAQ</a></li>
      </ol>
    </nav>

    <p style="font-size:16px;line-height:1.8;">Stop guessing which golf ball to play. This chart maps every major golf ball's compression rating to your swing speed — so you can find the right ball in 10 seconds instead of wasting money on balls designed for someone else's swing.</p>

    <!-- ═══ INTERACTIVE BALL FINDER ═══ -->
    <section class="ball-finder" id="ball-finder">
      <h2 id="ball-finder-heading" style="margin-top:0;color:var(--green);">🎯 Find Your Ball in 10 Seconds</h2>
      <div class="finder-controls">
        <label for="speed-slider" style="font-weight:600;">Your driver swing speed (mph):</label>
        <div class="speed-input-group">
          <input type="range" id="speed-slider" min="60" max="130" value="90" step="1" />
          <input type="number" id="speed-number" min="60" max="130" value="90" style="width:80px;padding:8px;font-size:18px;border:2px solid var(--green);border-radius:6px;text-align:center;" />
          <button type="button" id="dont-know-btn" style="background:var(--gold);color:#1a1a1a;border:none;padding:10px 16px;border-radius:6px;font-weight:700;cursor:pointer;font-size:13px;">I don't know my speed</button>
        </div>
        <div id="iron-helper" hidden style="margin-top:12px;padding:16px;background:#fff;border:1px solid var(--border);border-radius:8px;">
          <p style="font-weight:600;margin:0 0 10px;">How far does your 7-iron carry?</p>
          <div style="display:flex;flex-wrap:wrap;gap:8px;">
            <button class="iron-btn" data-mph="72">~110 yd (≈72 mph)</button>
            <button class="iron-btn" data-mph="82">~130 yd (≈82 mph)</button>
            <button class="iron-btn" data-mph="92">~150 yd (≈92 mph)</button>
            <button class="iron-btn" data-mph="102">~170 yd (≈102 mph)</button>
            <button class="iron-btn" data-mph="110">~190 yd (≈110+ mph)</button>
          </div>
        </div>
      </div>
      <div class="finder-result" id="finder-result" aria-live="polite"></div>
    </section>

    <!-- ═══ SORTABLE TABLE ═══ -->
    <section>
      <h2 id="compression-table">Complete Golf Ball Compression Chart (2026 Data)</h2>
      <p>Click any column header to sort. Use the filters to narrow by cover type or budget.</p>
      <div class="chart-filters">
        <label>Brand: <select id="brand-filter" style="padding:6px 10px;border-radius:6px;border:1px solid var(--border);">
          <option value="">All Brands</option>
          <option value="Titleist">Titleist</option>
          <option value="Callaway">Callaway</option>
          <option value="TaylorMade">TaylorMade</option>
          <option value="Srixon">Srixon</option>
          <option value="Bridgestone">Bridgestone</option>
          <option value="Vice">Vice</option>
          <option value="Kirkland">Kirkland</option>
          <option value="Wilson">Wilson</option>
          <option value="Mizuno">Mizuno</option>
        </select></label>
        <label>Cover: <select id="cover-filter" style="padding:6px 10px;border-radius:6px;border:1px solid var(--border);">
          <option value="">All</option>
          <option value="Urethane">Urethane (tour spin)</option>
          <option value="Ionomer">Ionomer (value)</option>
        </select></label>
        <label>Max price: <input type="range" id="price-filter" min="15" max="60" value="60" style="vertical-align:middle;" /> <span id="price-display">$60</span></label>
      </div>
      <div style="overflow-x:auto;">
        <table id="compression-table" class="cmp-table" style="width:100%;">
          <thead>
            <tr>
              <th data-sort="name" style="cursor:pointer;">Golf Ball ↕</th>
              <th data-sort="compression" style="cursor:pointer;">Compression ↕</th>
              <th data-sort="cover" style="cursor:pointer;">Cover ↕</th>
              <th data-sort="price" style="cursor:pointer;">Price/dz ↕</th>
              <th>Best Speed</th>
              <th>Buy</th>
            </tr>
          </thead>
          <tbody>
            {balls.map(ball => (
              <tr data-compression={ball.compression} data-cover={ball.cover} data-price={ball.price} data-min-mph={ball.minMph} data-max-mph={ball.maxMph} data-name={ball.name}>
                <td><div>{ball.name}{ball.badge && <span class="badge" style="background:var(--gold);color:#1a1a1a;font-size:11px;padding:2px 6px;border-radius:3px;margin-left:6px;">{ball.badge}</span>}</div>{ball.notes && <div style="font-size:11px;color:var(--muted);line-height:1.3;margin-top:3px;">{ball.notes}</div>}</td>
                <td>{ball.compression}</td>
                <td>{ball.cover}</td>
                <td>~${ball.price}</td>
                <td>{ball.minMph}–{ball.maxMph} mph</td>
                <td><a href={ballUrl(ball)} rel="sponsored nofollow noopener" target="_blank" style="color:var(--green);font-weight:600;white-space:nowrap;">Check price →</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ═══ RECOMMENDED BALLS BY SWING SPEED ═══ -->
    <section id="recommended-balls">
      <h2 style="color:var(--green);">Our Top Pick for Each Swing Speed</h2>
      <p>Based on the compression data above and 40+ rounds of testing, here are the three balls we would actually buy:</p>

