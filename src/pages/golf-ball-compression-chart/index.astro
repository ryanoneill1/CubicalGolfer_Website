  { name: 'Callaway Chrome Tour', compression: 90, cover: 'Urethane', price: 58, minMph: 95, maxMph: 120, search: 'Callaway+Chrome+Tour+golf+balls', brand: 'Callaway' },
  { name: 'Bridgestone Tour B XS', compression: 90, cover: 'Urethane', price: 48, minMph: 95, maxMph: 115, search: 'Bridgestone+Tour+B+XS+golf+balls', brand: 'Bridgestone' },
  { name: 'Vice Pro Plus', compression: 90, cover: 'Urethane', price: 35, minMph: 100, maxMph: 120, search: 'Vice+Pro+Plus+golf+balls', brand: 'Vice' },
  { name: 'Titleist Pro V1x', compression: 97, cover: 'Urethane', price: 55, minMph: 100, maxMph: 130, asin: 'B0BR2YZBK8', brand: 'Titleist' },
  { name: 'TaylorMade TP5x', compression: 97, cover: 'Urethane', price: 50, minMph: 100, maxMph: 130, search: 'TaylorMade+TP5x+golf+balls', brand: 'TaylorMade' },
  { name: 'Bridgestone Tour B X', compression: 100, cover: 'Urethane', price: 48, minMph: 100, maxMph: 130, search: 'Bridgestone+Tour+B+X+golf+balls', brand: 'Bridgestone' },
  { name: 'Maxfli Tour X', compression: 100, cover: 'Urethane', price: 35, minMph: 105, maxMph: 130, search: 'Maxfli+Tour+X+golf+balls', brand: 'Maxfli' },
