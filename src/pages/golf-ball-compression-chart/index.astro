  .finder-picks { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px; margin-top: 16px; }
  .pick-card { background: #fff; padding: 14px; border-radius: 8px; display: flex; flex-direction: column; gap: 6px; border: 1px solid var(--border); }
  .pick-card.premium { border-top: 4px solid var(--gold); }
  .pick-card.budget { border-top: 4px solid var(--green); }
