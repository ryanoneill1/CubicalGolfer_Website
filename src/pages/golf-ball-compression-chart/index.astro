---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAffiliateLink } from '../../data/affiliate-links';
import { articleSchema, faqSchema, breadcrumbSchema } from '../../lib/schema';
import { ARTICLES } from '../../data/articles';

const article = ARTICLES.find(a => a.slug === '/golf-ball-compression-chart/')!;

const meta = {
  title: 'Golf Ball Compression Chart 2026 — Interactive Filter by Swing Speed',
  description: 'Interactive 2026 golf ball compression chart — 34+ balls filtered by your swing speed. Compression, cover, price, and recommended buy. Match your ball in 10 seconds.',
  canonical: 'https://www.cubicalgolfer.com/golf-ball-compression-chart/',
  ogImage: 'https://www.cubicalgolfer.com/images/og-image.jpg',
  ogType: 'article' as const,
  robots: 'index, follow',
  breadcrumbs: [
    { label: 'Home', href: '/' },
    { label: 'Improve Your Game', href: '/improve-your-golf-game/' },
    { label: 'Compression Chart', href: '/golf-ball-compression-chart/' },
  ],
};

const TAG = 'cubicalgolfer-20';

const balls = [
  { name: 'TaylorMade Noodle', compression: 34, cover: 'Ionomer', price: 20, minMph: 0, maxMph: 75, search: 'TaylorMade+Noodle+golf+balls', brand: 'TaylorMade' },
