---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ARTICLES }      from '../../data/articles';
import { breadcrumbSchema, collectionPageSchema, faqSchema } from '../../lib/schema';

const apparelSlugs = ['/best-golf-shirts/', '/best-golf-pants/', '/best-golf-shorts/', '/best-golf-hats/', '/best-golf-sunglasses/', '/best-golf-rain-jacket/'];
const articles = (ARTICLES as any[]).filter(a => apparelSlugs.includes(a.slug));

const meta = {
  title: 'Golf Apparel Guides — Shirts, Pants, Shorts, Hats',
  description: 'Golf apparel guides tested by a weekend golfer. Shirts, pants, shorts, hats, sunglasses, and rain jackets compared for comfort, performance, and value.',
  canonical: 'https://www.cubicalgolfer.com/golf-apparel/',
  ogImage: 'https://www.cubicalgolfer.com/images/og-image.jpg',
  ogType: 'website' as const,
  robots: 'index, follow',
  breadcrumbs: [
    { label: 'Home', href: '/' },
    { label: 'Golf Apparel', href: '/golf-apparel/' },
  ],
};

const hubFaq = [
  { q: 'What should I wear golfing for the first time?', a: 'A collared polo shirt, golf shorts or pants (no jeans or cargo shorts), golf shoes or clean athletic shoes, and a hat for sun protection. Most public courses have relaxed dress codes, but a collared shirt is universally expected. See our specific guides for shirts, shorts, and shoes.' },
  { q: 'Do I need golf-specific clothing?', a: 'You do not need golf-branded clothing, but you do need performance fabric. Cotton absorbs sweat and restricts movement. Polyester or poly-blend polos, stretch pants, and moisture-wicking shorts make a genuine comfort difference over 4+ hours in the sun. The golf-specific versions also include UV protection.' },
];

const schemas = [breadcrumbSchema(meta.breadcrumbs), faqSchema(hubFaq), collectionPageSchema({ title: meta.title, description: meta.description, url: meta.canonical, articles })];
---

<BaseLayout {meta} {schemas} activeNav="golf-apparel">
  <article class="art-content" style="max-width:900px;margin:0 auto;padding:0 var(--page-px) 60px;">
    <header class="art-hero">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="bc-sep" aria-hidden="true">›</span>
        <span aria-current="page">Golf Apparel</span>
      </nav>
      <h1>Golf Apparel Guides — What to Wear on the Course</h1>
      <p class="art-excerpt">Performance golf clothing tested by a weekend golfer in Midwest heat and rain. Every guide covers fit, fabric, UV protection, and whether the premium brands actually outperform the budget options. No sponsored content — we buy everything and test it ourselves.</p>
    </header>

    <section style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin:24px 0 32px;">
      {articles.map(a => (
        <a href={a.slug} style="display:block;padding:20px;background:#fff;border:1px solid var(--border);border-radius:12px;text-decoration:none;color:inherit;transition:border-color .2s;">
          <span style="font-size:28px;display:block;margin:0 0 8px;">{a.emoji}</span>
          <h2 style="font-size:16px;color:var(--green);margin:0 0 6px;">{a.titleDisplay}</h2>
          <p style="font-size:14px;color:var(--muted);margin:0;line-height:1.5;">{a.excerpt}</p>
        </a>
      ))}
    </section>

    <section style="margin:0 0 24px;">
      <h2 style="font-size:18px;color:var(--green);margin:0 0 12px;">Related gear guides</h2>
      <p style="font-size:15px;line-height:1.7;">For the rest of your on-course setup, see our <a href="/best-golf-shoes-for-walking/">walking shoes</a>, <a href="/best-golf-gloves-for-men/">gloves</a>, <a href="/best-golf-accessories-under-50/">accessories under $50</a>, and <a href="/best-golf-bags-2026/">golf bags</a> guides.</p>
    </section>

    <section id="faq">
      <h2 style="font-size:18px;color:var(--green);margin:0 0 16px;">Frequently Asked Questions</h2>
      {hubFaq.map(({ q, a }) => (
        <div style="margin:0 0 16px;">
          <h3 style="font-size:15px;margin:0 0 6px;">{q}</h3>
          <p style="font-size:14px;line-height:1.7;color:var(--body);margin:0;">{a}</p>
        </div>
      ))}
    </section>
  </article>
</BaseLayout>
