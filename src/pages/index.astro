---
// src/pages/gear-quiz/index.astro — Interactive gear recommendation quiz
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumbSchema } from '../../lib/schema';

const meta = {
  title: 'Golf Gear Quiz — Find Your Perfect Gear in 30 Seconds',
  description: 'Answer 4 quick questions and get personalized golf gear recommendations based on your handicap, budget, and game. Built by the Cubical Golfer team.',
  canonical: 'https://www.cubicalgolfer.com/gear-quiz/',
  ogImage: 'https://www.cubicalgolfer.com/images/og-image.jpg',
  ogType: 'website' as const,
  robots: 'index, follow',
  breadcrumbs: [
    { label: 'Home', href: '/' },
    { label: 'Gear Quiz', href: '/gear-quiz/' },
  ],
};
const schemas = [breadcrumbSchema(meta.breadcrumbs)];
---

<BaseLayout {meta} {schemas} activeNav="gear-quiz">

  <header class="cat-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">Gear Quiz</span>
    </nav>
    <h1>🎯 What Gear Should You Buy Next?</h1>
    <p class="cat-subhead">4 questions. 30 seconds. Personalized recommendations from a team of
desk jockeys who test golf gear between meetings.</p>
  </header>

  <div id="quiz-container" style="max-width:680px;margin:0 auto;padding:0 var(--page-px) 60px;">

    <!-- PROGRESS BAR -->
    <div id="quiz-progress" style="margin-bottom:32px;">
      <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
        <span id="progress-label" style="font-size:13px;font-weight:600;color:var(--muted);">Question 1 of 4</span>
        <span id="progress-pct" style="font-size:13px;font-weight:600;color:var(--green);">25%</span>
      </div>
      <div style="background:var(--cream-dark);border-radius:20px;height:8px;overflow:hidden;">
        <div id="progress-bar" style="background:var(--gold);height:100%;width:25%;border-radius:20px;transition:width .4s ease;"></div>
      </div>
    </div>

    <!-- QUESTIONS -->
    <div id="quiz-questions">

      <div class="quiz-step" data-step="1" style="display:block;">
        <h2 style="font-family:'Playfair Display',serif;font-size:22px;color:var(--green);margin-bottom:6px;">What's your handicap range?</h2>
        <p style="font-size:14px;color:var(--muted);margin-bottom:20px;">No judgment — this helps us recommend the right level of gear.</p>
        <div class="quiz-options">
          <button class="quiz-btn" data-key="handicap" data-value="beginner">🏌️ Beginner (25+)</button>
          <button class="quiz-btn" data-key="handicap" data-value="mid">⛳ Mid Handicap (15–25)</button>
          <button class="quiz-btn" data-key="handicap" data-value="low">🎯 Low Handicap (5–15)</button>
          <button class="quiz-btn" data-key="handicap" data-value="scratch">🏆 Scratch or Better (&lt;5)</button>
        </div>
      </div>

      <div class="quiz-step" data-step="2" style="display:none;">
        <h2 style="font-family:'Playfair Display',serif;font-size:22px;color:var(--green);margin-bottom:6px;">How often do you play?</h2>
        <p style="font-size:14px;color:var(--muted);margin-bottom:20px;">This helps us calibrate value-for-money recommendations.</p>
        <div class="quiz-options">
          <button class="quiz-btn" data-key="frequency" data-value="monthly">📅 Monthly</button>
          <button class="quiz-btn" data-key="frequency" data-value="2-3x">🗓️ 2–3x per month</button>
          <button class="quiz-btn" data-key="frequency" data-value="weekly">📆 Weekly</button>
          <button class="quiz-btn" data-key="frequency" data-value="2+weekly">🔥 2+ per week</button>
        </div>
      </div>

      <div class="quiz-step" data-step="3" style="display:none;">
        <h2 style="font-family:'Playfair Display',serif;font-size:22px;color:var(--green);margin-bottom:6px;">What's your budget for one piece of gear?</h2>
        <p style="font-size:14px;color:var(--muted);margin-bottom:20px;">We'll only recommend gear that fits your price range.</p>
        <div class="quiz-options">
          <button class="quiz-btn" data-key="budget" data-value="under50">💵 Under $50</button>
          <button class="quiz-btn" data-key="budget" data-value="50-150">💰 $50–$150</button>
          <button class="quiz-btn" data-key="budget" data-value="150-300">💎 $150–$300</button>
          <button class="quiz-btn" data-key="budget" data-value="300+">🏅 $300+</button>
        </div>
      </div>

      <div class="quiz-step" data-step="4" style="display:none;">
        <h2 style="font-family:'Playfair Display',serif;font-size:22px;color:var(--green);margin-bottom:6px;">What do you struggle with most?</h2>
        <p style="font-size:14px;color:var(--muted);margin-bottom:20px;">Pick the one area where you lose the most strokes.</p>
        <div class="quiz-options">
          <button class="quiz-btn" data-key="struggle" data-value="distance">🚀 Distance off the tee</button>
          <button class="quiz-btn" data-key="struggle" data-value="accuracy">🎯 Accuracy (slices, hooks)</button>
          <button class="quiz-btn" data-key="struggle" data-value="shortgame">⛳ Short game (chipping & putting)</button>
          <button class="quiz-btn" data-key="struggle" data-value="management">🧠 Course management</button>
        </div>
      </div>

    </div>

    <!-- RESULTS -->
    <div id="quiz-results" style="display:none;">
      <div style="text-align:center;margin-bottom:32px;">
        <span style="font-size:48px;">🎉</span>
        <h2 style="font-family:'Playfair Display',serif;font-size:26px;color:var(--green);margin:12px 0 6px;">Your Personalized Gear Plan</h2>
        <p style="font-size:14px;color:var(--muted);">Based on your answers, here's where to start — curated by the Cubical Golfer team.</p>
      </div>
      <div id="results-cards" style="display:flex;flex-direction:column;gap:16px;"></div>
      <div style="text-align:center;margin-top:32px;">
        <button id="retake-btn" style="background:none;border:2px solid var(--green);color:var(--green);padding:12px 28px;border-radius:8px;font-size:14px;font-weight:700;cursor:pointer;">← Retake Quiz</button>
        <a href="/gear-reviews/" style="display:inline-block;margin-left:12px;background:var(--green);color:#fff;padding:12px 28px;border-radius:8px;font-size:14px;font-weight:700;text-decoration:none;">Browse All Gear →</a>
      </div>
    </div>

  </div>

  <style>
    .quiz-options { display: flex; flex-direction: column; gap: 10px; }
    .quiz-btn {
      display: flex; align-items: center; gap: 12px;
      width: 100%; padding: 16px 20px; border-radius: 10px;
      border: 2px solid var(--border); background: #fff;
      font-size: 15px; font-weight: 600; color: var(--text);
      cursor: pointer; transition: all .2s ease; text-align: left;
      font-family: 'DM Sans', sans-serif;
    }
    .quiz-btn:hover { border-color: var(--green); background: #f0f7f2; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(0,0,0,.06); }
    .quiz-btn.selected { border-color: var(--green); background: var(--green); color: #fff; }

    .result-card {
      background: #fff; border: 1px solid var(--border); border-radius: 12px;
      padding: 24px; display: flex; gap: 16px; align-items: flex-start;
      transition: box-shadow .2s;
    }
    .result-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,.08); }
    .result-num {
      flex-shrink: 0; width: 36px; height: 36px; border-radius: 50%;
      background: var(--green); color: var(--gold); font-weight: 800;
      font-size: 16px; display: flex; align-items: center; justify-content: center;
    }
    .result-body h3 { font-size: 17px; font-weight: 700; color: var(--green); margin: 0 0 6px; }
    .result-body p { font-size: 14px; line-height: 1.6; color: var(--body); margin: 0 0 10px; }
    .result-link {
      display: inline-block; font-size: 13px; font-weight: 700;
      color: var(--green); text-decoration: none; padding: 6px 14px;
      border: 2px solid var(--green); border-radius: 6px; transition: all .15s;
    }
    .result-link:hover { background: var(--green); color: #fff; }

    @media (max-width: 640px) {
      .result-card { flex-direction: column; }
    }
  </style>

  <script>
    (function() {
      const answers = {};
      let step = 1;

      // Recommendation database
      const RECS = {
        'beginner-distance': [
          { title: 'Best Beginner Golf Set Under $500', desc: 'A complete set with a forgiving driver is the fastest way to add distance when you are starting out. The right starter set eliminates 3 bad clubs from your bag.', url: '/best-beginner-golf-set-under-500/', tag: 'STARTER KIT' },
          { title: 'Best Forgiving Drivers 2026', desc: 'A game-improvement driver with a large sweet spot will add 10-15 yards vs a hand-me-down. Forgiveness matters more than brand at your level.', url: '/best-golf-drivers-forgiveness/', tag: 'DISTANCE' },
          { title: 'Best Golf Balls for 90 MPH Swing Speed', desc: 'The right compression ball matched to your speed adds free yards. Most beginners play balls that are too firm for their swing.', url: '/best-golf-balls-90-mph-swing-speed/', tag: 'BALL FIT' },
        ],
        'beginner-accuracy': [
          { title: 'How to Fix Your Slice Permanently', desc: 'A slice is the #1 problem for beginners. Fix your grip first — this single change corrects 70% of rightward misses without any swing changes.', url: '/how-to-fix-your-slice/', tag: 'FIX #1' },
          { title: 'Best Golf Training Aids 2026', desc: 'Alignment sticks ($12) and a putting mirror ($25) fix the two most common beginner errors: aim and setup. Cheapest improvement you can buy.', url: '/best-golf-training-aids/', tag: 'TRAINING' },
          { title: '15-Minute Morning Practice Routine', desc: 'Fifteen minutes before work, 3x per week, builds more muscle memory than a weekend range session. No driving anywhere required.', url: '/golf-practice-routine-before-work/', tag: 'PRACTICE' },
        ],
        'beginner-shortgame': [
          { title: 'How to Improve Your Putting', desc: '65% of all strokes happen inside 100 yards. A putting mirror and 10 minutes of daily practice will drop your scores faster than any club upgrade.', url: '/how-to-improve-putting/', tag: 'PUTTING' },
          { title: 'Best Golf Putters 2026', desc: 'A quality mallet putter with alignment aids helps beginners aim correctly. The Odyssey White Hot OG is our top pick for golfers shooting 90+.', url: '/best-golf-putters-2026/', tag: 'PUTTER' },
          { title: '7 Practice Drills at Home (15 Min)', desc: 'Gate putting, clock drill, and one-handed chips — 7 drills you can do on carpet that will transform your short game in 4 weeks.', url: '/golf-practice-drills-at-home/', tag: 'DRILLS' },
        ],
        'beginner-management': [
          { title: 'How to Break 90: Weekend Roadmap', desc: 'Breaking 90 means bogey golf — 17 over par. The fastest path: eliminate blow-up holes and aim center of every green instead of at pins.', url: '/how-to-break-90/', tag: 'SCORING' },
          { title: 'Golf for Beginners — Complete Guide', desc: 'Grip, stance, course etiquette, and the rules that actually matter. Everything you need to know to play confidently and not slow anyone down.', url: '/golf-for-beginners/', tag: 'START HERE' },
          { title: 'Best Golf GPS Watches 2026', desc: 'Knowing exact yardages eliminates guessing — the #1 cause of bad club selection. A $149 GPS watch helps more than a $400 driver.', url: '/best-golf-gps-watches/', tag: 'GPS' },
        ],
        'mid-distance': [
          { title: 'Best Forgiving Drivers 2026', desc: 'At your level, the right driver adds 8-12 yards. We tested 5 drivers — the Callaway Paradym Ai Smoke Max had the most forgiveness on off-center hits.', url: '/best-golf-drivers-forgiveness/', tag: 'DRIVER' },
          { title: 'Best Golf Balls for 90 MPH Swing Speed', desc: 'Stop playing a Pro V1 at 90 mph. A mid-compression ball like the Srixon Q-Star Tour ($35/dz) compresses better at your speed and costs $20 less.', url: '/best-golf-balls-90-mph-swing-speed/', tag: 'BALL FIT' },
          { title: 'Best Golf Launch Monitors 2026', desc: 'A launch monitor shows you exactly what your swing produces. The Garmin R10 ($549) gives you data that replaces guesswork with facts.', url: '/best-golf-launch-monitors-2026/', tag: 'DATA' },
        ],
        'mid-accuracy': [
          { title: 'How to Fix Your Slice Permanently', desc: 'Even mid-handicappers fight the slice. Strengthen your grip and feel the clubface close through impact — our guide has the specific drills.', url: '/how-to-fix-your-slice/', tag: 'FIX' },
          { title: 'Best Golf Irons 2026', desc: 'Game-improvement irons with wider soles and more offset keep your misses on the green instead of in the bunker. Real forgiveness data inside.', url: '/best-golf-irons-2026/', tag: 'IRONS' },
          { title: 'Best Golf Rangefinders 2026', desc: 'Knowing exact yardage eliminates 2-3 bad club selections per round. The Bushnell Tour V6 Shift ($329) locks the pin faster than anything we tested.', url: '/best-golf-rangefinders-2026/', tag: 'RANGEFINDER' },
        ],
        'mid-shortgame': [
          { title: 'How to Stop 3-Putting', desc: 'Three-putting is a distance control problem. Lag putt from 30 feet to within 3 feet and three-putts disappear. We have 5 drills that fix it.', url: '/how-to-stop-3-putting/', tag: 'PUTTING' },
          { title: 'Best Golf Putters 2026', desc: 'Upgrading from a starter-set putter to a quality mallet saves 1-3 putts per round. The alignment aid alone is worth the price.', url: '/best-golf-putters-2026/', tag: 'PUTTER' },
          { title: '15-Minute Morning Practice Routine', desc: 'A gate putting drill and towel chipping drill before work — 15 minutes, 3x per week — dropped our testers 1.8 strokes in 8 weeks.', url: '/golf-practice-routine-before-work/', tag: 'ROUTINE' },
        ],
        'mid-management': [
          { title: 'Best Golf Rangefinders 2026', desc: 'Course management starts with knowing your numbers. A rangefinder eliminates guessing and forces better decisions on every approach shot.', url: '/best-golf-rangefinders-2026/', tag: 'RANGEFINDER' },
          { title: 'Best Golf GPS Watches 2026', desc: 'A GPS watch gives you front/middle/back of every green plus hazard distances — all on your wrist without slowing down play.', url: '/best-golf-gps-watches/', tag: 'GPS WATCH' },
          { title: 'How to Break 90: Weekend Roadmap', desc: 'Stop chasing pins. Aim center-green, eliminate triples, and play the smart shot. Our roadmap has the math that proves it works.', url: '/how-to-break-90/', tag: 'STRATEGY' },
        ],
        'low-distance': [
          { title: 'Best Golf Launch Monitors 2026', desc: 'At your level, optimizing launch angle and spin rate matters more than swing speed. A launch monitor gives you the data to fine-tune.', url: '/best-golf-launch-monitors-2026/', tag: 'LAUNCH MON' },
          { title: 'Best Forgiving Drivers 2026', desc: 'Even low handicappers benefit from forgiveness. The right driver maintains ball speed on misses — test data from a Foresight GC3 inside.', url: '/best-golf-drivers-forgiveness/', tag: 'DRIVER' },
          { title: 'Best Golf Balls 2026', desc: 'At your swing speed, ball selection matters. Our guide matches compression, cover, and spin to your specific game — tested over 35+ rounds.', url: '/best-golf-balls-2026/', tag: 'BALL' },
        ],
        'low-accuracy': [
          { title: 'Best Golf Irons 2026', desc: 'Players irons with the right shaft flex sharpen dispersion. Our testing shows which irons hold the tightest groupings for single-digit handicaps.', url: '/best-golf-irons-2026/', tag: 'IRONS' },
          { title: 'Best Golf Swing Analyzers 2026', desc: 'A swing analyzer clips to your shaft and shows you face angle, path, and tempo in real time. Fix patterns you cannot feel.', url: '/best-golf-swing-analyzers/', tag: 'ANALYZER' },
          { title: 'Best Golf Rangefinders 2026', desc: 'Precise yardage + slope adjustment = the right club every time. The Bushnell Tour V6 is what most competitive amateurs carry.', url: '/best-golf-rangefinders-2026/', tag: 'RANGEFINDER' },
        ],
        'low-shortgame': [
          { title: 'Best Golf Putters 2026', desc: 'At your level, putter fitting matters. Lie angle, toe hang, and insert feel all affect make percentage on the 6-10 footers that separate 5 from 10.', url: '/best-golf-putters-2026/', tag: 'PUTTER' },
          { title: 'How to Stop 3-Putting', desc: 'Low handicappers three-putt from lag distance. Our speed control drills focus on the 25-40 foot range where most damage happens.', url: '/how-to-stop-3-putting/', tag: 'LAG SPEED' },
          { title: 'Best Golf Training Aids 2026', desc: 'A pressure putting trainer and a chipping net give you high-quality reps at home. Specificity beats volume at your skill level.', url: '/best-golf-training-aids/', tag: 'TRAINING' },
        ],
        'low-management': [
          { title: 'Best Golf GPS Watches 2026', desc: 'The Garmin S62 gives you a virtual caddie that suggests clubs based on your actual stats. Data-driven decisions save 2-3 shots per round.', url: '/best-golf-gps-watches/', tag: 'GPS WATCH' },
          { title: 'Best Golf Rangefinders 2026', desc: 'Laser precision + slope for practice rounds gives you the exact adjusted distances that improve your miss patterns over time.', url: '/best-golf-rangefinders-2026/', tag: 'RANGEFINDER' },
          { title: 'Best Golf Apps 2026', desc: 'Shot tracking apps reveal where you actually lose strokes — not where you think you lose them. Data changes decisions.', url: '/best-golf-apps/', tag: 'APPS' },
        ],
        'scratch-distance': [
          { title: 'Best Golf Launch Monitors 2026', desc: 'Optimize launch conditions with real data. The Rapsodo MLM2PRO ($699) gives you spin axis, apex, and descent angle for every shot.', url: '/best-golf-launch-monitors-2026/', tag: 'LAUNCH MON' },
          { title: 'Trackman 4 vs Foresight GCQuad', desc: 'Considering a premium launch monitor? We compare the two systems every tour pro uses — accuracy, cost, and which one fits your setup.', url: '/trackman-vs-foresight-gcquad/', tag: 'COMPARISON' },
          { title: 'Best Forgiving Drivers 2026', desc: 'Even scratch golfers miss the center. The right driver holds ball speed across the face — our testing shows which ones do it best.', url: '/best-golf-drivers-forgiveness/', tag: 'DRIVER' },
        ],
        'scratch-accuracy': [
          { title: 'Best Golf Irons 2026', desc: 'At your level, iron fitting with shaft optimization is the biggest accuracy lever. Our guide breaks down what to test in a fitting.', url: '/best-golf-irons-2026/', tag: 'IRONS' },
          { title: 'Best Golf Swing Analyzers 2026', desc: 'Sensor-based analysis catches patterns your eye misses. Compare your metrics to tour averages and close the specific gaps.', url: '/best-golf-swing-analyzers/', tag: 'ANALYZER' },
          { title: 'Best Golf Launch Monitors 2026', desc: 'Indoor practice with real data feedback. Dial in your stock shot shapes with spin rate and launch angle precision.', url: '/best-golf-launch-monitors-2026/', tag: 'DATA' },
        ],
        'scratch-shortgame': [
          { title: 'Best Golf Putters 2026', desc: 'At scratch level, putter MOI and face insert technology separate makes from misses on the 8-12 footers that define competitive rounds.', url: '/best-golf-putters-2026/', tag: 'PUTTER' },
          { title: 'Best Golf Balls 2026', desc: 'Greenside spin control is everything. Our spin comparison data shows which balls check, release, and hold on various green conditions.', url: '/best-golf-balls-2026/', tag: 'BALL' },
          { title: 'Best Golf Training Aids 2026', desc: 'Targeted pressure putting trainers and short game feedback tools for deliberate practice at the competitive level.', url: '/best-golf-training-aids/', tag: 'TRAINING' },
        ],
        'scratch-management': [
          { title: 'Best Golf GPS Watches 2026', desc: 'The Garmin S62 with Virtual Caddie uses your real strokes-gained data to suggest the statistically optimal play on every hole.', url: '/best-golf-gps-watches/', tag: 'GPS WATCH' },
          { title: 'Best Golf Rangefinders 2026', desc: 'Sub-yard accuracy + slope + jolt vibration confirmation. The tool competitive amateurs rely on for every approach shot.', url: '/best-golf-rangefinders-2026/', tag: 'RANGEFINDER' },
          { title: 'Best Golf Apps 2026', desc: 'Advanced strokes-gained analysis by shot type, hole type, and club. See exactly where your competitive game leaks strokes.', url: '/best-golf-apps/', tag: 'ANALYTICS' },
        ],
      };

      // Handle button clicks
      document.querySelectorAll('.quiz-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var key = this.getAttribute('data-key');
          var value = this.getAttribute('data-value');
          answers[key] = value;

          // Visual feedback
          this.parentElement.querySelectorAll('.quiz-btn').forEach(function(b) { b.classList.remove('selected'); });
          this.classList.add('selected');

          // Advance after short delay
          setTimeout(function() {
            if (step < 4) {
              document.querySelector('[data-step="' + step + '"]').style.display = 'none';
              step++;
              document.querySelector('[data-step="' + step + '"]').style.display = 'block';
              document.getElementById('progress-label').textContent = 'Question ' + step + ' of 4';
              document.getElementById('progress-pct').textContent = (step * 25) + '%';
              document.getElementById('progress-bar').style.width = (step * 25) + '%';
            } else {
              showResults();
            }
          }, 300);
        });
      });

      function showResults() {
        document.getElementById('quiz-questions').style.display = 'none';
        document.getElementById('quiz-progress').style.display = 'none';
        document.getElementById('quiz-results').style.display = 'block';

        var key = answers.handicap + '-' + answers.struggle;
        var recs = RECS[key] || RECS['mid-accuracy'];

        var cardsHtml = '';
        recs.forEach(function(rec, i) {
          cardsHtml += '<div class="result-card">' +
            '<div class="result-num">' + (i + 1) + '</div>' +
            '<div class="result-body">' +
              '<span style="font-size:11px;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:.08em;">' + rec.tag + '</span>' +
              '<h3>' + rec.title + '</h3>' +
              '<p>' + rec.desc + '</p>' +
              '<a href="' + rec.url + '" class="result-link">Read the Full Guide →</a>' +
            '</div>' +
          '</div>';
        });
        document.getElementById('results-cards').innerHTML = cardsHtml;
      }

      // Retake
      document.getElementById('retake-btn').addEventListener('click', function() {
        step = 1;
        document.getElementById('quiz-results').style.display = 'none';
        document.getElementById('quiz-questions').style.display = 'block';
        document.getElementById('quiz-progress').style.display = 'block';
        document.querySelectorAll('.quiz-step').forEach(function(s) { s.style.display = 'none'; });
        document.querySelector('[data-step="1"]').style.display = 'block';
        document.querySelectorAll('.quiz-btn').forEach(function(b) { b.classList.remove('selected'); });
        document.getElementById('progress-label').textContent = 'Question 1 of 4';
        document.getElementById('progress-pct').textContent = '25%';
        document.getElementById('progress-bar').style.width = '25%';
      });
    })();
  </script>

</BaseLayout>
