---
const meta = {
  title: 'Cubical Golfer — Golf Gear Reviews for Weekend Golfers',
  description: 'Independent golf gear reviews, buying guides and tips for weekend golfers. Tested rangefinders, GPS watches, balls and training aids.',
  canonical: 'https://www.cubicalgolfer.com/',
  ogImage: 'https://www.cubicalgolfer.com/images/og-image.jpg',
  ogType: 'website' as const,
  robots: 'index,follow',
  breadcrumbs: [] as Array<{label: string; href: string}>,
};
const schemas = [{ '@context': 'https://schema.org', '@type': 'WebSite', name: 'Cubical Golfer', url: 'https://www.cubicalgolfer.com' }];
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout {meta} {schemas} activeNav="home">
  <main style="max-width:960px;margin:0 auto;padding:64px clamp(1rem,4vw,2rem)">
    <h1 style="font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,46px);color:var(--green);margin-bottom:16px">Golf Gear Reviews for Weekend Golfers</h1>
    <p style="font-size:18px;color:var(--muted);max-width:600px;margin-bottom:40px">Honest reviews, buying guides and tips — tested on real courses by real weekend golfers.</p>
    <div style="display:flex;gap:14px;flex-wrap:wrap">
      <a href="/gear-reviews/" style="padding:13px 26px;background:var(--green);color:#fff;border-radius:8px;font-weight:700;font-size:15px;text-decoration:none">Golf Gear Reviews →</a>
      <a href="/golf-tech/" style="padding:13px 26px;background:var(--cream-dark);color:var(--text);border-radius:8px;font-weight:700;font-size:15px;text-decoration:none">Golf Tech →</a>
      <a href="/golf-accessories/" style="padding:13px 26px;background:var(--cream-dark);color:var(--text);border-radius:8px;font-weight:700;font-size:15px;text-decoration:none">Accessories →</a>
      <a href="/improve-your-golf-game/" style="padding:13px 26px;background:var(--cream-dark);color:var(--text);border-radius:8px;font-weight:700;font-size:15px;text-decoration:none">Improve Your Game →</a>
    </div>
  </main>
</BaseLayout>
