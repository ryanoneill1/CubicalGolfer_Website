---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema } from '../lib/schema';

const meta = {
  title: 'Cookie Policy — Cubical Golfer',
  description: 'Cubical Golfer cookie policy — what cookies and local storage we use, why, and how to manage them.',
  canonical: 'https://www.cubicalgolfer.com/cookie-policy/',
  ogImage: 'https://www.cubicalgolfer.com/images/og-image.jpg',
  ogType: 'website' as const,
  robots: 'index,follow',
  breadcrumbs: [
    { label: 'Home', href: '/' },
    { label: 'Cookie Policy', href: '/cookie-policy/' },
  ],
};
const schemas = [breadcrumbSchema(meta.breadcrumbs)];
const updated = '2026-04-26';
---

<BaseLayout {meta} {schemas}>
  <div class="art-content" style="max-width:750px;margin:0 auto;padding:48px 24px;">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">Cookie Policy</span>
    </nav>

    <h1>Cookie Policy</h1>
    <p style="font-size:14px;color:var(--muted);">Last updated: {updated}</p>

    <p>Cubical Golfer uses cookies and local storage to improve your experience and understand how the site is used. This policy explains what we use, why, and how you can manage your preferences.</p>

    <h2>What Are Cookies?</h2>
    <p>Cookies are small text files stored on your device when you visit a website. They help sites remember your preferences, understand usage patterns, and improve functionality. Cookies cannot access other data on your device.</p>

    <h2>First-Party Storage</h2>

    <h3>Cookie Consent Preference</h3>
    <p>We store your cookie consent choice in your browser's localStorage (not a cookie) so you are not asked again on every visit. This data never leaves your device.</p>
    <p>Key: <code>cg-cookie-consent</code> — Value: "accepted" or "declined" — Duration: persists until you clear browser data — Provider: Cubical Golfer</p>

    <h2>Third-Party Cookies and Services</h2>

    <h3>Cloudflare Web Analytics</h3>
    <p>We use Cloudflare Web Analytics to understand how visitors interact with our site. Cloudflare Web Analytics does not use cookies, does not track individual visitors, and does not collect personally identifiable information. It measures aggregate page views and performance metrics only.</p>
    <p>Provider: Cloudflare — Cookies: none — <a href="https://www.cloudflare.com/web-analytics/" target="_blank" rel="noopener">Learn more</a></p>

    <h3>Affiliate Tracking Cookies</h3>
    <p>When you click an affiliate link, the retailer may place a cookie on your device to track the referral. This is how we earn a commission on qualifying purchases. These cookies are placed by the retailer, not by Cubical Golfer.</p>
    <p><strong>Amazon Associates:</strong> Amazon places cookies when you click an affiliate link. Duration: 24 hours (or 89 days if you add an item to cart). Provider: Amazon. <a href="https://www.amazon.com/gp/help/customer/display.html?nodeId=468496" target="_blank" rel="noopener">Amazon Privacy Policy</a></p>
    <p><strong>Bushnell (via Impact):</strong> Impact Radius may place a tracking cookie when you click a Bushnell affiliate link. Duration: 30 days. Provider: Impact.</p>
    <p><strong>LAB Golf / Vice Golf:</strong> Direct affiliate links to these retailers may use their own tracking cookies. Duration varies by retailer.</p>
    <p>See our <a href="/affiliate-disclosure/">Affiliate Disclosure</a> for more details on how affiliate links work.</p>

    <h3>ConvertKit (Kit.com)</h3>
    <p>If you subscribe to our email newsletter, ConvertKit (Kit.com) processes your email address and may place cookies for form functionality. Provider: ConvertKit. <a href="https://kit.com/privacy" target="_blank" rel="noopener">ConvertKit Privacy Policy</a></p>

    <h2>How to Manage Cookies</h2>
    <p>You can control cookies through your browser settings. Most browsers allow you to view which cookies are stored, delete all or specific cookies, block cookies from specific sites, and block all third-party cookies.</p>
    <p>You can also use the cookie banner that appears on your first visit to accept or decline non-essential cookies. To reset your preference, clear your browser's localStorage for this site.</p>
    <p>Note: disabling cookies may affect your experience on retailer websites when clicking affiliate links.</p>

    <h2>Changes to This Policy</h2>
    <p>We may update this Cookie Policy when we add or remove third-party services. Changes will be posted on this page with an updated date.</p>

    <h2>Contact</h2>
    <p>Questions about cookies? Contact us at <a href="mailto:hello@cubicalgolfer.com">hello@cubicalgolfer.com</a>.</p>
  </div>
</BaseLayout>
