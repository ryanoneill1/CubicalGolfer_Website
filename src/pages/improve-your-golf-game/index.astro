---
// src/pages/improve-your-golf-game/index.astro
import { getAffiliateLink } from '../../data/affiliate-links';
import BaseLayout        from '../../layouts/BaseLayout.astro';
import { ARTICLES }      from '../../data/articles';
import { categoryMeta }  from '../../lib/seo';
import { getCategoryArticles } from '../../lib/linking';
import { breadcrumbSchema, collectionPageSchema } from '../../lib/schema';

const cat      = 'improve-game';
const articles = getCategoryArticles(cat);
const meta     = categoryMeta(cat);
const schemas  = [
  breadcrumbSchema(meta.breadcrumbs),
  collectionPageSchema({ title: meta.title, description: meta.description, url: meta.canonical, articles }),
];
---

<BaseLayout {meta} {schemas} activeNav="improve-game">

  <header class="cat-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">Improve Your Game</span>
    </nav>
    <h1>🎯 Improve Your Golf Game</h1>
    <p class="cat-subhead">Fix your slice, break 90, lower your handicap — practical guides for
weekend golfers who are serious about getting better.</p>
  </header>

  <div class="hub-featured" style="margin:0 0 28px;padding:18px 22px;background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.25);border-radius:10px;display:flex;flex-wrap:wrap;align-items:center;gap:12px 20px;">
    <div style="flex:1;min-width:200px;">
      <span style="font-size:12px;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:0.5px;">⭐ Featured Pick</span>
      <p style="font-size:16px;font-weight:700;margin:4px 0 2px;color:var(--green);">Arccos Caddie Sensors — ~$179</p>
      <p style="font-size:13px;margin:0;color:var(--muted);">AI-powered shot tracking that actually improves scores</p>
    </div>
    {(() => {
      const aff = getAffiliateLink('arccos-caddie-sensors');
      const secUrl = (aff as any).golfGalaxyUrl || '';
      const secR = secUrl.includes('amazon') ? 'Amazon' : secUrl.includes('playbetter') ? 'PlayBetter' : secUrl.includes('golfgalaxy') || secUrl.includes('click-101736949') ? 'Golf Galaxy' : '';
      return (
        <div style="display:flex;flex-wrap:wrap;gap:8px;">
          <a href={aff.url} target="_blank" rel="nofollow noopener sponsored"
             style="display:inline-block;background:var(--gold);color:#1a1a1a;padding:10px 18px;border-radius:8px;font-size:13px;font-weight:700;text-decoration:none;">
            Check Price at {aff.retailer} →
          </a>
          {secUrl && secR && (
            <a href={secUrl} target="_blank" rel="nofollow noopener sponsored"
               style="display:inline-block;background:#fff;color:var(--green);padding:10px 18px;border-radius:8px;font-size:13px;font-weight:700;text-decoration:none;border:2px solid var(--green);">
              Check Price at {secR} →
            </a>
          )}
        </div>
      );
    })()}
  </div>


  <div class="cat-page-body">
    {articles.length === 0 ? (
      <p style="color:var(--muted);padding:32px 0">No articles yet — check back soon.</p>
    ) : (
      <div class="articles-grid">
        {articles.map(a => (
          <a href={a.slug} class="article-card" aria-label={`Read: ${a.titleDisplay}`}>
            <div class={`art-thumb ${(a as any).thumbnail ? '' : a.thumb}`}>
              <span class={
                a.tag === 'BUYING GUIDE' ? 'art-badge tag-buy' :
                a.tag === 'COMPARISON'   ? 'art-badge tag-cmp' :
                a.tag === 'TUTORIAL'     ? 'art-badge tag-tut' :
                a.tag === 'LISTICLE'     ? 'art-badge tag-list' :
                a.tag === 'LIFESTYLE'    ? 'art-badge tag-life' :
                'art-badge tag-rev'
              }>{a.tag}</span>
              {(a as any).thumbnail ? (
                <img src={(a as any).thumbnail} alt={a.titleDisplay} loading="lazy" decoding="async" width="400" height="260"
                  class="art-thumb__img" onerror="this.style.display='none'" />
              ) : (
                <span aria-hidden="true">{a.emoji}</span>
              )}
            </div>
            <div class="art-body">
              <h3>{a.titleDisplay}</h3>
              <p>{a.excerpt}</p>
              <div class="art-foot">
                <span class="art-words">{a.words} · Updated 2026</span>
                <span class="art-read">Read guide →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>

</BaseLayout>
