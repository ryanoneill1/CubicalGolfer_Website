---
// src/pages/[...slug].astro — Consistency System v2.0 — April 2026

import BaseLayout    from '../layouts/BaseLayout.astro';
import ProductCard   from '../components/ProductCard.astro';
import AffiliateCTA  from '../components/AffiliateCTA.astro';
import StickyBar     from '../components/StickyBar.astro';
import { ARTICLES }  from '../data/articles';
import { articleMeta } from '../lib/seo';
import { articleSchema, faqSchema, breadcrumbSchema, howToSchema, buyingGuideProductSchema } from '../lib/schema';
import { getMergedRelated } from '../lib/linking';
import { getAffiliateLink } from '../data/affiliate-links';
import type { Article } from '../data/types';

export async function getStaticPaths() {
  return ARTICLES.map(article => ({
    params: { slug: article.slug.replace(/^\/|\/$/g, '') },
    props: { article },
  }));
}

interface Props { article: Article }
const { article } = Astro.props;

const meta    = articleMeta(article);
const related = getMergedRelated(article, 6);

const schemas: object[] = [
  articleSchema(article),
  breadcrumbSchema(meta.breadcrumbs),
];
if (article.faq && article.faq.length > 0) {
  schemas.push(faqSchema(article.faq));
}
if (article.pageType === 'tutorial' && article.toc && article.toc.length > 0) {
  schemas.push(howToSchema({
    name:        article.titleDisplay,
    description: article.description,
    url:         `https://www.cubicalgolfer.com${article.slug}`,
    steps:       article.toc,
  }));
}

const TAG_CLASS: Record<string, string> = {
  'BUYING GUIDE': 'tag-buy', 'COMPARISON': 'tag-cmp', 'TUTORIAL': 'tag-tut',
  'LISTICLE': 'tag-list', 'LIFESTYLE': 'tag-life', 'GUIDE': 'tag-rev',
};
const CAT_LABEL: Record<string, string> = {
  'gear-reviews': 'Golf Gear Reviews', 'golf-tech': 'Golf Tech',
  'golf-accessories': 'Golf Accessories', 'improve-game': 'Improve Your Golf Game',
  'golf-lifestyle': 'Golf Lifestyle',
};
const CAT_SLUG: Record<string, string> = {
  'gear-reviews': 'gear-reviews', 'golf-tech': 'golf-tech',
  'golf-accessories': 'golf-accessories', 'improve-game': 'improve-your-golf-game',
  'golf-lifestyle': 'golf-lifestyle',
};

const sameCategory = ARTICLES.filter(
  a => a.category === article.category && a.id !== article.id
).slice(0, 3);

const isBuyingGuide = article.pageType === 'buying-guide' || article.pageType === 'comparison';
const isCommercial  = isBuyingGuide || article.pageType === 'listicle';

// Cubicle Golfer personas — each category gets a rotating cast of desk-bound golf dreamers
const PERSONAS: Record<string, Array<{ name: string; tagline: string }>> = {
  'gear-reviews': [
    { name: 'Fairway Finance Guy', tagline: '14-hdcp · reviews gear between budget meetings' },
    { name: 'The Deskbound Driver', tagline: '16-hdcp · tests drivers on lunch-break range sessions' },
    { name: 'Chief Bogey Officer', tagline: '18-hdcp · approves gear purchases nobody asked for' },
  ],
  'golf-tech': [
    { name: 'Spreadsheet Swinger', tagline: '12-hdcp · tracks strokes gained like quarterly KPIs' },
    { name: 'The KPI Caddie', tagline: '15-hdcp · measures everything, improves slowly' },
    { name: 'PowerPoint Pro Golfer', tagline: '17-hdcp · once made a slide deck about swing plane' },
  ],
  'improve-game': [
    { name: 'Mulligan Manager', tagline: '16-hdcp · manages mulligans better than projects' },
    { name: 'The Back Nine Analyst', tagline: '14-hdcp · always shoots better on the back nine' },
    { name: 'VP of Fairway Strategy', tagline: '15-hdcp · has a strategy for everything except putting' },
  ],
  'golf-accessories': [
    { name: 'The Cubicle Caddie', tagline: '15-hdcp · keeps a putter under the desk' },
    { name: 'Conference Call Golfer', tagline: '18-hdcp · practices grip during all-hands meetings' },
    { name: 'The Commuter Caddie', tagline: '16-hdcp · listens to golf podcasts in traffic' },
  ],
  'golf-lifestyle': [
    { name: 'The Lunch Break Golfer', tagline: '13-hdcp · has played 9 holes in 58 minutes' },
    { name: '5PM Tee Time', tagline: '15-hdcp · leaves at 4:59, tees off at 5:15' },
    { name: 'Out-of-Office Golfer', tagline: '17-hdcp · sets auto-reply, heads to the course' },
  ],
};
// Pick a persona deterministically from the article ID so it's consistent across builds
const catPersonas = PERSONAS[article.category] ?? PERSONAS['gear-reviews'];
const personaIndex = article.id.split('').reduce((sum: number, c: string) => sum + c.charCodeAt(0), 0) % catPersonas.length;
const persona = catPersonas[personaIndex];

// Cross-category "Cubicle Golfer" tips — shown on ALL article pages with category-aware links
const CUBICLE_TIPS_BY_CAT: Record<string, Array<{ slug: string; label: string }>> = {
  'gear-reviews': [
    { slug: '/office-hacks/', label: 'Office Hacks Hub — All Tips for 9-to-5 Golfers' },
    { slug: '/golf-practice-drills-at-home/', label: '7 Practice Drills You Can Do at Home in 15 Minutes' },
    { slug: '/how-to-sneak-in-more-golf-rounds/', label: 'How to Sneak In More Golf Rounds With a Day Job' },
    { slug: '/best-golf-gear-under-100/', label: 'Best Golf Gear Under $100 for Weekend Golfers' },
  ],
  'golf-tech': [
    { slug: '/office-hacks/', label: 'Office Hacks Hub — All Tips for 9-to-5 Golfers' },
    { slug: '/golf-practice-drills-at-home/', label: '7 Practice Drills at Home (No Range Needed)' },
    { slug: '/golf-fitness-office-golfer/', label: 'Golf Fitness Routines for the Office Golfer' },
    { slug: '/best-golf-gear-under-100/', label: 'Best Golf Gear Under $100 for Weekend Golfers' },
  ],
  'improve-game': [
    { slug: '/office-hacks/', label: 'Office Hacks Hub — All Tips for 9-to-5 Golfers' },
    { slug: '/golf-fitness-office-golfer/', label: 'Golf Fitness Routines for the Office Golfer' },
    { slug: '/how-to-sneak-in-more-golf-rounds/', label: 'How to Sneak In More Golf Rounds With a Day Job' },
    { slug: '/best-beginner-golf-set-under-500/', label: 'Best Beginner Set Under $500' },
  ],
  'golf-accessories': [
    { slug: '/office-hacks/', label: 'Office Hacks Hub — All Tips for 9-to-5 Golfers' },
    { slug: '/golf-practice-drills-at-home/', label: '7 Practice Drills You Can Do at Home in 15 Minutes' },
    { slug: '/best-golf-gear-under-100/', label: 'Best Golf Gear Under $100 for Weekend Golfers' },
    { slug: '/how-to-practice-golf-at-home/', label: 'How to Practice Golf at Home' },
  ],
  'golf-lifestyle': [
    { slug: '/office-hacks/', label: 'Office Hacks Hub — All Tips for 9-to-5 Golfers' },
    { slug: '/golf-practice-drills-at-home/', label: '7 Practice Drills at Home (No Range Needed)' },
    { slug: '/best-golf-gear-under-100/', label: 'Best Golf Gear Under $100 for Weekend Golfers' },
    { slug: '/how-to-break-90/', label: 'How to Break 90 This Season' },
  ],
};
const cubicleGolferLinks = (CUBICLE_TIPS_BY_CAT[article.category] ?? CUBICLE_TIPS_BY_CAT['gear-reviews'])
  .filter(tip => tip.slug !== article.slug);

const BADGE_TO_PRODUCT: Record<string, Record<string, string>> = {
