    'BEST GPS WATCH':   'shot-scope-v5',
  },
};---

<BaseLayout {meta} {schemas} activeNav={article.category}>

  {/* Sticky bar for buying guides — uses first product with affiliate key */}
  {isBuyingGuide && (() => {
    // Try comparisonTable winner first, fall back to first badged section
    const topRow = article.comparisonTable?.rows?.find((r: any) => r.affiliateKey);
    const fallbackSection = !topRow
      ? article.sections?.find((s: any) => s.badge && (s.affiliateKey || BADGE_TO_PRODUCT[article.id]?.[s.badge]))
      : null;
    const fallbackKey = fallbackSection
      ? ((fallbackSection as any).affiliateKey || BADGE_TO_PRODUCT[article.id]?.[(fallbackSection as any).badge])
      : null;
    const topAff = topRow
      ? getAffiliateLink(topRow.affiliateKey)
      : (fallbackKey ? getAffiliateLink(fallbackKey) : null);
    const topName = topRow ? topRow.name : (fallbackSection as any)?.h2?.replace(/^Best [^:]+:\s*/i, '') ?? '';
    const topBadge = topRow ? (topRow.winner ? 'BEST PICK' : topRow.bestFor) : (fallbackSection as any)?.badge ?? 'TOP PICK';
    if (!topAff) return null;
    return (
      <StickyBar
        name={topName}
        price={topAff.price ?? ''}
        url={topAff.url}
        retailer={topAff.retailer}
        badge={topBadge}
      />
    );
  })()}

  <header class="art-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <a href={`/${CAT_SLUG[article.category]}/`}>{CAT_LABEL[article.category]}</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">{article.titleDisplay}</span>
    </nav>

    <span class={`art-tag-lg ${TAG_CLASS[article.tag] || 'tag-buy'}`}>{article.tag}</span>
    <h1>{article.titleDisplay}</h1>

  </header>

  <article class="art-content" itemscope itemtype="https://schema.org/Article" data-category={article.category} data-page-type={article.pageType}>

    <!-- ── Author / Trust Box ── -->
    {(() => {
      // ── Page-type bio mapping ─────────────────────────────────────────────
      const RANGEFINDER_IDS = ['rangefinders','best-golf-rangefinder-beginners','bushnell-vs-garmin-rangefinder','rangefinder-worth-it','rangefinder-vs-gps','best-golf-rangefinder-under-200'];
      const GPS_IDS         = ['gps-watches','best-gps-golf-watch-high-handicappers','rangefinder-vs-gps'];
      const BALL_IDS        = ['golf-balls','golf-ball-compression','pro-v1-vs-pro-v1x','best-golf-balls-slow-swing-speed','best-golf-balls-weekend-golfers','what-golf-ball-high-handicapper'];

      const isRangefinderPage = RANGEFINDER_IDS.includes(article.id);
      const isGpsPage         = GPS_IDS.includes(article.id);
      const isBallPage        = BALL_IDS.includes(article.id);
      const hasBio            = isRangefinderPage || isGpsPage || isBallPage;

      // ── Trust line per page type ──────────────────────────────────────────
      const trustLine = isRangefinderPage
        ? 'Every rangefinder on this page was independently purchased and ranged 200+ flags across 12 real rounds — not a demo day.'
        : isGpsPage
        ? 'Every GPS watch here was independently purchased and cross-checked against a laser rangefinder 50+ times per round across 12 rounds.'
        : isBallPage
        ? 'Every ball on this page was independently purchased and tested across 5 full rounds — tracking driver carry and wedge spin on the same holes each time.'
        : null;

      return (
        <div class="author-box">
          <a href="/about/" style="flex-shrink:0" aria-label="About Cubical Golfer">
            <img src="/images/cubicalgolfer-logo.jpg" alt="Cubical Golfer" class="author-avatar-img" width="48" height="48" />
          </a>
          <div style="flex:1">
            <span class="author-name">
              <a href="/about/" style="color:inherit;text-decoration:none">Cubical Golfer</a>
              <span style="font-size:11px;font-weight:500;color:var(--muted);margin-left:6px">15+ yrs · low-teens hdcp · all gear self-purchased</span>
            </span>
            <span class="author-meta">
              📖 {article.words} words &nbsp;·&nbsp;
              📅 Updated: {article.dateModified} &nbsp;·&nbsp;
              ⛳ <a href="/how-we-test/" style="color:inherit">How we test →</a>
            </span>

            {/* ── Expanded bio blurb — specific to page type ── */}
            {hasBio && (
              <details class="author-bio-details">
                <summary class="author-bio-toggle">About the reviewer →</summary>
                <p class="author-bio-text">
                  {isRangefinderPage && (
                    <>
                      We ranged 200+ flags across 12 rounds — on hilly parkland, tight tree-lined courses,
                      and coastal layouts — using the Bushnell Tour V6 Shift as our reference device.
                      Playing to a low-teens handicap means we face the same 150–175 yard approach decisions
                      a 15–22 handicapper does every round. We know the difference between ranging the flag
                      and ranging the tree behind it. <a href="/how-we-test/">Full testing methodology →</a>
                    </>
                  )}
                  {isGpsPage && (
                    <>
                      We cross-checked GPS yardage against a laser rangefinder on 50+ shots per round across
                      12 rounds — logging every time GPS distance differed from laser distance and why
                      (elevation, doglegs, partial holes). Reference watch: Garmin Approach S62.
                      Playing to a low-teens handicap, we make real course management decisions every round —
                      exactly the context a 15–22 handicapper needs. <a href="/how-we-test/">Full testing methodology →</a>
                    </>
                  )}
                  {isBallPage && (
                    <>
                      We tested 15 ball models over 5 rounds per ball — tracking driver carry and wedge spin
                      on the same 3 holes each round to isolate ball performance from swing variation.
                      At a low-teens handicap with a swing speed in the 88–92 mph range, our data reflects
                      what most 15–22 handicappers actually experience, not launch monitor results from
                      a tour fitting. <a href="/how-we-test/">Full testing methodology →</a>
                    </>
                  )}
                </p>
              </details>
            )}
          </div>
          <span class="verified-badge">✅ Independently Tested</span>
        </div>
      );
    })()}

    <!-- Quick Verdict box for buying guides -->
    {article.comparisonTable && (
      <div class="verdict-quick" id="quick-verdict" aria-label="Quick Verdict — Top Picks" itemscope itemtype="https://schema.org/ItemList">
        <p class="verdict-quick-title">⚡ Quick Verdict</p>
        <div class="verdict-quick-picks">
          {article.comparisonTable.rows.slice(0, 3).map((row, i) => {
            const vpAff = row.affiliateKey ? getAffiliateLink(row.affiliateKey) : null;
            const vpUrl = vpAff?.url || (row as any).url || '#';
            return (
              <a
                href={vpUrl}
                target="_blank"
                rel="nofollow noopener sponsored"
                class={`verdict-pick ${row.winner ? 'verdict-pick--winner' : ''}`}
                aria-label={`${row.bestFor}: ${row.name} — ${row.price}`}
              >
                <span class="verdict-pick-label">{row.bestFor}</span>
                <span class="verdict-pick-name">{row.name}</span>
                <span class="verdict-pick-price">{row.price}</span>
                <span class="verdict-pick-cta">{vpUrl !== '#' ? 'See price →' : ''}</span>
              </a>
            );
          })}
        </div>
      </div>
    )}

    <div class="intro-box" id="article-intro" role="note" aria-label="Article summary"><p>{article.intro}</p></div>

    {/* ── Trust line + Testing Standards badge (buying guides with specific page type) ── */}
    {isBuyingGuide && (() => {
      const RANGEFINDER_IDS = ['rangefinders','best-golf-rangefinder-beginners','bushnell-vs-garmin-rangefinder','rangefinder-worth-it','rangefinder-vs-gps','best-golf-rangefinder-under-200'];
      const GPS_IDS         = ['gps-watches','best-gps-golf-watch-high-handicappers','rangefinder-vs-gps'];
      const BALL_IDS        = ['golf-balls','golf-ball-compression','pro-v1-vs-pro-v1x','best-golf-balls-slow-swing-speed','best-golf-balls-weekend-golfers','what-golf-ball-high-handicapper'];

      const isRangefinderPage = RANGEFINDER_IDS.includes(article.id);
      const isGpsPage         = GPS_IDS.includes(article.id);
      const isBallPage        = BALL_IDS.includes(article.id);
      const trustLine = isRangefinderPage
        ? 'Every rangefinder here was independently purchased and ranged 200+ flags across 12 real rounds — not a demo day.'
        : isGpsPage
        ? 'Every GPS watch here was independently purchased and cross-checked against a laser rangefinder 50+ times per round across 12 rounds.'
        : isBallPage
        ? 'Every ball here was independently purchased and tested across 5 full rounds, tracking driver carry and wedge spin on the same holes each time.'
        : null;

      if (!trustLine) return null;
      return (
        <div class="trust-line">
          <span class="trust-line__text">🔍 {trustLine}</span>
        </div>
      );
    })()}

    {/* ── Testing Standards badge — buying guides only ── */}
    {isBuyingGuide && (
      <div class="testing-badge" aria-label="Testing standards">
        <span class="testing-badge__item">✓ Tested over 10+ real rounds</span>
        <span class="testing-badge__item">✓ Independently purchased — not gifted</span>
        <span class="testing-badge__item">✓ Updated {article.dateModified.slice(0,7).replace('-','/')}</span>
      </div>
    )}

    {/* ── Inline affiliate disclosure ── */}
    {isBuyingGuide && (
      <p class="inline-disclosure">
        ⚖️ <em>This page contains affiliate links — we earn a small commission if you buy through them, at no extra cost to you. <a href="/about/">Editorial Policy →</a></em>
      </p>
    )}

    {/* ── Above-the-fold ProductCard grid (top 3 picks) ── */}
    {article.comparisonTable && (() => {
      const topRows = article.comparisonTable.rows.slice(0, 3).filter((r: any) => r.affiliateKey);
      if (!topRows.length) return null;
      return (
        <div class="product-card-grid" aria-label="Top picks">
          {topRows.map((row: any) => {
            const aff = getAffiliateLink(row.affiliateKey);
            return (
              <ProductCard
                name={row.name}
                badge={row.winner ? 'BEST PICK' : row.bestFor}
                price={aff.price}
                retailer={aff.retailer}
                url={aff.url}
                label={aff.label}
                winner={row.winner}
                emoji={article.emoji}
                productId={row.affiliateKey}
                imgSrc={aff.imgSrc ?? undefined}
                imgAlt={aff.imgAlt ?? row.name}
                benefits={aff.benefits}
              />
            );
          })}
        </div>
      );
    })()}

    {article.toc && article.toc.length > 0 && (
      <nav class="toc" aria-label="Table of contents">
        <p class="toc-heading">In this guide</p>
        <ol>
          {article.toc.map(item => <li>{item}</li>)}
        </ol>
      </nav>
    )}

    {article.comparisonTable && (
      <div class="cmp-wrap">
        <table class="cmp-table" role="table">
          <caption class="sr-only">Comparison table: {article.titleDisplay}</caption>
          <thead>
            <tr>
              {article.comparisonTable.headers.map((h: string) => <th scope="col">{h}</th>)}
              <th scope="col" class="cmp-th-buy">Buy</th>
            </tr>
          </thead>
          <tbody>
            {article.comparisonTable.rows.map((row: any) => {
              const rowAff = row.affiliateKey ? getAffiliateLink(row.affiliateKey) : null;
              return (
                <tr class={row.winner ? 'cmp-winner' : ''}>
                  <td>
                    {row.name}
                    {row.winner && <span class="badge-best">BEST PICK</span>}
                  </td>
                  <td>{row.bestFor}</td>
                  <td>{row.price}</td>
                  <td>{row.feature1}</td>
                  <td>{row.feature2}</td>
                  <td class="cmp-td-buy">
                    {rowAff ? (
                      <a
                        href={rowAff.url}
                        class="cmp-buy-btn"
                        target="_blank"
                        rel="nofollow noopener sponsored"
                        aria-label={`Check price for ${row.name} on ${rowAff.retailer}`}
                      >
                        {rowAff.price} →
                      </a>
                    ) : (
                      <span class="cmp-no-link">—</span>
                    )}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
        {/* ── Bottom Line — directs undecided readers ── */}
        {(article as any).bottomLine && (
          <div class="cmp-bottom-line"
               aria-label="Our bottom-line recommendation"
               set:html={(article as any).bottomLine}
          />
        )}
      </div>
    )}

    {article.sections.map((section, idx) => {
      const sectionAffKey = (section as any).affiliateKey;
      const productId = sectionAffKey || BADGE_TO_PRODUCT[article.id]?.[section.badge || ''];
      const aff = (productId && productId.length > 0) ? getAffiliateLink(productId) : null;
      return (
        <div class="art-section">
          <h2>{section.h2}</h2>
          {section.badge && <span class="badge-pill">{section.badge}</span>}
          {(section as any).rating && (
            <div class="product-rating" aria-label={`Rated ${(section as any).rating} out of 5 stars`}>
              <span class="stars" aria-hidden="true">
                {'★'.repeat(Math.floor((section as any).rating))}{'☆'.repeat(5 - Math.floor((section as any).rating))}
              </span>
              <span class="rating-score">{(section as any).rating}/5</span>
              {(section as any).ratingCount && (
                <span class="rating-count">({(section as any).ratingCount} reviews)</span>
              )}
            </div>
          )}

          {/* Product image — only for migrated articles (no comparisonTable). Articles with comparisonTable already show images in the top ProductCard grid. */}
          {section.badge && !article.comparisonTable && (() => {
            const rawSectionImg = aff ? (aff.imgSrc ?? `/images/products/${productId}.webp`) : (productId ? `/images/products/${productId}.webp` : null);
            const sectionImgSrc = rawSectionImg ?? null;
            const sectionImgAlt = aff ? (aff.imgAlt ?? section.h2) : section.h2;
            return (
              <div class="product-img-wrap">
                {sectionImgSrc ? (
                  <img
                    src={sectionImgSrc}
                    alt={sectionImgAlt}
                    width="280"
                    height="200"
                    loading="lazy"
                    decoding="async"
                    class="product-section-img"
                    onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                  />
                ) : null}
                <div class="product-img-fallback" style={sectionImgSrc ? 'display:none' : ''}>
                  <span aria-hidden="true" style="font-size:52px">{article.emoji}</span>
                  <span style="font-size:12px;color:var(--muted);margin-top:8px;text-align:center">Photo coming soon</span>
                </div>
              </div>
            );
          })()}

          {section.body && section.body.trim() && <p>{section.body}</p>}
          {section.price && <p class="price-note">💰 Price: {section.price}</p>}
          {/* ── Inline HTML table (e.g. compression chart by swing speed) ── */}
          {(section as any).tableHtml && (
            <div class="cmp-wrap section-table" set:html={(section as any).tableHtml} />
          )}
          {/* ── Affiliate callout block (after chart) ── */}
          {(section as any).calloutHtml && (
            <div set:html={(section as any).calloutHtml} />
          )}
          {section.items && section.items.length > 0 && (
            <ul>
              {section.items.map((item: any) => (
                <li>
                  {item.affiliateKey ? (
                    <>
                      <a
                        href={getAffiliateLink(item.affiliateKey).url}
                        target="_blank"
                        rel="nofollow noopener sponsored"
                        style="font-weight:700;color:var(--green)"
                      >{item.name}</a>{' '}— {item.desc}
                    </>
                  ) : (
                    <><strong>{item.name}</strong> — {item.desc}</>
                  )}
                </li>
              ))}
            </ul>
          )}

          {/* Pros / Cons — rendered when section has direct pros/cons arrays (migrated pages) */}
          {((section as any).pros?.length > 0 || (section as any).cons?.length > 0) && (
            <div class="pros-cons">
              {(section as any).pros?.length > 0 && (
                <div class="pros">
                  <h4>Pros</h4>
                  <ul>
                    {(section as any).pros.map((p: string) => <li>{p}</li>)}
                  </ul>
                </div>
              )}
              {(section as any).cons?.length > 0 && (
                <div class="cons">
                  <h4>Cons</h4>
                  <ul>
                    {(section as any).cons.map((c: string) => <li>{c}</li>)}
                  </ul>
                </div>
              )}
            </div>
          )}

          {/* Why Buy — shown when section has a why field */}
          {(section as any).why && (section as any).why.trim() && (
            <div class="why-buy">
              <strong>Why a weekend golfer buys this:</strong> {(section as any).why}
            </div>
          )}

          {/* Direct URL CTA — for sections with a url field but no affiliateKey */}
          {(section as any).url && (section as any).url !== '#' && !aff && (
            <a
              href={(section as any).url}
              target="_blank"
              rel="nofollow noopener sponsored"
              class="btn-cta btn-cta--primary"
            >
              Check Price on Amazon →
            </a>
          )}

          {/* Affiliate buy button — using AffiliateCTA component */}
          {aff && (
            <AffiliateCTA
              url={aff.url}
              price={aff.price}
              name={section.h2}
              retailer={aff.retailer}
              label={(section as any).ctaLabel || aff.label}
              variant={((section.badge?.includes('BEST OVERALL') || section.badge?.includes('BEST PICK')) || (section.badge && article.sections.slice(0, idx).every((s: any) => !s.badge))) ? 'primary' : 'secondary'}
              disclosure={true}
            />
          )}
        </div>
      );
    })}

    {article.faq && article.faq.length > 0 && (
      <div class="art-faq">
        <h2>Frequently Asked Questions</h2>
        {article.faq.map(({ q, a }) => (
          <details class="faq-item">
            <summary>{q}</summary>
            <div class="faq-answer">{a}</div>
          </details>
        ))}
      </div>
    )}

    {related.length > 0 && (
      <div class="rel-cluster">
        <h3>Related Guides</h3>
        <div class="rel-links">
          {related.map(link => <a href={link.slug}>{link.label}</a>)}
        </div>
      </div>
    )}

    <div class="art-cta">
      <h3>Get the Free Golf Gear Buying Guide</h3>
      <p>The cheat sheet every weekend golfer needs before buying anything new. No spam, ever.</p>
      <a href="/" class="btn-gold" style="display:inline-block;margin-top:8px;">Browse All Guides →</a>
    </div>

  </article>

  {sameCategory.length > 0 && (
    <section class="related-section" aria-label="More guides">
      <h2>More {CAT_LABEL[article.category]} Guides</h2>
      <div class="related-grid">
        {sameCategory.map(a => (
          <a href={a.slug} class="article-card" aria-label={`Read: ${a.titleDisplay}`}>
            <div class={`art-thumb ${a.thumb}`}>
              <span class={`art-badge ${TAG_CLASS[a.tag] || 'tag-buy'}`}>{a.tag}</span>
              <span aria-hidden="true">{a.emoji}</span>
            </div>
            <div class="art-body">
              <h3>{a.titleDisplay}</h3>
              <p>{a.excerpt}</p>
              <div class="art-foot">
                <span class="art-words">{a.words} · Updated 2026</span>
                <span class="art-read">Read guide →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

</BaseLayout>
