  },
  'handicap': {
    'BEST RANGEFINDER':  'precision-pro-nx9-hd',
    'BEST STAT TRACKER': 'arccos-caddie-sensors',
    'BEST PRACTICE AID': 'putting-mirror',
  },
  'accessories-25': {
    'BEST UNDER $15': 'alignment-sticks',
    'BEST UNDER $30': 'putting-mirror',
    'BEST UNDER $20': 'frogger-amphibian-towel',
  },
  'accessories-50': {
    'BEST UNDER $15': 'alignment-sticks',
    'BEST UNDER $30': 'putting-mirror',
    'BEST UNDER $40': 'eyeline-putting-cup',
  },
  'sneak-rounds': {
    'BEST FOR FAST ROUNDS': 'shot-scope-v5',
    'BEST TOUCHSCREEN GPS': 'garmin-approach-s42',
    'BEST RANGEFINDER':     'precision-pro-nx9-hd',
  },
  'fitness': {
    'BEST MOBILITY TOOL': 'alignment-sticks',
    'BEST STAT TRACKER':  'arccos-caddie-sensors',
    'BEST POWER TRACKER': 'rapsodo-mlm2pro',
  },
  'courses': {
    'BEST RANGEFINDER': 'bushnell-tour-v6-shift',
