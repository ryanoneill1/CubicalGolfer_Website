  },
};

// Product schema for buying-guide sections with badges + affiliate links
if (isBuyingGuide) {
  for (const section of article.sections) {
    if (!section.badge) continue;
    const sectionAffKey = (section as any).affiliateKey;
    const pid = (sectionAffKey !== undefined)
      ? sectionAffKey
      : (BADGE_TO_PRODUCT[article.id]?.[section.badge || ''] ?? '');
    if (!pid) continue;
    const aff = getAffiliateLink(pid);
    if (!aff?.url) continue;
    // FIX: Pass price, retailer, image — required by Google Product schema
    schemas.push(buyingGuideProductSchema(
      section, aff.url, aff.price, aff.retailer,
      aff.imgSrc ? `https://www.cubicalgolfer.com${aff.imgSrc}` : undefined
    ));
  }
}
---

<BaseLayout {meta} {schemas} activeNav={article.category}>

  {/* Sticky bar for buying guides */}
  {isBuyingGuide && (() => {
    const topRow = article.comparisonTable?.rows?.find((r: any) => r.affiliateKey);
    const topAff = topRow ? getAffiliateLink(topRow.affiliateKey) : null;
    if (!topAff) return null;
    return (
      <StickyBar
        name={topRow.name}
        price={topAff.price ?? ''}
        url={topAff.url}
        retailer={topAff.retailer}
        badge={topRow.winner ? 'BEST PICK' : topRow.bestFor}
      />
    );
  })()}

  {/* ── HERO ───────────────────────────────────────────────────────────────── */}
  <header class="art-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <a href={`/${CAT_SLUG[article.category]}/`}>{CAT_LABEL[article.category]}</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">{article.titleDisplay}</span>
    </nav>

    <span class={`art-tag-lg ${TAG_CLASS[article.tag] || 'tag-buy'}`}>{article.tag}</span>
    <h1>{article.titleDisplay}</h1>

    <div class="author-box">
      <a href="/about/" style="flex-shrink:0" aria-label="About Ryan O. — Cubical Golfer">
        <img src={AUTHOR_BYLINE.avatar} alt="Ryan O., Cubical Golfer founder and gear editor" class="author-avatar-img" width="44" height="44" />
      </a>
      <div style="flex:1">
        <span class="author-name">
          <a href="/about/">{AUTHOR_BYLINE.name}</a>
          <span style="font-size:11px;font-weight:400;color:#556B5C;margin-left:6px">{AUTHOR_BYLINE.tagline}</span>
        </span>
        <span class="author-meta">
          📖 {article.words} words &nbsp;·&nbsp;
          📅 Updated: {article.dateModified} &nbsp;·&nbsp;
          ⛳ <a href="/how-we-test/">How we test →</a>
        </span>
      </div>
      <span class="verified-badge">Independently tested</span>
    </div>
  </header>

  {/* ── WHY TRUST THIS GUIDE — E-E-A-T trust section (buying guides + reviews + listicles) ── */}
  {(isBuyingGuide || article.pageType === 'listicle') && (
    <div class="trust-card">
      <h3 class="trust-card__heading">Why Trust This Guide</h3>
      <ul class="trust-card__list">
        <li><strong>Every product purchased</strong> — bought with our own money, no manufacturer loans or freebies</li>
        <li><strong>10+ real rounds per product</strong> — tested on actual courses, not a simulator or fitting bay</li>
        <li><strong>12-handicap perspective</strong> — written for weekend golfers, not scratch players or tour pros</li>
        <li><strong>Updated {article.dateModified}</strong> — prices and picks reviewed regularly</li>
      </ul>
      <a href="/how-we-test/" class="trust-card__link">See full testing methodology →</a>
    </div>
  )}

  {/* ── ARTICLE BODY ────────────────────────────────────────────────────────── */}
  <article class="art-content">

    {/* QUICK ANSWER BOX — buying guides only */}
    {(article as any).quickAnswerProduct && article.bottomLine && (() => {
      const qaAff = getAffiliateLink((article as any).quickAnswerProduct);
      const productCount = article.comparisonTable?.rows?.length ?? article.sections?.length ?? 0;
      if (!qaAff?.url) return null;
      return (
        <div class="quick-answer-box">
          <div class="quick-answer-header">⚡ Quick Answer</div>
          <p class="quick-answer-text" set:html={article.bottomLine} />
          <a href={qaAff.url} class="quick-answer-cta" target="_blank"
            rel="nofollow noopener sponsored"
            aria-label={`Check price for our #1 pick`}>
            Our #1 Pick: {qaAff.price} at {qaAff.retailer} — Check Today's Price →
          </a>
          <p class="quick-answer-more">Read the full guide below for all {productCount} products tested.</p>
        </div>
      );
    })()}

    {/* BOTTOM LINE — shows as "Our Verdict" ONLY when Quick Answer box is NOT rendered */}
    {article.bottomLine && !(article as any).quickAnswerProduct && (
      <div class="bottom-line-box" role="note" aria-label="Our verdict">
        <p class="bottom-line-label">Our Verdict</p>
        <p set:html={article.bottomLine} />
      </div>
    )}

    {/* QUICK VERDICT CARDS — top picks at a glance */}
    {isBuyingGuide && article.comparisonTable?.rows && (() => {
      const topRows = article.comparisonTable.rows.filter((r: any) => r.affiliateKey).slice(0, 3);
      if (topRows.length === 0) return null;
      return (
        <div class="product-card-grid">
          {topRows.map((row: any) => {
            const aff = getAffiliateLink(row.affiliateKey);
            return (
              <ProductCard
                name={row.name}
                badge={row.winner ? 'BEST PICK' : row.bestFor}
                price={aff.price}
                retailer={aff.retailer}
                url={aff.url}
                label={aff.label}
                winner={row.winner}
                emoji={article.emoji}
                imgSrc={(aff as any).imgSrc}
                imgAlt={(aff as any).imgAlt ?? row.name}
                benefits={(aff as any).benefits}
              />
            );
          })}
        </div>
      );
    })()}

    {/* INTRO */}
    <div class="intro-box"><p>{article.intro}</p></div>

    {/* UPDATE LOG — collapsible changelog */}
    {(article as any).updateLog && (article as any).updateLog.length > 0 && (
      <details class="update-log" style="margin:16px 0 24px;border:1px solid var(--border);border-radius:8px;background:#fff;font-size:13px;">
        <summary style="padding:10px 16px;cursor:pointer;font-weight:600;color:var(--muted);list-style:none;display:flex;align-items:center;gap:8px;">
          <span style="font-size:15px;">📋</span>
          Update Log — last updated {(article as any).updateLog[0].date}
          <span style="margin-left:auto;font-size:11px;color:var(--muted);opacity:.6;">▼</span>
        </summary>
        <div style="padding:4px 16px 14px;border-top:1px solid var(--border);">
          {(article as any).updateLog.map((entry: {date: string; note: string}) => (
            <div style="display:flex;gap:10px;padding:6px 0;border-bottom:1px solid rgba(0,0,0,.04);">
              <span style="flex-shrink:0;font-weight:600;color:var(--green);min-width:90px;">{entry.date}</span>
              <span style="color:var(--body);">{entry.note}</span>
            </div>
          ))}
        </div>
      </details>
    )}

    {/* TABLE OF CONTENTS */}
    {article.toc && article.toc.length > 0 && (
      <nav class="toc" aria-label="Table of contents">
        <p class="toc-heading">In this guide</p>
        <ol>
          {article.toc.map(item => <li>{item}</li>)}
        </ol>
      </nav>
    )}

    {/* COMPARISON TABLE */}
    {article.comparisonTable && (() => {
      const headers = article.comparisonTable.headers;
      // FIX: Only render bestFor as a column when headers include a "Best For" column.
      // Previously bestFor was hardcoded as column 2, causing data to shift right
      // on any article whose headers don't include "Best For" (23 pages affected).
      const hasBestForHeader = headers.some((h: string) => /best\s*for/i.test(h));
      const innerHeaderCount = headers.length - 1; // minus the product-name column

      return (
      <div class="cmp-wrap">
        <table class="cmp-table" role="table">
          <caption class="sr-only">Comparison table: {article.titleDisplay}</caption>
          <thead>
            <tr>
              {headers.map((h: string) => <th scope="col" tabindex="0" role="button" aria-label={`Sort by ${h}`}>{h}</th>)}
              <th scope="col" class="cmp-th-buy">Buy</th>
            </tr>
          </thead>
          <tbody>
            {article.comparisonTable.rows.map((row: any) => {
              const rowAff = row.affiliateKey ? getAffiliateLink(row.affiliateKey) : null;
              // Build inner cells to match header order
              const innerCells: string[] = [];
              if (hasBestForHeader && row.bestFor) innerCells.push(row.bestFor);
              if (row.price) innerCells.push(row.price);
              if (row.feature1) innerCells.push(row.feature1);
              if (row.feature2) innerCells.push(row.feature2);
              // Pad to match header count so Buy column stays aligned
              while (innerCells.length < innerHeaderCount) innerCells.push('');
              // Trim if more data fields than headers (e.g. head-to-head pages)
              const trimmedCells = innerCells.slice(0, innerHeaderCount);
              return (
                <tr class={row.winner ? 'cmp-winner' : ''}>
                  <td>
                    {rowAff ? (
                      <a href={rowAff.url} target="_blank" rel="nofollow noopener sponsored"
                        class="cmp-product-link">{row.name}</a>
                    ) : row.name}
                    {row.winner && <span class="badge-best">BEST PICK</span>}
                  </td>
                  {trimmedCells.map((cell: string) => <td>{cell}</td>)}
                  <td class="cmp-td-buy">
                    {rowAff ? (
                      <a href={rowAff.url} class="cmp-buy-btn" target="_blank"
                        rel="nofollow noopener sponsored"
                        aria-label={`Check price for ${row.name} on ${rowAff.retailer}`}>
                        {row.price} →
                      </a>
                    ) : (
                      <span class="cmp-no-link">—</span>
                    )}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
      );
    })()}

    {/* TESTING NOTES */}
    {article.testingNotes && (
      <div class="testing-note" role="note">
        {article.testingNotes}
        <a href="/how-we-test/">See full testing methodology</a>
      </div>
    )}
    {isCommercial && !article.testingNotes && (
      <div class="testing-note" role="note">
        All products on this page were independently purchased and tested across real rounds on actual golf courses.
        No manufacturer loans. No sponsored placements.
        <a href="/how-we-test/">See our full testing process</a>
      </div>
    )}

    {/* INDIVIDUAL PRODUCT SECTIONS */}
    {article.sections.map((section, idx) => {
      const sectionAffKey = (section as any).affiliateKey;
      const productId = (sectionAffKey !== undefined)
        ? sectionAffKey   // explicit affiliateKey on section takes priority ('' = no product)
        : (BADGE_TO_PRODUCT[article.id]?.[section.badge || ''] ?? '');
      const aff = productId ? getAffiliateLink(productId) : null;
      // FIX 2: Show mid-page email capture after section 3 on long pages
      const showMidEmail = idx === 2 && isBuyingGuide && article.sections.length >= 5;
      return (
        <>
        <div class="art-section">
          <h2>{section.h2}</h2>
          {section.badge && <span class="badge-pill">{section.badge}</span>}

          {(section as any).rating && (
            <div class="product-rating" aria-label={`Rated ${(section as any).rating} out of 5 stars`}>
              <span class="stars" aria-hidden="true">
                {'★'.repeat(Math.floor((section as any).rating))}{'☆'.repeat(5 - Math.floor((section as any).rating))}
              </span>
              <span class="rating-score">{(section as any).rating}/5</span>
              {(section as any).ratingCount && (
                <span class="rating-count">({(section as any).ratingCount} reviews)</span>
              )}
            </div>
          )}

          {/* Product image — only shown when a real product key exists */}
          {section.badge && isBuyingGuide && productId && (() => {
            const sectionImgSrc = aff ? (aff as any).imgSrc : null;
            const sectionImgAlt = aff ? (aff as any).imgAlt ?? section.h2 : section.h2;
            const imgElement = sectionImgSrc ? (
              <img src={sectionImgSrc} alt={sectionImgAlt} width="280" height="200"
                loading="lazy" decoding="async" class="product-section-img"
                onerror="this.src='/images/products/placeholder.webp'" />
            ) : (
              <div class="product-img-fallback">
                <span aria-hidden="true" style="font-size:48px">{article.emoji}</span>
              </div>
            );
            return (
              <div class="product-img-wrap">
                {/* FIX: Product images no longer clickable — reduces CTA noise.
                    Buy column and product name links remain as conversion points. */}
                {imgElement}
              </div>
            );
          })()}

          {section.body && section.body.trim() && <p>{section.body}</p>}

          {/* Inline section image — for editorial/lifestyle images in article body */}
          {(section as any).sectionImage && (() => {
            const secImg = (
              <img src={(section as any).sectionImage} alt={(section as any).sectionImageAlt ?? section.h2}
                width="680" height="400" loading="lazy" decoding="async"
                style="max-width:100%;height:auto;border-radius:12px;"
                onerror="this.style.display='none'" />
            );
            return (
              <figure style="margin:24px 0;text-align:center;position:relative;">
                {/* FIX: Section images no longer clickable — same rationale as product images */}
                {secImg}
              </figure>
            );
          })()}

          {/* Inline cubicle golfer callout — contextual cross-link inside article body */}
          {(section as any).callout && (
            <div style="margin:20px 0;padding:16px 20px;background:#f0f7f2;border-left:4px solid var(--green);border-radius:0 8px 8px 0;">
              <p style="margin:0;font-size:14px;line-height:1.6;color:var(--body);">
                🏢 <strong>Cubicle Golfer Tip:</strong>{' '}
                {(section as any).callout.text}{' '}
                <a href={(section as any).callout.link} style="color:var(--green);font-weight:700;text-decoration:underline;">
                  {(section as any).callout.label} →
                </a>
              </p>
            </div>
          )}

          {/* Price is now shown in the CTA button below */}

          {/* PROS / CONS — new in v2 */}
          {((section.pros && section.pros.length > 0) || (section.cons && section.cons.length > 0)) && (
            <div class="pros-cons-grid">
              {section.pros && section.pros.length > 0 && (
                <ul class="pros-list" aria-label="Pros">
                  <span class="pros-list-label">Pros</span>
                  {section.pros.map(pro => <li>{pro}</li>)}
                </ul>
              )}
              {section.cons && section.cons.length > 0 && (
                <ul class="cons-list" aria-label="Cons">
                  <span class="cons-list-label">Cons</span>
                  {section.cons.map(con => <li>{con}</li>)}
                </ul>
              )}
            </div>
          )}

          {section.items && section.items.length > 0 && (
            <ul>
              {section.items.map((item: any) => (
                <li>
                  {item.affiliateKey ? (
                    <>
                      <a href={getAffiliateLink(item.affiliateKey).url}
                        target="_blank" rel="nofollow noopener sponsored"
                        style="font-weight:700;color:var(--green)"
                      >{item.name}</a>{' — '}{item.desc}
                    </>
                  ) : (
                    <><strong>{item.name}</strong> — {item.desc}</>
                  )}
                </li>
              ))}
            </ul>
          )}

          {aff && (
            <AffiliateCTA
              url={aff.url} price={aff.price} name={section.h2}
              retailer={aff.retailer} label={aff.label}
              variant={section.badge?.includes('BEST OVERALL') || section.badge?.includes('BEST PICK') ? 'secondary' : 'primary'}
              disclosure={true}
              dateChecked={article.dateModified}
              isWinner={section.badge?.includes('BEST OVERALL') || section.badge?.includes('EDITOR') || section.badge?.includes('BEST PICK') || false}
            />
          )}
        </div>
        {showMidEmail && (
          <EmailCapture
            heading="Before you decide — grab the cheat sheet"
            variant="inline"
            idSuffix="-inline"
          />
        )}
        </>
      );
    })}

    {/* WHO SHOULD BUY / SKIP — required on buying guides */}
    {(article.whoFor || article.whoSkip) && (
      <div class="who-box">
        <h2 class="who-box-heading">Who Should Buy This — And Who Should Skip It</h2>
        {article.whoFor && article.whoFor.length > 0 && (
          <div class="who-buy">
            <span class="who-label">Buy if you…</span>
            <ul>
              {article.whoFor.map(item => <li>{item}</li>)}
            </ul>
          </div>
        )}
        {article.whoSkip && article.whoSkip.length > 0 && (
          <div class="who-skip">
            <span class="who-label">Skip if you…</span>
            <ul>
              {article.whoSkip.map(item => <li>{item}</li>)}
            </ul>
          </div>
        )}
      </div>
    )}

    {/* FAQ */}
    {article.faq && article.faq.length > 0 && (
      <div class="art-faq">
        <h2>Frequently Asked Questions</h2>
        {article.faq.map(({ q, a }) => (
          <details class="faq-item">
            <summary>{q}</summary>
            <div class="faq-answer">{a}</div>
          </details>
        ))}
      </div>
    )}

    {/* RELATED GUIDES */}
    {related.length > 0 && (
      <div class="rel-cluster">
        <h3>Related Guides</h3>
        <div class="rel-links">
          {related.map(link => <a href={link.slug}>{link.label}</a>)}
        </div>
      </div>
    )}

    {/* MORE FOR CUBICLE GOLFERS — cross-category links on ALL article pages */}
    {cubicleGolferLinks.length > 0 && (
      <div class="rel-cluster" style="background:var(--green);border:none;">
        <h3 style="color:var(--gold);font-size:13px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;margin-bottom:14px;">🏢 More for Cubicle Golfers</h3>
        <p style="color:rgba(255,255,255,.7);font-size:14px;margin-bottom:16px;line-height:1.6;">
          You work 9-to-5. Golf is your weekend reset. These guides are built for your schedule.
        </p>
        <div class="rel-links">
          {cubicleGolferLinks.map(tip => (
            <a href={tip.slug} style="background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.12);color:#fff;">
              {tip.label}
            </a>
          ))}
        </div>
      </div>
    )}

    {/* AFFILIATE DISCLOSURE — required on all commercial pages */}
    {isCommercial && (
      <div class="disclosure-box" role="note" aria-label="Affiliate disclosure">
        Affiliate disclosure: some links on this page earn us a small commission at no extra
        cost to you. We purchased all products independently — commissions never affect our
        rankings or recommendations.
        <a href="/about/" class="disclosure-link">Learn more about how we work</a>
      </div>
    )}

    {/* UPDATE STAMP */}
    <div class="update-stamp" aria-label="Last updated">Last updated: {article.dateModified}</div>

    {/* SOURCES & REFERENCES */}
    {(article as any).sources && (article as any).sources.length > 0 && (
      <div class="update-stamp" style="margin-top:12px;font-size:12px;line-height:1.8;">
        <strong style="font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);">Sources & References</strong>
        <div style="margin-top:6px;">
          {(article as any).sources.map((src: {label: string; url: string}, i: number) => (
            <span>
              <a href={src.url} target="_blank" rel="noopener noreferrer nofollow" style="color:var(--green);text-decoration:underline;">{src.label}</a>
              {i < (article as any).sources.length - 1 && <span style="color:var(--muted);margin:0 8px;">·</span>}
            </span>
          ))}
        </div>
      </div>
    )}

    {/* BOTTOM CTA */}
    <div class="art-cta">
      <h3>Get the Free Golf Gear Buying Guide</h3>
      <p>The cheat sheet every weekend golfer needs before buying anything new. No spam, ever.</p>
      <a href="/" class="btn-gold" style="display:inline-block;margin-top:8px;">Browse All Guides →</a>
    </div>

  </article>

  {/* ── Prev / Next Navigation ───────────────────────────────────────── */}
  {(prevArticle || nextArticle) && (
    <nav class="prev-next-nav" aria-label="Previous and next articles">
      {prevArticle ? (
        <a href={prevArticle.slug} class="prev-next-link prev-next-link--prev">
          <span class="prev-next-label">← Previous</span>
          <span class="prev-next-title">{prevArticle.titleDisplay}</span>
        </a>
      ) : <span />}
      {nextArticle ? (
        <a href={nextArticle.slug} class="prev-next-link prev-next-link--next">
          <span class="prev-next-label">Next →</span>
          <span class="prev-next-title">{nextArticle.titleDisplay}</span>
        </a>
      ) : <span />}
    </nav>
  )}

  {/* SAME-CATEGORY CARD GRID */}
  {sameCategory.length > 0 && (
    <section class="related-section" aria-label="More guides">
      <h2>More {CAT_LABEL[article.category]} Guides</h2>
      <div class="related-grid">
        {sameCategory.map(a => (
          <a href={a.slug} class="article-card" aria-label={`Read: ${a.titleDisplay}`}>
            <div class={`art-thumb ${(a as any).thumbnail ? '' : a.thumb}`}>
              <span class={`art-badge ${TAG_CLASS[a.tag] || 'tag-buy'}`}>{a.tag}</span>
              {(a as any).thumbnail ? (
                <img src={(a as any).thumbnail} alt={a.titleDisplay} loading="lazy" decoding="async"
                  class="art-thumb__img" onerror="this.style.display='none'" />
              ) : (
                <span aria-hidden="true">{a.emoji}</span>
              )}
            </div>
            <div class="art-body">
              <h3>{a.titleDisplay}</h3>
              <p>{a.excerpt}</p>
              <div class="art-foot">
                <span class="art-words">{a.words} · Updated 2026</span>
                <span class="art-read">Read guide →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
  {/* STICKY MOBILE CTA BAR — buying guides only */}
  {stickyProduct && (
    <div id="sticky-cta" class="sticky-cta" aria-label="Quick buy">
      <div class="sticky-cta__body">
        <span class="sticky-cta__name">{stickyProduct.name}</span>
        <span class="sticky-cta__price">{stickyProduct.price}</span>
      </div>
      <a href={stickyProduct.url} class="sticky-cta__btn" target="_blank"
        rel="nofollow noopener sponsored">See Price →</a>
      <button class="sticky-cta__close" aria-label="Dismiss" id="sticky-cta-close">×</button>
    </div>
  )}

  {stickyProduct && (
    <style>{`
      .sticky-cta {
        display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 90;
        background: var(--green); border-top: 2px solid var(--gold);
        padding: 10px 14px; height: 56px;
        align-items: center; gap: 10px;
        box-shadow: 0 -4px 16px rgba(0,0,0,.18);
        transform: translateY(100%); transition: transform .3s ease;
      }
      .sticky-cta.visible { transform: translateY(0); }
      .sticky-cta__body { flex: 1; min-width: 0; }
      .sticky-cta__name {
        display: block; font-size: 13px; font-weight: 700; color: #fff;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      }
      .sticky-cta__price { font-size: 11px; color: var(--gold); font-weight: 600; }
      .sticky-cta__btn {
        flex-shrink: 0; background: var(--gold); color: var(--green);
        padding: 8px 16px; border-radius: 6px; font-size: 13px; font-weight: 800;
        text-decoration: none; white-space: nowrap;
      }
      .sticky-cta__btn:hover { background: var(--gold-dark); }
      .sticky-cta__close {
        flex-shrink: 0; background: none; border: none; color: #fff9;
        font-size: 20px; cursor: pointer; padding: 4px 2px; line-height: 1;
      }
      .sticky-cta__close:hover { color: #fff; }
      @media (min-width: 769px) { .sticky-cta { display: none !important; } }
      @media (max-width: 768px) { .sticky-cta { display: flex; } }
    `}</style>
  )}

  {stickyProduct && (
    <script is:inline>{`
      (function(){
        var bar = document.getElementById('sticky-cta');
        var closeBtn = document.getElementById('sticky-cta-close');
        if (!bar) return;
        var dismissed = false;
        var trigger = document.querySelector('.art-section');
        if (!trigger) trigger = document.querySelector('.product-img-wrap');
        if (!trigger) return;
        function check() {
          if (dismissed) return;
          var rect = trigger.getBoundingClientRect();
          if (rect.top < 0) {
            bar.classList.add('visible');
          } else {
            bar.classList.remove('visible');
          }
        }
        window.addEventListener('scroll', check, {passive: true});
        closeBtn.addEventListener('click', function() {
          dismissed = true;
          bar.classList.remove('visible');
          bar.style.display = 'none';
        });
      })();
    `}</script>
  )}
  {/* ── Sortable comparison table ──────────────────────────────────────── */}
  <script is:inline>
    (function() {
      var table = document.querySelector('.cmp-table');
      if (!table) return;
      var headers = table.querySelectorAll('thead th');
      var tbody = table.querySelector('tbody');
      if (!tbody) return;

      var sortCol = -1;
      var sortDir = 1;

      headers.forEach(function(th, idx) {
        if (th.classList.contains('cmp-th-buy')) return;
        function doSort() {
          if (sortCol === idx) { sortDir *= -1; }
          else { sortCol = idx; sortDir = 1; }
          headers.forEach(function(h) { h.classList.remove('sort-asc', 'sort-desc'); });
          th.classList.add(sortDir === 1 ? 'sort-asc' : 'sort-desc');

          var rows = Array.from(tbody.querySelectorAll('tr'));
          rows.sort(function(a, b) {
            var aText = (a.children[idx] ? a.children[idx].textContent : '').trim();
            var bText = (b.children[idx] ? b.children[idx].textContent : '').trim();
            var aNum = parseFloat(aText.replace(/[^0-9.\-]/g, ''));
            var bNum = parseFloat(bText.replace(/[^0-9.\-]/g, ''));
            if (!isNaN(aNum) && !isNaN(bNum)) return (aNum - bNum) * sortDir;
            return aText.localeCompare(bText) * sortDir;
          });
          rows.forEach(function(r) { tbody.appendChild(r); });
        }
        th.addEventListener('click', doSort);
        th.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); doSort(); }
        });
      });
    })();
  </script>

  {showBackToTop && <BackToTop />}

</BaseLayout>
