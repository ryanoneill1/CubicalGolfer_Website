---
// src/pages/[...slug].astro — upgraded with affiliate buttons + image scaffolding

import BaseLayout    from '../layouts/BaseLayout.astro';
import ProductCard   from '../components/ProductCard.astro';
import AffiliateCTA  from '../components/AffiliateCTA.astro';
import StickyBar     from '../components/StickyBar.astro';
import { ARTICLES }  from '../data/articles';
import { articleMeta } from '../lib/seo';
import { articleSchema, faqSchema, breadcrumbSchema } from '../lib/schema';
import { getMergedRelated } from '../lib/linking';
import { getAffiliateLink } from '../data/affiliate-links';
import type { Article } from '../data/types';

export async function getStaticPaths() {
  return ARTICLES.map(article => ({
    params: { slug: article.slug.replace(/^\/|\/$/g, '') },
    props: { article },
  }));
}

interface Props { article: Article }
const { article } = Astro.props;

const meta    = articleMeta(article);
const related = getMergedRelated(article, 4);

const schemas: object[] = [
  articleSchema(article),
  breadcrumbSchema(meta.breadcrumbs),
];
if (article.faq && article.faq.length > 0) {
  schemas.push(faqSchema(article.faq));
}

const TAG_CLASS: Record<string, string> = {
  'BUYING GUIDE': 'tag-buy', 'COMPARISON': 'tag-cmp', 'TUTORIAL': 'tag-tut',
  'LISTICLE': 'tag-list', 'LIFESTYLE': 'tag-life', 'GUIDE': 'tag-rev',
};
const CAT_LABEL: Record<string, string> = {
  'gear-reviews': 'Golf Gear Reviews', 'golf-tech': 'Golf Tech',
  'golf-accessories': 'Golf Accessories', 'improve-game': 'Improve Your Golf Game',
  'golf-lifestyle': 'Golf Lifestyle',
};
const CAT_SLUG: Record<string, string> = {
  'gear-reviews': 'gear-reviews', 'golf-tech': 'golf-tech',
  'golf-accessories': 'golf-accessories', 'improve-game': 'improve-your-golf-game',
  'golf-lifestyle': 'golf-lifestyle',
};

const sameCategory = ARTICLES.filter(
  a => a.category === article.category && a.id !== article.id
).slice(0, 3);

const isBuyingGuide = article.pageType === 'buying-guide' || article.pageType === 'comparison';

// Map section badges to affiliate product IDs per article
const BADGE_TO_PRODUCT: Record<string, Record<string, string>> = {
  'rangefinders': {
    'BEST OVERALL':   'bushnell-tour-v6-shift',
    'BEST BUDGET':    'precision-pro-nx9-hd',
    'BEST HYBRID':    'garmin-approach-z82',
    'PREMIUM PICK':   'bushnell-pro-xe',
  },
  'gps-watches': {
    'BEST OVERALL':       'garmin-approach-s62',
    'BEST AUTO-TRACKING': 'shot-scope-v5',
    'BEST BUDGET':        'bushnell-ion-elite',
  },
  'drivers': {
    'BEST OVERALL':  'callaway-paradym-ai-smoke-max',
    'BEST DISTANCE': 'taylormade-qi35-max',
    'BEST VALUE':    'cobra-aerojet-max',
  },
  'golf-balls': {
    'BEST OVERALL':  'titleist-pro-v1',
    'BEST DISTANCE': 'callaway-chrome-tour-2026',
    'BEST VALUE':    'srixon-soft-feel',
  },
  'irons': {
    'MOST FORGIVING': 'callaway-paradym-ai-smoke-max-irons',
    'BEST MID-RANGE': 'titleist-t300',
    'BEST OVERALL':   'callaway-paradym-ai-smoke-max-irons',
  },
  'beginner-sets': {
    'BEST OVERALL':  'wilson-profile-sgi',
    'BEST VALUE':    'callaway-strata',
    'BEST STEP-UP':  'taylormade-rbz-lite',
  },
  'gloves': {
    'BEST OVERALL':     'footjoy-weathersof-glove',
    'BEST VENTILATION': 'titleist-players-flex',
  },
  'swing-analyzers': {
    'BEST OVERALL':     'arccos-caddie-sensors',
    'BEST LAUNCH DATA': 'rapsodo-mlm2pro',
    'BEST BUDGET':      'swing-caddie-sc4-pro',
  },
  'ai-tools': {
    'BEST AI COACH':    '',
    'BEST LAUNCH DATA': 'rapsodo-mlm2pro',
    'BEST PUTTING':     'blast-motion-sensor',
    'BEST SIMULATOR':   'skytrak-plus',
  },
  'golf-apps': {
    'BEST FREE':       '',
    'BEST ALL-IN-ONE': '',
    'BEST FOR STATS':  'arccos-caddie-sensors',
  },
  'accessories-50': {},
  'golf-putters': {
    'BEST OVERALL': 'odyssey-white-hot-og',
    'BEST BLADE':   'scotty-cameron-phantom',
    'BEST BUDGET':  'cleveland-hb-soft-milled',
  },
  'golf-bags': {
    'BEST CARRY':  'sun-mountain-25-plus',
    'BEST STAND':  'titleist-players-4',
    'BEST CART':   'callaway-fairway-14',
    'BEST BUDGET': 'callaway-chev-dry',
  },
  'golf-ball-compression': {
    'BEST VALUE':   'srixon-soft-feel',
    'BEST OVERALL': 'titleist-pro-v1',
  },
  'pro-v1-vs-pro-v1x': {
    'BEST OVERALL':  'titleist-pro-v1',
    'BEST DISTANCE': 'titleist-pro-v1x',
  },
  'golf-gifts': {},
  'golf-shoes-walking': {
    'BEST OVERALL': 'footjoy-fury',
  },
};

// Rest of your existing file stays exactly the same until the template part
---

<BaseLayout {meta} {schemas} activeNav={CAT_SLUG[article.category] || 'gear-reviews'}>

  <header class="article-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <a href={`/${CAT_SLUG[article.category]}/`}>{CAT_LABEL[article.category]}</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">{article.titleDisplay}</span>
    </nav>
    <h1>{article.title}</h1>
    <p>{article.description}</p>
  </header>

  {article.sections && article.sections.map((section: any) => (
    <div class="article-section">
      {section.h2 && <h2>{section.h2}</h2>}
      {section.p && <p>{section.p}</p>}

      <!-- PRODUCT IMAGE BLOCK — now safely inside the section loop -->
      {section.badge && isBuyingGuide && (() => {
        const aff = getAffiliateLink(BADGE_TO_PRODUCT[article.id]?.[section.badge] || '');
        const sectionImgSrc = aff ? aff.imgSrc : null;
        const sectionImgAlt = aff ? aff.imgAlt ?? section.h2 : section.h2;

        return (
          <div class="product-image">
            {sectionImgSrc ? (
              <img 
                src={sectionImgSrc} 
                alt={sectionImgAlt}
                loading="lazy"
                width="800"
                height="600"
              />
            ) : (
              <div class="image-placeholder">
                <img 
                  src="/images/products/placeholder.webp" 
                  alt="Product image coming soon"
                  loading="lazy"
                />
                <p style="font-size:13px; color:#666; margin-top:8px;">
                  Missing image for this section.<br />
                  Add it as: <code>public/images/products/{article.id}-{(section.badge ?? '').toLowerCase().replace(/\s+/g,'-')}.webp</code>
                </p>
              </div>
            )}
          </div>
        );
      })()}

      {section.content && <div set:html={section.content} />}

      <!-- Affiliate CTA for this section -->
      {section.badge && isBuyingGuide && (() => {
        const aff = getAffiliateLink(BADGE_TO_PRODUCT[article.id]?.[section.badge] || '');
        return aff ? <AffiliateCTA affiliate={aff} /> : null;
      })()}

    </div>
  ))}

  <!-- Rest of your page (related articles, sticky bar, etc.) remains unchanged -->
  <StickyBar related={related} />

  {related.length > 0 && (
    <section class="related-section">
      <h2>You may also like</h2>
      <div class="related-grid">
        {related.map(r => (
          <a href={r.slug} class="related-card">
            <h3>{r.label}</h3>
          </a>
        ))}
      </div>
    </section>
  )}

</BaseLayout>
