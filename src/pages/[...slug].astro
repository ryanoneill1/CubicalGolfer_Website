---
import BaseLayout    from '../layouts/BaseLayout.astro';
import ProductCard   from '../components/ProductCard.astro';
import AffiliateCTA  from '../components/AffiliateCTA.astro';
import StickyBar     from '../components/StickyBar.astro';
import { ARTICLES }  from '../data/articles';
import { articleMeta } from '../lib/seo';
import { articleSchema, faqSchema, breadcrumbSchema } from '../lib/schema';
import { getMergedRelated } from '../lib/linking';
import { getAffiliateLink } from '../data/affiliate-links';
import type { Article } from '../data/types';

export async function getStaticPaths() {
  return ARTICLES.map(article => ({
    params: { slug: article.slug.replace(/^\/|\/$/g, '') },
    props: { article },
  }));
}

interface Props { article: Article }
const { article } = Astro.props;

const meta    = articleMeta(article);
const related = getMergedRelated(article, 4);

const schemas: object[] = [
  articleSchema(article),
  breadcrumbSchema(meta.breadcrumbs),
];
if (article.faq && article.faq.length > 0) {
  schemas.push(faqSchema(article.faq));
}

const TAG_CLASS: Record<string, string> = {
  'BUYING GUIDE': 'tag-buy', 'COMPARISON': 'tag-cmp', 'TUTORIAL': 'tag-tut',
  'LISTICLE': 'tag-list', 'LIFESTYLE': 'tag-life', 'GUIDE': 'tag-rev',
};
const CAT_LABEL: Record<string, string> = {
  'gear-reviews': 'Golf Gear Reviews', 'golf-tech': 'Golf Tech',
  'golf-accessories': 'Golf Accessories', 'improve-game': 'Improve Your Golf Game',
  'golf-lifestyle': 'Golf Lifestyle',
};
const CAT_SLUG: Record<string, string> = {
  'gear-reviews': 'gear-reviews', 'golf-tech': 'golf-tech',
  'golf-accessories': 'golf-accessories', 'improve-game': 'improve-your-golf-game',
  'golf-lifestyle': 'golf-lifestyle',
};

const sameCategory = ARTICLES.filter(
  a => a.category === article.category && a.id !== article.id
).slice(0, 3);

const isBuyingGuide = article.pageType === 'buying-guide' || article.pageType === 'comparison';
---

<BaseLayout {meta} {schemas} activeNav={CAT_SLUG[article.category] || 'gear-reviews'}>

  <header class="article-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <a href={`/${CAT_SLUG[article.category]}/`}>{CAT_LABEL[article.category]}</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">{article.titleDisplay}</span>
    </nav>
    <h1>{article.title}</h1>
    <p>{article.description}</p>
  </header>

  {article.sections && article.sections.map((section: any) => (
    <div class="article-section">
      {section.h2 && <h2>{section.h2}</h2>}
      {section.p && <p>{section.p}</p>}

      <!-- Original product image block (before any WebP changes) -->
      {section.badge && isBuyingGuide && (
        <div class="product-image">
          <ProductCard productId={section.badge} />
        </div>
      )}

      {section.content && <div set:html={section.content} />}

      <!-- Original affiliate CTA -->
      {section.badge && isBuyingGuide && (
        <AffiliateCTA badge={section.badge} />
      )}

    </div>
  ))}

  <StickyBar related={related} />

  {related.length > 0 && (
    <section class="related-section">
      <h2>You may also like</h2>
      <div class="related-grid">
        {related.map(r => (
          <a href={r.slug} class="related-card">
            <h3>{r.label}</h3>
          </a>
        ))}
      </div>
    </section>
  )}

</BaseLayout>
