---
// src/pages/[...slug].astro — upgraded with affiliate buttons + image scaffolding

import BaseLayout    from '../layouts/BaseLayout.astro';
import ProductCard   from '../components/ProductCard.astro';
import AffiliateCTA  from '../components/AffiliateCTA.astro';
import StickyBar     from '../components/StickyBar.astro';
import { ARTICLES }  from '../data/articles';
import { articleMeta } from '../lib/seo';
import { articleSchema, faqSchema, breadcrumbSchema, buyingGuideItemListSchema, compressionChartHowToSchema } from '../lib/schema';
import { getMergedRelated } from '../lib/linking';
import { getAffiliateLink } from '../data/affiliate-links';
import type { Article } from '../data/types';

export async function getStaticPaths() {
  return ARTICLES.map(article => ({
    params: { slug: article.slug.replace(/^\/|\/$/g, '') },
    props: { article },
  }));
}

interface Props { article: Article }
const { article } = Astro.props;

const meta    = articleMeta(article);
const related = getMergedRelated(article, 5);

const isBuyingGuide = article.pageType === 'buying-guide' || article.pageType === 'comparison';

const schemas: object[] = [
  articleSchema(article),
  breadcrumbSchema(meta.breadcrumbs),
];
if (article.faq && article.faq.length > 0) {
  schemas.push(faqSchema(article.faq));
}
// ItemList JSON-LD for buying guides — helps Google/AI extract top picks
if (isBuyingGuide && article.comparisonTable?.rows) {
  try {
    const picks = article.comparisonTable.rows
      .filter((r: any) => r?.affiliateKey)
      .map((r: any, i: number) => {
        const aff = getAffiliateLink(r.affiliateKey);
        return { name: r.name, url: aff?.url || '#', position: i + 1, description: r.bestFor || '' };
      });
    if (picks.length > 0) schemas.push(buyingGuideItemListSchema(article, picks));
  } catch (_) { /* skip if data incomplete */ }
}
// HowTo schema for compression chart — helps rank for "how to use a compression chart"
if (article.id === 'golf-ball-compression') {
  schemas.push(compressionChartHowToSchema());
}



const TAG_CLASS: Record<string, string> = {
  'BUYING GUIDE': 'tag-buy', 'COMPARISON': 'tag-cmp', 'TUTORIAL': 'tag-tut',
  'ROUNDUP': 'tag-list', 'LIFESTYLE': 'tag-life', 'GUIDE': 'tag-rev',
};
const CAT_LABEL: Record<string, string> = {
  'gear-reviews': 'Golf Gear Reviews', 'golf-tech': 'Golf Tech',
  'golf-accessories': 'Golf Accessories', 'improve-game': 'Improve Your Golf Game',
  'golf-lifestyle': 'Golf Lifestyle',
};
const CAT_SLUG: Record<string, string> = {
  'gear-reviews': 'gear-reviews', 'golf-tech': 'golf-tech',
  'golf-accessories': 'golf-accessories', 'improve-game': 'improve-your-golf-game',
  'golf-lifestyle': 'golf-lifestyle',
};

const sameCategory = ARTICLES.filter(
  a => a.category === article.category && a.id !== article.id
).slice(0, 3);



// Map section badges to affiliate product IDs per article
// ── Affiliate buy-button mapping ──────────────────────────────────────────────
// Maps article-id → section badge → affiliate product key.
//
// FIXES applied March 2026:
//   • swing-analyzers + ai-tools: BEST LAUNCH DATA was 'arccos-caddie-sensors'
//     → corrected to 'rapsodo-mlm2pro' (ASIN B0BTPZMCSF)
//   • gloves: BEST VENTILATION was 'footjoy-weathersof-glove'
//     → corrected to 'titleist-players-flex' (its own search link)
//   • ai-tools: added BEST PUTTING → blast-motion-sensor
//   • ai-tools: added BEST SIMULATOR → skytrak-plus
//   • swing-analyzers: added BEST BUDGET → swing-caddie-sc4-pro (SC4 PRO 2024)
//   • golf-apps: BEST FOR STATS → arccos-caddie-sensors (sensors that power the app)
// ─────────────────────────────────────────────────────────────────────────────
