  },
  'best-golf-gloves-men': {
    'BEST OVERALL':     'footjoy-weathersof-glove',
    'BEST PREMIUM':     'titleist-players-flex',
    'BEST WET WEATHER': 'footjoy-raingrip',
  },
  'best-budget-drivers': {
    'BEST OVERALL': 'taylormade-sim-max',
    'BEST VALUE':   'callaway-big-bertha-b21',
    'BEST NEW':     'cleveland-launcher-xl',
  },
  'golf-shoes-walking': {
    'BEST OVERALL': 'footjoy-flex-xp',
    'BEST PREMIUM': 'ecco-biom-c4',
    'BEST BUDGET':  'skechers-go-golf',
  },
  'tips-beginners': {
    'BEST BEGINNER SET': 'wilson-profile-sgi',
    'BEST TRAINING AID': 'alignment-sticks',
