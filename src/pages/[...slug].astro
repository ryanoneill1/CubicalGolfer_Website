    'PREMIUM PICK': 'callaway-chrome-tour-2026',
  },
  'rangefinder-under-200': {
    'BEST OVERALL': 'precision-pro-nx9-hd', 'BEST BUDGET': 'blue-tees-series-3-max',
  },
