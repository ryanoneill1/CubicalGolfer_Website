---
// src/pages/gear-reviews/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categoryMeta } from '../../lib/seo';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';
import { getCategoryArticles } from '../../lib/linking';

const cat     = 'gear-reviews';
const articles = getCategoryArticles(cat);
const meta    = categoryMeta(cat, articles.length);
const schemas = [
  breadcrumbSchema(meta.breadcrumbs),
  faqSchema([
    { q: 'What is the best golf gear for a weekend golfer?', a: 'Start with a quality rangefinder ($150–$350) and a GPS watch ($150–$500). These two devices provide yardage data that improves decision-making on every hole. Gear upgrades beyond clubs matter less than these two tools for most weekend golfers.' },
    { q: 'How much should a weekend golfer spend on golf gear?', a: 'Most weekend golfers need $300–$600 in gear beyond clubs: a rangefinder (~$200), a GPS watch (~$150), and a few training aids (~$50). Everything else is optional.' },
  ]),
];

const TAG_CLASS: Record<string, string> = {
  'BUYING GUIDE': 'tag-buy', 'COMPARISON': 'tag-cmp', 'TUTORIAL': 'tag-tut',
  'LISTICLE': 'tag-list', 'LIFESTYLE': 'tag-life', 'GUIDE': 'tag-rev',
};
---

<BaseLayout {meta} {schemas} activeNav="gear-reviews">

  <header class="cat-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">Golf Gear Reviews</span>
    </nav>
    <h1>🏌️ Golf Gear Reviews</h1>
    <p>Tested rangefinders, GPS watches, drivers, irons, golf balls, and more —
      ranked by how much they actually improve your game, not by spec sheets.</p>
  </header>

  <div class="cat-page-body">
    <div class="articles-grid">
      {articles.map(a => (
        <a href={a.slug} class="article-card" aria-label={`Read: ${a.titleDisplay}`}>
          <div class={`art-thumb ${a.thumb}`}>
            <span class={`art-badge ${TAG_CLASS[a.tag] || 'tag-buy'}`}>{a.tag}</span>
            <span aria-hidden="true">{a.emoji}</span>
          </div>
          <div class="art-body">
            <h3>{a.titleDisplay}</h3>
            <p>{a.excerpt}</p>
            <div class="art-foot">
              <span class="art-words">{a.words} · Updated 2026</span>
              <span class="art-read">Read guide →</span>
            </div>
          </div>
        </a>
      ))}
    </div>
    <div class="articles-grid" style="margin-top:40px">
      <p style="grid-column:1/-1;font-size:13px;font-weight:700;letter-spacing:.08em;color:var(--muted);text-transform:uppercase;margin-bottom:-8px">More Guides</p>
        <a href="/best-golf-rangefinder-beginners.html" class="article-card" aria-label="Read: Best Golf Rangefinder for Beginners">
          <div class="art-thumb brown">
            <span class="art-badge tag-buy">BUYING GUIDE</span>
            <span aria-hidden="true">🏌️</span>
          </div>
          <div class="art-body">
            <h3>Best Golf Rangefinder for Beginners</h3>
            <p>The simplest, most accurate rangefinders for first-time buyers — ranked by ease of use and value.</p>
            <div class="art-foot">
              <span class="art-words">2026 Guide</span>
              <span class="art-read">Read guide →</span>
            </div>
          </div>
        </a>
        <a href="/bushnell-vs-garmin-rangefinder.html" class="article-card" aria-label="Read: Bushnell vs Garmin Rangefinder">
          <div class="art-thumb brown">
            <span class="art-badge tag-cmp">COMPARISON</span>
            <span aria-hidden="true">⚖️</span>
          </div>
          <div class="art-body">
            <h3>Bushnell vs Garmin Rangefinder</h3>
            <p>Speed and accuracy vs. GPS course mapping — the two most trusted rangefinder brands compared head-to-head.</p>
            <div class="art-foot">
              <span class="art-words">2026 Guide</span>
              <span class="art-read">Read guide →</span>
            </div>
          </div>
        </a>
        <a href="/best-gps-golf-watch-high-handicappers.html" class="article-card" aria-label="Read: Best GPS Golf Watch for High Handicappers">
          <div class="art-thumb teal">
            <span class="art-badge tag-buy">BUYING GUIDE</span>
            <span aria-hidden="true">⌚</span>
          </div>
          <div class="art-body">
            <h3>Best GPS Golf Watch for High Handicappers</h3>
            <p>GPS watches chosen for simplicity and readability — the features high-handicappers actually need.</p>
            <div class="art-foot">
              <span class="art-words">2026 Guide</span>
              <span class="art-read">Read guide →</span>
            </div>
          </div>
        </a>
        <a href="/best-golf-balls-slow-swing-speed.html" class="article-card" aria-label="Read: Best Golf Balls for Slow Swing Speed">
          <div class="art-thumb green">
            <span class="art-badge tag-buy">BUYING GUIDE</span>
            <span aria-hidden="true">⛳</span>
          </div>
          <div class="art-body">
            <h3>Best Golf Balls for Slow Swing Speed</h3>
            <p>Low-compression balls that deliver more distance and better feel for swing speeds under 85 mph.</p>
            <div class="art-foot">
              <span class="art-words">2026 Guide</span>
              <span class="art-read">Read guide →</span>
            </div>
          </div>
        </a>
        <a href="/best-golf-balls-weekend-golfers.html" class="article-card" aria-label="Read: Best Golf Balls for Weekend Golfers">
          <div class="art-thumb olive">
            <span class="art-badge tag-buy">BUYING GUIDE</span>
            <span aria-hidden="true">⛳</span>
          </div>
          <div class="art-body">
            <h3>Best Golf Balls for Weekend Golfers</h3>
            <p>Five golf balls ranked by distance, feel, and real value for golfers who play 15–30 rounds a year.</p>
            <div class="art-foot">
              <span class="art-words">2026 Guide</span>
              <span class="art-read">Read guide →</span>
            </div>
          </div>
        </a>
    </div>
  </div>

</BaseLayout>
