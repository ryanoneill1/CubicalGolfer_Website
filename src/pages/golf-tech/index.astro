---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categoryMeta } from '../../lib/seo';
import { breadcrumbSchema } from '../../lib/schema';
import { getCategoryArticles } from '../../lib/linking';
const cat = 'golf-tech';
const articles = getCategoryArticles(cat);
const meta = categoryMeta(cat, articles.length);
const schemas = [breadcrumbSchema(meta.breadcrumbs)];
const TAG_CLASS: Record<string, string> = {
  'BUYING GUIDE':'tag-buy','COMPARISON':'tag-cmp','TUTORIAL':'tag-tut',
  'LISTICLE':'tag-list','LIFESTYLE':'tag-life','GUIDE':'tag-rev',
};
---
<BaseLayout {meta} {schemas} activeNav="golf-tech">
  <header class="cat-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">Golf Tech</span>
    </nav>
    <h1>🔭 Golf Tech</h1>
    <p>Apps, swing analyzers, AI coaches, and launch monitors — ranked by how much they improve your game between rounds.</p>
  </header>
  <div class="cat-page-body">
    <div class="articles-grid">
      {articles.map(a => (
        <a href={a.slug} class="article-card" aria-label={`Read: ${a.titleDisplay}`}>
          <div class={`art-thumb ${a.thumb}`}>
            <span class={`art-badge ${TAG_CLASS[a.tag] || 'tag-buy'}`}>{a.tag}</span>
            <span aria-hidden="true">{a.emoji}</span>
          </div>
          <div class="art-body">
            <h3>{a.titleDisplay}</h3>
            <p>{a.excerpt}</p>
            <div class="art-foot">
              <span class="art-words">{a.words} · Updated 2026</span>
              <span class="art-read">Read guide →</span>
            </div>
          </div>
        </a>
      ))}
    </div>
    <div class="articles-grid" style="margin-top:40px">
      <p style="grid-column:1/-1;font-size:13px;font-weight:700;letter-spacing:.08em;color:var(--muted);text-transform:uppercase;margin-bottom:-8px">More Guides</p>
        <a href="/best-golf-simulator-small-spaces.html" class="article-card" aria-label="Read: Best Golf Simulator for Small Spaces">
          <div class="art-thumb navy">
            <span class="art-badge tag-buy">BUYING GUIDE</span>
            <span aria-hidden="true">🏌️</span>
          </div>
          <div class="art-body">
            <h3>Best Golf Simulator for Small Spaces</h3>
            <p>Five complete simulator setups ranked for garages and spare rooms — photometric and radar options compared.</p>
            <div class="art-foot">
              <span class="art-words">2026 Guide</span>
              <span class="art-read">Read guide →</span>
            </div>
          </div>
        </a>
        <a href="/best-budget-launch-monitor.html" class="article-card" aria-label="Read: Best Budget Golf Launch Monitor">
          <div class="art-thumb teal">
            <span class="art-badge tag-buy">BUYING GUIDE</span>
            <span aria-hidden="true">📡</span>
          </div>
          <div class="art-body">
            <h3>Best Budget Golf Launch Monitor</h3>
            <p>Real launch data and simulator play without the TrackMan price. Top affordable monitors ranked.</p>
            <div class="art-foot">
              <span class="art-words">2026 Guide</span>
              <span class="art-read">Read guide →</span>
            </div>
          </div>
        </a>
        <a href="/skytrak-vs-mevo-plus.html" class="article-card" aria-label="Read: SkyTrak+ vs Mevo+: Full Comparison">
          <div class="art-thumb navy">
            <span class="art-badge tag-cmp">COMPARISON</span>
            <span aria-hidden="true">⚖️</span>
          </div>
          <div class="art-body">
            <h3>SkyTrak+ vs Mevo+: Full Comparison</h3>
            <p>Photometric precision vs. radar versatility — head-to-head on accuracy, software, space, and value.</p>
            <div class="art-foot">
              <span class="art-words">2026 Guide</span>
              <span class="art-read">Read guide →</span>
            </div>
          </div>
        </a>
        <a href="/how-to-build-garage-golf-simulator.html" class="article-card" aria-label="Read: How to Build a Garage Golf Simulator">
          <div class="art-thumb navy">
            <span class="art-badge tag-tut">TUTORIAL</span>
            <span aria-hidden="true">🏗️</span>
          </div>
          <div class="art-body">
            <h3>How to Build a Garage Golf Simulator</h3>
            <p>Everything you need to plan, budget, and build a simulator — from screen selection to software setup.</p>
            <div class="art-foot">
              <span class="art-words">2026 Guide</span>
              <span class="art-read">Read guide →</span>
            </div>
          </div>
        </a>
        <a href="/best-golf-swing-analyzer-iphone.html" class="article-card" aria-label="Read: Best Golf Swing Analyzer for iPhone">
          <div class="art-thumb purple">
            <span class="art-badge tag-buy">BUYING GUIDE</span>
            <span aria-hidden="true">📱</span>
          </div>
          <div class="art-body">
            <h3>Best Golf Swing Analyzer for iPhone</h3>
            <p>iPhone-compatible analyzers that combine sensor data with video for dual feedback on every swing.</p>
            <div class="art-foot">
              <span class="art-words">2026 Guide</span>
              <span class="art-read">Read guide →</span>
            </div>
          </div>
        </a>
        <a href="/best-golf-apps-handicap-tracking.html" class="article-card" aria-label="Read: Best Golf Apps for Handicap Tracking">
          <div class="art-thumb teal">
            <span class="art-badge tag-buy">BUYING GUIDE</span>
            <span aria-hidden="true">📊</span>
          </div>
          <div class="art-body">
            <h3>Best Golf Apps for Handicap Tracking</h3>
            <p>Five apps that track your handicap and round stats — ranked by automation and analytics depth.</p>
            <div class="art-foot">
              <span class="art-words">2026 Guide</span>
              <span class="art-read">Read guide →</span>
            </div>
          </div>
        </a>
    </div>
  </div>
</BaseLayout>
