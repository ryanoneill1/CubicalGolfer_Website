const colors = { Clubs: '#1E3A28', Balls: '#C9A84C', Accessories: '#4a7c5f', Tech: '#2c5d8f', Bag: '#8B7355', 'Lessons & Experiences': '#6b4e8b' };

function selectBudget(b) {
  const data = budgets[b];
  document.querySelectorAll('.calc-btn').forEach(btn => btn.classList.remove('calc-btn--active'));
  document.querySelector(`[data-b="${b}"]`).classList.add('calc-btn--active');

  document.getElementById('budget-title').textContent = data.title;

  // Allocation bar
  const bar = document.getElementById('alloc-bar');
  bar.innerHTML = '';
  for (const [cat, pct] of Object.entries(data.alloc)) {
    if (pct === 0) continue;
    bar.innerHTML += `<div style="flex:${pct};background:${colors[cat]||'#666'};display:flex;align-items:center;justify-content:center;padding:0 4px;overflow:hidden;white-space:nowrap;">${cat} ${pct}%</div>`;
  }

  // Sections
  const sectionsEl = document.getElementById('budget-sections');
  sectionsEl.innerHTML = '';
  data.sections.forEach(sec => {
    let html = `<h3 style="margin:20px 0 8px;color:${colors[sec.cat]||'var(--text)'};">${sec.cat}</h3><table class="cmp-table"><thead><tr><th>Product</th><th>Price</th><th></th></tr></thead><tbody>`;
    sec.items.forEach(item => {
      const link = item.url ? `<a href="${item.url}" target="_blank" rel="nofollow noopener sponsored" style="color:var(--green);font-weight:600;text-decoration:none;">Buy →</a>` : '';
      html += `<tr><td>${item.name}${item.note ? '<br><small style="color:var(--muted);">'+item.note+'</small>' : ''}</td><td style="white-space:nowrap;font-weight:600;">$${item.price.toLocaleString()}</td><td>${link}</td></tr>`;
    });
    html += '</tbody></table>';
    sectionsEl.innerHTML += html;
  });

  // Upgrade path
  document.getElementById('upgrade-list').innerHTML = data.upgrade.map(u => `<p style="margin:4px 0;">${u}</p>`).join('');

  document.getElementById('budget-result').style.display = 'block';
  document.getElementById('budget-result').scrollIntoView({ behavior: 'smooth', block: 'start' });
}
// Expose to global scope for inline onclick handlers (Astro wraps define:vars in IIFE)
window.selectBudget = selectBudget;
