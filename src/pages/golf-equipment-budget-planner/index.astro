---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAffiliateLink } from '../../data/affiliate-links';
import { articleSchema, faqSchema, breadcrumbSchema } from '../../lib/schema';

const meta = {
  title: 'Golf Equipment Budget Planner — What to Buy First',
  description: 'Interactive golf budget planner. Pick your total budget and see exactly what to buy, in what order, with specific product recommendations at every tier.',
  canonical: 'https://www.cubicalgolfer.com/golf-equipment-budget-planner/',
  ogImage: 'https://www.cubicalgolfer.com/images/og-image.jpg',
  ogType: 'article' as const,
  robots: 'index, follow',
  breadcrumbs: [
    { label: 'Home', href: '/' },
    { label: 'Gear Reviews', href: '/gear-reviews/' },
    { label: 'Budget Planner', href: '/golf-equipment-budget-planner/' },
  ],
};

const faqs = [
  { q: 'How much should a beginner spend on golf equipment?', a: 'A complete beginner set (clubs, bag, balls, gloves, tees) costs $300-$500. The Callaway Strata set ($350) is the best value starter package.' },
  { q: 'What golf equipment should I buy first?', a: 'Clubs first (beginner set or used irons), then a glove, balls, and tees. Skip the rangefinder, watch, and training aids until you play regularly.' },
  { q: 'Is expensive golf equipment worth it?', a: 'For beginners: no. A $350 beginner set performs 90% as well as $2,000 in individual clubs. Invest in lessons first. For mid-handicappers: fitted irons make a measurable difference.' },
  { q: 'When should I upgrade from a beginner set?', a: 'When your handicap drops below 20 and you play 15+ rounds per year. Upgrade irons first (biggest impact), then driver, then putter. Keep the bag and accessories.' },
];

const schemas = [
  articleSchema({ headline: meta.title, description: meta.description, datePublished: '2026-05-17', dateModified: '2026-05-17', url: meta.canonical }),
  faqSchema(faqs),
  breadcrumbSchema(meta.breadcrumbs),
];

const TAG = 'cubicalgolfer-20';
const products = {
  strata: getAffiliateLink('callaway-strata-set'),
  supersoft: getAffiliateLink('callaway-supersoft'),
  r10: getAffiliateLink('garmin-approach-r10'),
  prov1: getAffiliateLink('titleist-pro-v1'),
  spiderTour: getAffiliateLink('taylormade-spider-tour'),
  rtx6: getAffiliateLink('cleveland-rtx6-52'),
  fiberbuilt: getAffiliateLink('fiberbuilt-flight-deck'),
  s62: getAffiliateLink('garmin-approach-s62'),
  bushnell: getAffiliateLink('bushnell-tour-v6-shift'),
  arccos: getAffiliateLink('arccos-caddie-sensors'),
  bagboy: getAffiliateLink('bag-boy-nitron'),
  dawnPatrol: getAffiliateLink('callaway-dawn-patrol'),
};
---

<BaseLayout {meta} {schemas} activeNav="gear-reviews">

  <article class="art-content">
    <header class="art-hero">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="bc-sep" aria-hidden="true">›</span>
        <a href="/gear-reviews/">Gear Reviews</a><span class="bc-sep" aria-hidden="true">›</span>
        <span aria-current="page">Budget Planner</span>
      </nav>
      <p class="art-freshness">Updated May 2026 · Interactive Tool</p>
      <h1>Golf Equipment Budget Planner — What to Buy First</h1>
      <p class="art-excerpt">Pick your total budget. We'll show you exactly what to buy, in what order, with specific products and prices. Every recommendation tested by us.</p>
      <div class="author-box">
        <img src="/images/ryan-avatar.webp" alt="Ryan" width="44" height="44" loading="lazy" class="author-box__avatar" onerror="this.style.display='none'" />
        <div><p class="author-box__name">Ryan O'Neill</p><p class="author-box__bio">12-handicap · Built a full bag from scratch on a budget</p></div>
      </div>
    </header>

    <div class="trust-card">
      <p class="trust-card__heading">Why Trust This Planner</p>
      <p>Every product was independently purchased and tested. Prices updated May 2026. We never recommend gear we haven't used ourselves.</p>
    </div>

    <section id="planner">
      <h2>What's Your Total Golf Budget?</h2>
      <div id="budget-btns" style="display:flex;gap:10px;flex-wrap:wrap;margin:16px 0 24px;">
        <button class="calc-btn" data-b="500" onclick="selectBudget(500)">$500</button>
        <button class="calc-btn" data-b="1000" onclick="selectBudget(1000)">$1,000</button>
        <button class="calc-btn" data-b="2500" onclick="selectBudget(2500)">$2,500</button>
        <button class="calc-btn" data-b="5000" onclick="selectBudget(5000)">$5,000</button>
        <button class="calc-btn" data-b="10000" onclick="selectBudget(10000)">$10,000</button>
      </div>
      <div id="budget-result" style="display:none;">
        <h2 id="budget-title"></h2>

        <!-- Visual allocation bar -->
