---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { comparisonMeta } from '../../lib/seo';
import { comparisonSchema, breadcrumbSchema } from '../../lib/schema';
import { COMPARISONS } from '../../data/comparisons';
import { getAffiliateLink } from '../../data/affiliate-links';

export async function getStaticPaths() {
  return COMPARISONS.map(c => ({
    params: { slug: c.slug },
    props: { c },
  }));
}

const { c } = Astro.props;
const meta = comparisonMeta(c);

const PRODUCT_NAMES: Record<string, string> = {
  'bushnell-tour-v6': 'Bushnell Tour V6 Shift',
  'precision-pro-nx9': 'Precision Pro NX9 HD',
  'garmin-s62': 'Garmin Approach S62',
  'shot-scope-v5': 'Shot Scope V5',
  'arccos-caddie': 'Arccos Caddie',
  'callaway-paradym': 'Callaway Paradym AI Smoke Max',
  'taylormade-qi35': 'TaylorMade Qi35 Max',
  // add any others you need
};

const PRODUCT_AFFILIATE_MAP: Record<string, string> = {
  'bushnell-tour-v6': 'bushnell-tour-v6-shift',
  'precision-pro-nx9': 'precision-pro-nx9-hd',
  'garmin-s62': 'garmin-approach-s62',
  'shot-scope-v5': 'shot-scope-v5',
  'arccos-caddie': 'arccos-caddie-sensors',
  'callaway-paradym': 'callaway-paradym',
  'taylormade-qi35': 'taylormade-qi35',
  // add any others you need
};

const affA = getAffiliateLink(PRODUCT_AFFILIATE_MAP[c.productA] || '');
const affB = getAffiliateLink(PRODUCT_AFFILIATE_MAP[c.productB] || '');
const winnerAff = getAffiliateLink(PRODUCT_AFFILIATE_MAP[c.winner] || '');
---

<BaseLayout {meta} schemas={[comparisonSchema(c), breadcrumbSchema(meta.breadcrumbs)]}>

  <h1>{c.title}</h1>

  <p>{c.description}</p>

  {(affA || affB) && (
    <div class="compare-prices">
      {affA && (
        <p>
          {PRODUCT_NAMES[c.productA] || c.productA} {affA.price} 
          <a href={affA.url}>[{affA.label} → at {affA.retailer}]</a>
        </p>
      )}
      {affB && (
        <p>
          {PRODUCT_NAMES[c.productB] || c.productB} {affB.price} 
          <a href={affB.url}>[{affB.label} → at {affB.retailer}]</a>
        </p>
      )}
    </div>
  )}

  {c.intro}

  ## The Verdict

  ### 🏆 Winner: {PRODUCT_NAMES[c.winner] || c.winner}

  {c.winnerReason}

  <!-- Safe winner button -->
  {winnerAff ? (
    <a href={winnerAff.url} class="btn-primary">
      {winnerAff.price} Buy the winner → {winnerAff.label} at {winnerAff.retailer}
    </a>
  ) : null}

  {c.verdict}

  <!-- Safe final recommendation block -->
  {winnerAff ? (
    <div class="final-rec">
      <a href={winnerAff.url}>
        {winnerAff.price} {PRODUCT_NAMES[c.winner] || c.winner} → at {winnerAff.retailer}
      </a>
    </div>
  ) : null}

  {c.faq && c.faq.length > 0 && (
    <section>
      <h2>Frequently Asked Questions</h2>
      {c.faq.map(({ q, a }) => (
        <details>
          <summary>{q}</summary>
          <p>{a}</p>
        </details>
      ))}
    </section>
  )}

  {(affA || affB) && (
    <div class="compare-ctas">
      {affA && (
        <a href={affA.url}>
          {affA.price} {PRODUCT_NAMES[c.productA]} → at {affA.retailer}
        </a>
      )}
      {affB && (
        <a href={affB.url}>
          {affB.price} {PRODUCT_NAMES[c.productB]} → at {affB.retailer}
        </a>
      )}
    </div>
  )}

</BaseLayout>
