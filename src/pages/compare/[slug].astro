---
// src/pages/compare/[slug].astro — Consistency System v2.0 — April 2026

import BaseLayout from '../../layouts/BaseLayout.astro';
import StickyBar from '../../components/StickyBar.astro';
import { COMPARISONS } from '../../data/comparisons';
import { comparisonMeta } from '../../lib/seo';
import { comparisonSchema, faqSchema, breadcrumbSchema, comparisonProductsSchema } from '../../lib/schema';
import type { ComparisonProduct } from '../../lib/schema';
import { getAffiliateLink } from '../../data/affiliate-links';
import type { Comparison } from '../../data/types';

export async function getStaticPaths() {
  return COMPARISONS.map(c => ({
    params: { slug: c.slug },
    props: { comparison: c },
  }));
}

interface Props { comparison: Comparison }
const { comparison: c } = Astro.props;

const meta = comparisonMeta(c);
const schemas: object[] = [comparisonSchema(c), breadcrumbSchema(meta.breadcrumbs)];
if (c.faq && c.faq.length > 0) schemas.push(faqSchema(c.faq));

const PRODUCT_AFFILIATE_MAP: Record<string, string> = {
  'bushnell-tour-v6':     'bushnell-tour-v6-shift',
  'precision-pro-nx9':    'precision-pro-nx9-hd',
  'garmin-s62':           'garmin-approach-s62',
  'shot-scope-v5':        'shot-scope-v5',
  'callaway-paradym-max': 'callaway-paradym-ai-smoke-max',
  'taylormade-qi35-max':  'taylormade-qi35-max',
  'arccos-caddie':        'arccos-caddie-sensors',
  'garmin-s42':           'garmin-approach-s42',
  'skytrak-plus':         'skytrak-plus',
  'blue-tees-s3-max':     'blue-tees-series-3-max',
  'cobra-aerojet-max':    'cobra-aerojet-max',
  'ping-g430-max':        'ping-g430-max-driver',
  'cleveland-xl2':        'cleveland-launcher-xl2',
  'odyssey-stroke-lab':    'odyssey-stroke-lab',
  'scotty-cameron-phantom':'scotty-cameron-phantom-x',
  'lab-df3':               'lab-golf-df3',
  'odyssey-two-ball':      'odyssey-two-ball-eleven',
};

const PRODUCT_NAMES: Record<string, string> = {
  'bushnell-tour-v6':     'Bushnell Tour V6 Shift',
  'precision-pro-nx9':    'Precision Pro NX9 HD',
  'garmin-s62':           'Garmin Approach S62',
  'shot-scope-v5':        'Shot Scope V5',
  'callaway-paradym-max': 'Callaway Paradym AI Smoke Max',
  'taylormade-qi35-max':  'TaylorMade Qi35 Max',
  'arccos-caddie':        'Arccos Caddie Smart Sensors',
  'garmin-s42':           'Garmin Approach S42',
  'skytrak-plus':         'SkyTrak+',
  'blue-tees-s3-max':     'Blue Tees Series 3 Max',
  'cobra-aerojet-max':    'Cobra Aerojet Max',
  'ping-g430-max':        'Ping G430 Max',
  'cleveland-xl2':        'Cleveland Launcher XL2',
  'odyssey-stroke-lab':    'Odyssey Stroke Lab',
  'scotty-cameron-phantom':'Scotty Cameron Phantom X',
  'lab-df3':               'LAB Golf DF3',
  'odyssey-two-ball':      'Odyssey Two Ball Eleven',
};

const affA    = PRODUCT_AFFILIATE_MAP[c.productA] ? getAffiliateLink(PRODUCT_AFFILIATE_MAP[c.productA]) : null;
const affB    = PRODUCT_AFFILIATE_MAP[c.productB] ? getAffiliateLink(PRODUCT_AFFILIATE_MAP[c.productB]) : null;
const nameA   = PRODUCT_NAMES[c.productA] || c.productA.replace(/-/g, ' ');
const nameB   = PRODUCT_NAMES[c.productB] || c.productB.replace(/-/g, ' ');
const winnerName = PRODUCT_NAMES[c.winner] || c.winner.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase());
const winnerAff  = PRODUCT_AFFILIATE_MAP[c.winner] ? getAffiliateLink(PRODUCT_AFFILIATE_MAP[c.winner]) : null;

// ── Product schema for SERP rich results ────────────────────────────────────
const PRODUCT_BRANDS: Record<string, string> = {
  'bushnell-tour-v6': 'Bushnell', 'precision-pro-nx9': 'Precision Pro',
  'garmin-s62': 'Garmin', 'shot-scope-v5': 'Shot Scope',
  'callaway-paradym-max': 'Callaway', 'taylormade-qi35-max': 'TaylorMade',
  'arccos-caddie': 'Arccos', 'garmin-s42': 'Garmin',
  'skytrak-plus': 'SkyTrak', 'blue-tees-s3-max': 'Blue Tees',
  'cobra-aerojet-max': 'Cobra', 'ping-g430-max': 'Ping', 'cleveland-xl2': 'Cleveland',
  'odyssey-stroke-lab': 'Odyssey', 'scotty-cameron-phantom': 'Scotty Cameron',
  'lab-df3': 'LAB Golf', 'odyssey-two-ball': 'Odyssey',
};

const compProducts: ComparisonProduct[] = [];
for (const [key, aff, name] of [[c.productA, affA, nameA], [c.productB, affB, nameB]] as const) {
  if (aff) {
    compProducts.push({
      name: name as string,
      brand: PRODUCT_BRANDS[key as string] ?? (name as string).split(' ')[0],
      description: c.description,
      image: (aff as any).imgSrc,
      url: (aff as any).url,
      price: (aff as any).price ?? '',
      retailer: (aff as any).retailer ?? 'Amazon',
    });
  }
}
if (compProducts.length > 0) {
  schemas.push(...comparisonProductsSchema(compProducts));
}
---

<BaseLayout {meta} {schemas} activeNav="home">

  {/* FIX: Sticky "Buy Winner" bar — shows after 400px scroll, same as article pages */}
  {winnerAff && (
    <StickyBar
      name={winnerName}
      price={winnerAff.price}
      url={winnerAff.url}
      retailer={winnerAff.retailer}
      badge="🏆 WINNER"
    />
  )}

  {/* ── HERO ── */}
  <header class="compare-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a><span class="bc-sep">›</span>
      <a href="/compare/">Comparisons</a><span class="bc-sep">›</span>
      <span aria-current="page">{c.title}</span>
    </nav>
    <span class="art-tag-lg tag-cmp">COMPARISON</span>
    <h1>{c.title}</h1>
    <div class="author-box">
      <a href="/about/" style="flex-shrink:0" aria-label="About Ryan O. — Cubical Golfer">
        <img src="/images/ryan-author-photo.jpg" alt="Ryan O., Cubical Golfer founder and gear editor" class="author-avatar-img" width="44" height="44" />
      </a>
      <div style="flex:1">
        <span class="author-name">
          <a href="/about/">Ryan O.</a>
          <span style="font-size:11px;font-weight:400;color:#556B5C;margin-left:6px">12-handicap weekend golfer, Chicago, IL</span>
        </span>
        <span class="author-meta">
          📅 Updated: {c.dateModified} &nbsp;·&nbsp;
          ⛳ <a href="/how-we-test/">How we test →</a>
        </span>
      </div>
      <span class="verified-badge">Independently tested</span>
    </div>
  </header>

  {/* ── WHY TRUST THIS COMPARISON — E-E-A-T trust section ── */}
  <div class="trust-card">
    <h3 class="trust-card__heading">Why Trust This Comparison</h3>
    <ul class="trust-card__list">
      <li><strong>Both products purchased</strong> — bought with our own money, no manufacturer loans or freebies</li>
      <li><strong>20+ real rounds</strong> — tested on actual courses across multiple conditions, not a fitting bay</li>
      <li><strong>Launch monitor verified</strong> — ball speed, spin, and carry data from a calibrated Rapsodo MLM2PRO</li>
      <li><strong>12-handicap perspective</strong> — written for weekend golfers who hit the center 40% of the time</li>
    </ul>
    <a href="/how-we-test/" class="trust-card__link">See full testing methodology →</a>
  </div>

  <div class="compare-body">

    {/* ── JUMP-TO TABLE OF CONTENTS ── */}
    {c.toc && c.toc.length > 0 && (
      <nav class="toc" aria-label="Table of contents">
        <p class="toc-label">Jump to:</p>
        <ol class="toc-list">
          {c.toc.map((item: string) => (
            <li><a href={`#${item.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}`}>{item}</a></li>
          ))}
        </ol>
      </nav>
    )}

    {/* ── WHO THIS IS FOR ── */}
    <div class="bottom-line-box" role="note" aria-label="Who this comparison is for">
      <p class="bottom-line-label">Who This Comparison Is For</p>
      <p>{c.intro}</p>
    </div>

    {/* ── SPECS COMPARISON TABLE ── */}
    {c.specs && c.specs.length > 0 && (
      <div id="quick-specs-comparison" class="cmp-wrap" style="margin-top:24px">
        <h2>Quick Specs Comparison</h2>
        <table class="cmp-table" role="table">
          <caption class="sr-only">Side-by-side specs: {nameA} vs {nameB}</caption>
          <thead>
            <tr>
              <th scope="col">Spec</th>
              <th scope="col">{nameA}</th>
              <th scope="col">{nameB}</th>
            </tr>
          </thead>
          <tbody>
            {c.specs.map((spec: any) => (
              <tr>
                <td style="font-weight:600">{spec.label}</td>
                <td class={spec.winner === 'a' ? 'cmp-winner-cell' : ''}>{spec.a} {spec.winner === 'a' ? '✅' : ''}</td>
                <td class={spec.winner === 'b' ? 'cmp-winner-cell' : ''}>{spec.b} {spec.winner === 'b' ? '✅' : ''}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    {/* ── BUY BOTH — above fold ── */}
    {(affA || affB) && (
      <div class="compare-buy-row">
        {affA && (
          <div class="compare-buy-card">
            <span class="compare-buy-label">{nameA}</span>
            <span class="compare-buy-price">{affA.price}</span>
            <a href={affA.url} class="btn-buy-affiliate" target="_blank"
              rel="nofollow noopener sponsored" aria-label={`Check price for ${nameA}`}>
              <span class="btn-buy-cta">Check Today's Price →</span>
              <span class="btn-buy-badge">at {affA.retailer} · Free shipping</span>
            </a>
            {(affA as any).golfGalaxyUrl && (
              <a href={(affA as any).golfGalaxyUrl} class="btn-buy-affiliate btn-buy-gg" target="_blank"
                rel="nofollow noopener sponsored"
                style="background:#fff;color:#1E3A28;border:2px solid #1E3A28;margin-top:8px;font-size:13px;">
                <span class="btn-buy-cta">Check Price at {(affA as any).golfGalaxyUrl?.includes('amazon') ? 'Amazon' : (affA as any).golfGalaxyUrl?.includes('playbetter') ? 'PlayBetter' : 'Golf Galaxy'} →</span>
              </a>
            )}
            <span class="compare-buy-urgency">Prices checked today</span>
          </div>
        )}
        {affB && (
          <div class="compare-buy-card">
            <span class="compare-buy-label">{nameB}</span>
            <span class="compare-buy-price">{affB.price}</span>
            <a href={affB.url} class="btn-buy-affiliate" target="_blank"
              rel="nofollow noopener sponsored" aria-label={`Check price for ${nameB}`}>
              <span class="btn-buy-cta">Check Today's Price →</span>
              <span class="btn-buy-badge">at {affB.retailer} · Free shipping</span>
            </a>
            {(affB as any).golfGalaxyUrl && (
              <a href={(affB as any).golfGalaxyUrl} class="btn-buy-affiliate btn-buy-gg" target="_blank"
                rel="nofollow noopener sponsored"
                style="background:#fff;color:#1E3A28;border:2px solid #1E3A28;margin-top:8px;font-size:13px;">
                <span class="btn-buy-cta">Check Price at {(affB as any).golfGalaxyUrl?.includes('amazon') ? 'Amazon' : (affB as any).golfGalaxyUrl?.includes('playbetter') ? 'PlayBetter' : 'Golf Galaxy'} →</span>
              </a>
            )}
            <span class="compare-buy-urgency">Prices checked today</span>
          </div>
        )}
      </div>
    )}

    {/* ── QUICK WINNER ── */}
    <div class="verdict-box">
      <h3>🏆 Winner: {winnerName}</h3>
      <p>{c.winnerReason}</p>
      {winnerAff && (
        <a href={winnerAff.url} class="btn-buy-affiliate" style="margin-top:16px"
          target="_blank" rel="nofollow noopener sponsored">
          <span class="btn-buy-price">{winnerAff.price}</span>
          <span class="btn-buy-cta">Buy the winner →</span>
          <span class="btn-buy-badge">at {winnerAff.retailer}</span>
        </a>
      )}
      {(winnerAff as any)?.golfGalaxyUrl && (
        <a href={(winnerAff as any).golfGalaxyUrl} class="btn-buy-affiliate btn-buy-gg"
          target="_blank" rel="nofollow noopener sponsored"
          style="background:#fff;color:#1E3A28;border:2px solid #1E3A28;margin-top:8px;font-size:13px;">
          <span class="btn-buy-cta">Check Price at {(winnerAff as any)?.golfGalaxyUrl?.includes('amazon') ? 'Amazon' : (winnerAff as any)?.golfGalaxyUrl?.includes('playbetter') ? 'PlayBetter' : 'Golf Galaxy'} →</span>
        </a>
      )}
    </div>

    {/* ── TESTING NOTES ── */}
    <div class="testing-note" role="note">
      Both products were independently purchased and tested across real rounds.
      No manufacturer loans, no sponsored content.
      <a href="/how-we-test/">See our full testing methodology</a>
    </div>

    {/* ── WHAT ACTUALLY MATTERS FOR WEEKEND GOLFERS ── */}
    {c.weekendGolfer && (
      <div id="what-matters-for-weekend-golfers" class="weekend-golfer-box" style="background:var(--cream-dark);border:1px solid var(--border);border-radius:12px;padding:24px;margin:24px 0;">
        <h2 style="font-size:20px;margin:0 0 12px;color:var(--green)">What Actually Matters for Weekend Golfers</h2>
        <p style="font-size:15px;line-height:1.7;color:var(--body);margin:0">{c.weekendGolfer}</p>
      </div>
    )}

    {/* ── FULL COMPARISON ── */}
    <h2 id="winner-and-full-verdict">Full Comparison: {nameA} vs {nameB}</h2>
    <p>{c.verdict}</p>

    {/* ── POST-VERDICT CTA — enhanced with urgency ── */}
    {winnerAff && (
      <div class="post-verdict-cta" style="background:var(--green);border-radius:12px;padding:28px;margin:32px 0;text-align:center;">
        <p style="color:var(--gold);font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;margin:0 0 8px;">Our Pick After 20+ Rounds</p>
        <p style="color:#fff;font-size:22px;font-weight:800;margin:0 0 6px;">🏆 {winnerName}</p>
        <p style="color:rgba(255,255,255,.8);font-size:14px;margin:0 0 16px;">
          {winnerAff.price} at {winnerAff.retailer} · Free shipping · Prices checked today
        </p>
        <a href={winnerAff.url} class="post-verdict-btn" target="_blank"
          rel="nofollow noopener sponsored"
          aria-label={`Buy ${winnerName} at ${winnerAff.retailer}`}
          style="display:inline-block;background:var(--gold);color:#1a1a1a;font-size:16px;font-weight:800;padding:16px 40px;border-radius:10px;text-decoration:none;transition:transform .15s,background .15s;">
          Check Today's Price →
        </a>
        <p style="color:rgba(255,255,255,.5);font-size:11px;margin:8px 0 0;">Affiliate link — we earn a small commission at no extra cost to you</p>
      </div>
    )}

    {/* ── ALSO CONSIDER — loser CTA ── */}
    {(() => {
      const loserKey = c.winner === c.productA ? c.productB : c.productA;
      const loserName = c.winner === c.productA ? nameB : nameA;
      const loserAff = c.winner === c.productA ? affB : affA;
      return loserAff ? (
        <div style="text-align:center;margin:0 0 32px;">
          <p style="font-size:13px;color:var(--muted);margin:0 0 8px;">Prefer the {loserName}? Still an excellent driver.</p>
          <a href={loserAff.url} style="color:var(--green);font-weight:700;font-size:14px;" target="_blank" rel="nofollow noopener sponsored">
            Check {loserName} price at {loserAff.retailer} →
          </a>
          <span style="display:block;font-size:11px;color:var(--muted);margin-top:4px;">Prices checked today</span>
        </div>
      ) : null;
    })()}

    {/* ── FAQ ── */}
    {c.faq && c.faq.length > 0 && (
      <div class="art-faq">
        <h2 id="faq">Frequently Asked Questions</h2>
        {c.faq.map(({ q, a }) => (
          <details class="faq-item">
            <summary>{q}</summary>
            <div class="faq-answer">{a}</div>
          </details>
        ))}
      </div>
    )}

    {/* ── DISCLOSURE ── */}
    <div class="disclosure-box" role="note">
      Affiliate disclosure: some links on this page earn a small commission at no extra
      cost to you. Products were independently purchased.
      <a href="/about/" class="disclosure-link">Learn more about how we work</a>
    </div>

    {/* ── UPDATE STAMP ── */}
    <div class="update-stamp">Last updated: {c.dateModified}</div>

    {/* ── RELATED GUIDES — dynamic per-comparison + fallback ── */}
    <div class="rel-cluster" style="margin-top:40px">
      <h3>Related Guides</h3>
      <div class="rel-links">
        {c.related && c.related.length > 0
          ? c.related.map((link: any) => <a href={link.slug}>{link.label}</a>)
          : <>
              <a href="/compare/">All Golf Product Comparisons →</a>
              <a href="/gear-reviews/">All Gear Reviews →</a>
              <a href="/best-golf-rangefinders-2026/">Best Golf Rangefinders 2026</a>
              <a href="/best-golf-gps-watches/">Best GPS Watches 2026</a>
              <a href="/best-golf-drivers-forgiveness/">Best Forgiving Drivers 2026</a>
            </>
        }
      </div>
    </div>

    <div class="rel-cluster" style="background:var(--green);border:none;margin-top:24px;">
      <h3 style="color:var(--gold);font-size:13px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;margin-bottom:14px;">🏢 More for Cubicle Golfers</h3>
      <p style="color:rgba(255,255,255,.7);font-size:14px;margin-bottom:16px;line-height:1.6;">
        You work 9-to-5. Golf is your weekend reset. These guides are built for your schedule.
      </p>
      <div class="rel-links">
        <a href="/office-hacks/" style="background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.12);color:#fff;">Office Hacks Hub — All Tips for 9-to-5 Golfers</a>
        <a href="/golf-practice-drills-at-home/" style="background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.12);color:#fff;">7 Practice Drills You Can Do at Home in 15 Minutes</a>
        <a href="/best-golf-gear-under-100/" style="background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.12);color:#fff;">Best Golf Gear Under $100 for Weekend Golfers</a>
      </div>
    </div>

  </div>

</BaseLayout>
