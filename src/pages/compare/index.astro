---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { COMPARISONS } from '../../data/comparisons';
import { ARTICLES } from '../../data/articles';

// Get all VS comparison articles (not in /compare/ route)
const vsArticles = (ARTICLES as any[]).filter(a => 
  (a.slug.includes('-vs-') || a.pageType === 'comparison') && 
  !a.slug.startsWith('/compare/')
).sort((a: any, b: any) => a.title.localeCompare(b.title));
import { breadcrumbSchema } from '../../lib/schema';

const meta = {
  title: 'Golf Product Comparisons 2026 — Side-by-Side Reviews',
  description: 'Head-to-head golf product comparisons. Bushnell vs Precision Pro, Garmin vs Shot Scope, Callaway vs TaylorMade — tested side-by-side.',
  canonical: 'https://www.cubicalgolfer.com/compare/',
  ogImage: 'https://www.cubicalgolfer.com/images/og-image.png',
  ogType: 'website' as const,
  robots: 'index,follow,max-snippet:-1,max-image-preview:large',
  breadcrumbs: [
    { label: 'Home', href: '/' },
    { label: 'Comparisons', href: '/compare/' },
  ],
};
const schemas = [breadcrumbSchema(meta.breadcrumbs)];
---

<BaseLayout {meta} {schemas} activeNav="home">

  <header class="compare-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">Comparisons</span>
    </nav>
    <h1>Golf Product Comparisons</h1>
    <p>Head-to-head tested comparisons for weekend golfers who want to know: which one is actually worth buying?</p>
  </header>

  <div class="cat-page-body">
    <div class="articles-grid">
      {COMPARISONS.map(c => (
        <a href={`/compare/${c.slug}/`} class="article-card">
          <div class="art-thumb">
            <span class="art-badge tag-cmp">COMPARISON</span>
            {c.thumbnail
              ? <img src={c.thumbnail} alt={c.title} loading="lazy" width="400" height="260" style="width:100%;height:100%;object-fit:cover;border-radius:8px 8px 0 0;" />
              : <span aria-hidden="true">⚖️</span>
            }
          </div>
          <div class="art-body">
            <p class="hub-card-title">{c.title}</p>
            <p>{c.intro.substring(0, 120)}…</p>
            <div class="art-foot">
              <span class="art-words">Tested · Updated 2026</span>
              <span class="art-read">See comparison →</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- VS Comparisons from articles -->
    <div style="margin-top:32px">
      <h2 style="font-size:20px;margin-bottom:16px">More Head-to-Head Comparisons</h2>
      <div class="articles-grid">
        {vsArticles.map(a => (
          <a href={a.slug} class="article-card">
            <div class={`art-thumb ${a.thumbnail ? '' : a.thumb}`}>
              <span class="art-badge tag-cmp">{a.tag || 'COMPARISON'}</span>
              {a.thumbnail
                ? <img src={a.thumbnail} alt={a.titleDisplay || a.title} loading="lazy" width="400" height="260" style="width:100%;height:100%;object-fit:cover;border-radius:8px 8px 0 0;" />
                : <span aria-hidden="true">{a.emoji || '⚖️'}</span>
              }
            </div>
            <div class="art-body">
              <p class="hub-card-title">{a.titleDisplay || a.title}</p>
              <p>{a.excerpt?.substring(0, 120)}…</p>
              <div class="art-foot">
                <span class="art-words">{a.words} · Updated 2026</span>
                <span class="art-read">Read comparison →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

</BaseLayout>