---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema , aboutPageSchema } from '../lib/schema';
import { ARTICLES } from '../data/articles';

const meta = {
  title: 'About Cubical Golfer — Our Editorial Policy & Testing Process',
  description: 'Independent golf gear reviews tested over 40+ real rounds — tested by real weekend golfers who buy every product themselves.',
  canonical: 'https://www.cubicalgolfer.com/about/',
  ogImage: 'https://www.cubicalgolfer.com/images/og-image.png',
  ogType: 'website' as const,
  robots: 'index,follow',
  breadcrumbs: [
    { label: 'Home', href: '/' },
    { label: 'About', href: '/about/' },
  ],
};
const schemas = [breadcrumbSchema(meta.breadcrumbs), aboutPageSchema()];
---

<BaseLayout {meta} {schemas} activeNav="about">

  <header class="about-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">About</span>
    </nav>
    <div style="display:flex;align-items:center;gap:20px;margin-bottom:20px;flex-wrap:wrap">
      <img src="/images/cubicalgolfer-logo.jpg" alt="Cubical Golfer" 
           width="72" height="72" style="border-radius:16px;box-shadow:0 4px 16px rgba(0,0,0,.2)" />
      <div>
        <h1 style="margin:0">Built for the Office Golfer</h1>
        <p style="margin:4px 0 0;font-size:14px;opacity:.7">Independent gear reviews by real weekend golfers</p>
      </div>
    </div>
    <p>
      Cubical Golfer is an independent golf media site for everyday players
      who squeeze rounds in on weekends, obsess over their handicap on Monday,
      and refuse to stop getting better.
    </p>
  </header>

  <div class="about-body">
    <div class="about-grid">
      <div>
        <h2>Who We Are</h2>
        <p>
          We're weekend golfers with day jobs. We play 25–40 rounds a year on Saturday mornings
          and occasional twilight rounds after work. We don't have tour coaches or sponsor budgets.
          We have the same $300 to spend on gear that you do, and we want to know exactly what's worth it.
        </p>
        <p>
          Every piece of gear we recommend was purchased with our own money and tested over multiple
          real rounds — not on a demo day, not in a manufacturer's testing facility. On actual golf courses,
          in actual conditions, by actual 10–20 handicappers.
        </p>

        <h2 style="margin-top:36px">Our Editorial Policy</h2>
        <p>
          We earn affiliate commissions from some links on this site. This means if you click a link
          and buy something, we may earn a small commission at no extra cost to you. This does NOT
          affect our rankings or recommendations. We have declined to recommend products we were paid
          to promote because they weren't genuinely the best option.
        </p>
        <p>
          We never accept manufacturer loans for reviews. Every product we test is purchased by us.
          No manufacturer has editorial control or advance review of our content.
        </p>
      </div>

      <div>
        <h2>Our Testing Process</h2>
        <div class="about-vals">
          <div class="about-val">
            <span class="vi">🏌️</span>
            <h4>Tested Over Real Rounds</h4>
            <p>Every piece of gear is used over a minimum of 5–10 rounds before we write about it. We don't form opinions from spec sheets.</p>
          </div>
          <div class="about-val">
            <span class="vi">💰</span>
            <h4>Independently Purchased</h4>
            <p>All products are purchased by us. No freebies, no manufacturer loans, no sponsored content hidden as reviews.</p>
          </div>
          <div class="about-val">
            <span class="vi">⛳</span>
            <h4>Written for Weekend Golfers</h4>
            <p>Our target reader is a 12–22 handicapper with limited practice time and a real budget. We write for that person, not for tour players.</p>
          </div>
          <div class="about-val">
            <span class="vi">🔄</span>
            <h4>Regularly Updated</h4>
            <p>Every guide is reviewed and updated at minimum annually. Gear that no longer represents best value is removed.</p>
          </div>
        </div>

        <div style="background:var(--cream-dark);border-radius:12px;padding:24px;margin-top:24px;">
          <h4 style="font-size:14px;font-weight:700;margin-bottom:12px;">By the Numbers</h4>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:10px">
            <li style="font-size:14px;color:var(--body)">✅ <strong>{ARTICLES.length}+ guides</strong> published</li>
            <li style="font-size:14px;color:var(--body)">✅ <strong>40+ rounds</strong> of hands-on testing</li>
            <li style="font-size:14px;color:var(--body)">✅ <strong>$0</strong> in sponsored content</li>
            <li style="font-size:14px;color:var(--body)">✅ <strong>100%</strong> independently purchased gear</li>
          </ul>
        </div>

        <!-- ── PART 1: Contact section on About page ── -->
        <div style="background:var(--green);border-radius:12px;padding:28px;margin-top:28px;color:#fff;">
          <h3 style="font-size:16px;font-weight:800;margin:0 0 8px;color:#fff;">Get in Touch</h3>
          <p style="font-size:13px;line-height:1.65;margin:0 0 16px;color:rgba(255,255,255,.75);">
            Questions about a product review, a correction, or a partnership inquiry?
            We read every email and respond within 2 business days.
          </p>
          <a
            href="mailto:hello@cubicalgolfer.com"
            style="display:inline-flex;align-items:center;gap:8px;padding:11px 22px;background:var(--gold);color:var(--text);border-radius:6px;font-size:14px;font-weight:700;text-decoration:none;"
          >
            ✉️ hello@cubicalgolfer.com
          </a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>
