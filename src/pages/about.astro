---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema } from '../lib/schema';
import { ARTICLES } from '../data/articles';

const meta = {
  title: 'Meet The Cubical Golfer Team — Desk Jockeys Who Live for Tee Time',
  description: 'A crew of 9-to-5 workers who test golf gear between meetings and dream of birdies during conference calls. Meet the team behind every review.',
  canonical: 'https://www.cubicalgolfer.com/about/',
  ogImage: 'https://www.cubicalgolfer.com/images/og-image.png',
  ogType: 'website' as const,
  robots: 'index,follow',
  breadcrumbs: [
    { label: 'Home', href: '/' },
    { label: 'About', href: '/about/' },
  ],
};
const schemas = [breadcrumbSchema(meta.breadcrumbs)];

const TEAM = [
  { name: 'Fairway Finance Guy', role: 'Gear Reviews Lead', hdcp: '14', bio: 'Reviews rangefinders and drivers between budget meetings. Has a spreadsheet ranking every rangefinder he\'s ever used. His coworkers think he\'s in finance — he\'s actually pricing golf gear.' },
  { name: 'Spreadsheet Swinger', role: 'Golf Tech Editor', hdcp: '12', bio: 'Tracks strokes gained like quarterly KPIs. Built a launch monitor comparison matrix during a team standup. Believes every swing fault can be fixed with data.' },
  { name: 'The Cubicle Caddie', role: 'Accessories Editor', hdcp: '15', bio: 'Keeps a putter under the desk and a groove brush in the laptop bag. Has strong opinions about gloves, towels, and anything under $50 that improves your round.' },
  { name: 'Mulligan Manager', role: 'Improvement Guides', hdcp: '16', bio: 'Manages mulligans better than projects. Writes every practice drill and scoring guide on the site. Shot 79 once and will not let anyone forget it.' },
  { name: 'The Lunch Break Golfer', role: 'Lifestyle & Courses', hdcp: '13', bio: 'Has played 9 holes in 58 minutes. Writes about sneaking in rounds, golf fitness, and every course within weekend-drive distance. Eats lunch at 11:30 to make the 12:15 tee time.' },
  { name: '5PM Tee Time', role: 'Weekend Warrior', hdcp: '15', bio: 'Leaves at 4:59. Tees off at 5:15. Tests gear during twilight rounds and writes about it the next morning before anyone else is in the office.' },
  { name: 'Chief Bogey Officer', role: 'Senior Editor', hdcp: '18', bio: 'Approves gear purchases nobody asked for. Makes the final call on every "Best Overall" pick. Has never broken 80 but has broken two drivers.' },
  { name: 'The Back Nine Analyst', role: 'Comparisons Lead', hdcp: '14', bio: 'Always shoots better on the back nine. Runs every head-to-head comparison on the site. Believes the front nine is just a warm-up.' },
];
---

<BaseLayout {meta} {schemas} activeNav="about">

  <header class="about-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">About</span>
    </nav>
    <div style="display:flex;align-items:center;gap:20px;margin-bottom:20px;flex-wrap:wrap">
      <img src="/images/cubicalgolfer-logo.jpg" alt="The Cubical Golfer Team"
           width="72" height="72" style="border-radius:16px;box-shadow:0 4px 16px rgba(0,0,0,.2)" />
      <div>
        <h1 style="margin:0">We're Stuck in Cubicles. Golf Keeps Us Sane.</h1>
        <p style="margin:4px 0 0;font-size:14px;opacity:.7">The Cubical Golfer Team · 15-handicap average · Gear Editors & Weekend Warriors</p>
      </div>
    </div>
    <p>
      We sit in meetings wishing we were on the back nine. We check tee times during lunch breaks.
      We have swing thoughts during conference calls and alignment stick daydreams during all-hands.
      Cubical Golfer is built by people exactly like you — 9-to-5 workers who live for Saturday morning
      golf and refuse to stop getting better.
    </p>
  </header>

  <div class="about-body">
    <div class="about-grid">
      <div>
        <h2>Meet the Team</h2>
        <p style="margin-bottom:24px;color:var(--muted);font-size:15px;">
          Real desk jobs. Real handicaps. Real gear reviews written between meetings.
        </p>

        <div style="display:flex;flex-direction:column;gap:16px;">
          {TEAM.map(member => (
            <div style="background:#fff;border:1px solid var(--border);border-radius:12px;padding:20px;">
              <div style="display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:8px;margin-bottom:8px;">
                <h3 style="font-size:17px;font-weight:700;color:var(--green);margin:0;">{member.name}</h3>
                <span style="font-size:12px;font-weight:600;color:var(--muted);background:var(--cream-dark);padding:3px 10px;border-radius:20px;">{member.hdcp}-hdcp · {member.role}</span>
              </div>
              <p style="font-size:14px;line-height:1.65;color:var(--body);margin:0;">{member.bio}</p>
            </div>
          ))}
        </div>

        <h2 style="margin-top:40px" id="affiliate">Our Editorial Policy</h2>
        <p>
          We earn affiliate commissions from some links on this site. If you click a link
          and buy something, we may earn a small commission at no extra cost to you. This does NOT
          affect our rankings or recommendations. We have declined to recommend products we were paid
          to promote because they weren't genuinely the best option.
        </p>
        <p>
          We never accept manufacturer loans for reviews. Every product we test is purchased by us.
          No manufacturer has editorial control or advance review of our content. Our day jobs pay
          the bills — this site exists because we genuinely love testing golf gear.
        </p>
      </div>

      <div>
        <h2>How We Test</h2>
        <div class="about-vals">
          <div class="about-val">
            <span class="vi">🏌️</span>
            <h4>10+ Real Rounds Per Product</h4>
            <p>Every piece of gear gets 10+ rounds before we write about it. We form opinions on the 14th hole, not from spec sheets.</p>
          </div>
          <div class="about-val">
            <span class="vi">💰</span>
            <h4>Bought With Our Own Paychecks</h4>
            <p>No freebies. No manufacturer loans. Every product was purchased by someone on this team using money they could have spent on greens fees.</p>
          </div>
          <div class="about-val">
            <span class="vi">🏢</span>
            <h4>Written From Our Cubicles</h4>
            <p>We write for the golfer with a full-time job, limited practice time, and a real budget. If you've ever checked tee times during a meeting, this site is for you.</p>
          </div>
          <div class="about-val">
            <span class="vi">🔄</span>
            <h4>Regularly Updated</h4>
            <p>Every guide is reviewed annually. Gear that no longer represents best value gets removed — no matter how much the Chief Bogey Officer liked it.</p>
          </div>
        </div>

        <div style="background:var(--cream-dark);border-radius:12px;padding:24px;margin-top:24px;">
          <h4 style="font-size:14px;font-weight:700;margin-bottom:12px;">By the Numbers</h4>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:10px">
            <li style="font-size:14px;color:var(--body)">✅ <strong>{ARTICLES.length}+ guides</strong> published</li>
            <li style="font-size:14px;color:var(--body)">✅ <strong>40+ rounds</strong> of hands-on testing</li>
            <li style="font-size:14px;color:var(--body)">✅ <strong>~15 handicap</strong> average across the team</li>
            <li style="font-size:14px;color:var(--body)">✅ <strong>$0</strong> in sponsored content</li>
            <li style="font-size:14px;color:var(--body)">✅ <strong>100%</strong> independently purchased gear</li>
            <li style="font-size:14px;color:var(--body)">✅ <strong>{TEAM.length} desk jockeys</strong> who'd rather be golfing</li>
            <li style="font-size:14px;color:var(--body)">✅ <strong>∞</strong> tee times checked during meetings</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>
