---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema } from '../lib/schema';
import { ARTICLES } from '../data/articles';

const meta = {
  title: 'About Cubical Golfer — Real Gear Reviews by Ryan O.',
  description: 'I\'m Ryan, a 12-handicap weekend golfer in Chicago. I started Cubical Golfer to test golf gear with my own money and share honest picks for golfers like me.',
  canonical: 'https://www.cubicalgolfer.com/about/',
  ogImage: 'https://www.cubicalgolfer.com/images/og-image.jpg',
  ogType: 'website' as const,
  robots: 'index,follow',
  breadcrumbs: [
    { label: 'Home', href: '/' },
    { label: 'About', href: '/about/' },
  ],
};
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: {
    '@type': 'Person',
    '@id': 'https://www.cubicalgolfer.com/about/#author',
    name: 'Ryan O.',
    alternateName: 'Cubical Golfer',
    url: 'https://www.cubicalgolfer.com/about/',
    jobTitle: 'Founder & Lead Tester, Cubical Golfer',
    description: 'Weekend golfer who tests every product with his own money. 12-handicap, 14 years playing, 25-40 rounds per year in Chicago.',
    image: 'https://www.cubicalgolfer.com/images/ryan-author-photo.jpg',
    email: 'hello@cubicalgolfer.com',
    sameAs: [
      'https://x.com/CubicalGolfer',
    ],
    knowsAbout: [
      'Golf rangefinders', 'Golf GPS watches', 'Golf launch monitors',
      'Golf irons', 'Golf drivers', 'Golf balls', 'Golf putters',
      'Golf swing improvement', 'Golf equipment testing',
    ],
  },
};
const schemas = [breadcrumbSchema(meta.breadcrumbs), personSchema];
---

<BaseLayout {meta} {schemas} activeNav="about">

  <header class="about-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">About</span>
    </nav>
    <div style="display:flex;align-items:center;gap:20px;margin-bottom:20px;flex-wrap:wrap">
      <!-- TODO: Replace placeholder with real headshot of Ryan — casual, on a course is best -->
      <img src="/images/ryan-author-photo.jpg" alt="Ryan O., Cubical Golfer founder and gear editor"
           width="80" height="80" style="border-radius:50%;object-fit:cover;box-shadow:0 4px 16px rgba(0,0,0,.2)" />
      <div>
        <h1 style="margin:0">Built for the Office Golfer</h1>
        <p style="margin:4px 0 0;font-size:14px;opacity:.7">Independent gear reviews by real weekend golfers</p>
      </div>
    </div>
  </header>

  <div class="about-body">
    <div class="about-grid">
      <div>
        <h2>About Ryan</h2>
        <p style="margin-bottom:16px;">
          I'm Ryan O. — a 12-handicap weekend golfer based in Chicago, IL. I have been playing golf
          for 14 years, starting on the public courses around Northwest Indiana and working my way
          down from a 24-handicap through sheer stubbornness and a lot of range buckets. My home
          courses are the Chicago-area public tracks that most Midwest golfers know well — the kind
          where a Saturday morning tee time costs $45 and the starter asks if you can play fast.
        </p>
        <p style="margin-bottom:16px;">
          I started Cubical Golfer in 2024 because every gear review I read was either written by a
          scratch golfer with a 115 mph swing speed or sponsored by a manufacturer with a vested
          interest. Neither applied to me — a regular guy with a desk job who plays 25-40 rounds a
          year, buys his own gear, and wants to know what actually works without the marketing hype.
          My day job pays the bills. This site exists because I genuinely love testing golf gear and
          helping weekend golfers make better decisions.
        </p>
        <p style="margin-bottom:16px;">
          I play year-round when Chicago weather allows it (roughly March through November), practice
          at the range 1-2 times per week, and squeeze in rounds after work whenever the tee sheet
          has a late-afternoon opening. If you have ever checked tee times during a meeting, scheduled
          a "dentist appointment" on a Friday afternoon, or kept a packed golf bag in your trunk all
          week — this site is for you.
        </p>

        <div style="background:#f0f7f2;border-left:3px solid var(--green);border-radius:0 8px 8px 0;padding:20px 24px;margin:24px 0;">
          <h3 style="font-size:17px;font-weight:700;color:#1E3A28;margin:0 0 8px;">Ryan O. — Credentials</h3>
          <p style="font-size:14px;line-height:1.65;color:var(--body);margin:0;">
            USGA Handicap Index: 12.4 · Rounds per year: 25-40 · Driver swing speed: 94 mph ·
            Home courses: public tracks in Chicago metro and Northwest Indiana ·
            Testing methodology: every product independently purchased and used over 10+ real rounds ·
            Years playing: 14 · Handicap journey: 24 → 12 over 8 years
          </p>
        </div>

        <h2 style="margin-top:40px" id="affiliate">Our Editorial Policy</h2>
        <p>
          I earn affiliate commissions from some links on this site. If you click a link
          and buy something, I may earn a small commission at no extra cost to you. This does NOT
          affect my rankings or recommendations. I have declined to recommend products I was paid
          to promote because they weren't genuinely the best option.
        </p>
        <p>
          I never accept manufacturer loans for reviews. Every product I test is purchased by me.
          No manufacturer has editorial control or advance review of my content. For full details,
          see our <a href="/affiliate-disclosure/">affiliate disclosure</a>.
        </p>

        <h2 style="margin-top:40px">Contact</h2>
        <div style="background:var(--cream-dark);border-radius:12px;padding:24px;margin-bottom:24px;">
          <p style="font-size:16px;margin:0 0 8px;">
            <strong>Email:</strong> <a href="mailto:hello@cubicalgolfer.com" style="color:var(--green);font-weight:600;">hello@cubicalgolfer.com</a>
          </p>
          <p style="font-size:14px;color:var(--muted);margin:0;">
            I read and respond to every email within 48 hours. Gear questions, review corrections,
            partnership inquiries — all welcome. See our <a href="/contact/">contact page</a> for details.
          </p>
        </div>

        <h2 style="margin-top:40px">Where to Find Me</h2>
        <div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:24px;">
          <a href="https://x.com/CubicalGolfer" rel="me noopener" target="_blank"
             style="display:inline-flex;align-items:center;gap:6px;background:var(--green);color:#fff;padding:10px 20px;border-radius:8px;font-size:14px;font-weight:600;text-decoration:none;">
            𝕏 Follow on X
          </a>
          <a href="mailto:hello@cubicalgolfer.com"
             style="display:inline-flex;align-items:center;gap:6px;background:var(--cream-dark);color:var(--green);padding:10px 20px;border-radius:8px;font-size:14px;font-weight:600;text-decoration:none;border:1px solid var(--green);">
            ✉️ hello@cubicalgolfer.com
          </a>
        </div>
      </div>

      <div>
        <h2>How I Test</h2>
        <div class="about-vals">
          <div class="about-val">
            <span class="vi">🏌️</span>
            <h4>10+ Real Rounds Per Product</h4>
            <p>Every piece of gear gets 10+ rounds before I write about it. I form opinions on the 14th hole, not from spec sheets.</p>
          </div>
          <div class="about-val">
            <span class="vi">💰</span>
            <h4>Bought With My Own Money</h4>
            <p>No freebies. No manufacturer loans. Every product is purchased by me using money I could have spent on greens fees.</p>
          </div>
          <div class="about-val">
            <span class="vi">🏢</span>
            <h4>Written From My Cubicle</h4>
            <p>I write for the golfer with a full-time job, limited practice time, and a real budget. If you've ever checked tee times during a meeting, this site is for you.</p>
          </div>
          <div class="about-val">
            <span class="vi">🔄</span>
            <h4>Regularly Updated</h4>
            <p>Every guide is reviewed annually. Gear that no longer represents best value gets removed — no matter how much I liked it.</p>
          </div>
        </div>

        <div style="background:var(--cream-dark);border-radius:12px;padding:24px;margin-top:24px;">
          <h4 style="font-size:14px;font-weight:700;margin-bottom:12px;">By the Numbers</h4>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:10px">
            <li style="font-size:14px;color:var(--body)">✅ <strong>{ARTICLES.length}+ guides</strong> published</li>
            <li style="font-size:14px;color:var(--body)">✅ <strong>40+ rounds</strong> of hands-on testing</li>
            <li style="font-size:14px;color:var(--body)">✅ <strong>12 handicap</strong> (USGA Index: 12.4)</li>
            <li style="font-size:14px;color:var(--body)">✅ <strong>14 years</strong> playing golf</li>
            <li style="font-size:14px;color:var(--body)">✅ <strong>$0</strong> in sponsored content</li>
            <li style="font-size:14px;color:var(--body)">✅ <strong>100%</strong> independently purchased gear</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>
