---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema, aboutPageSchema } from '../lib/schema';
import { ARTICLES } from '../data/articles';

const meta = {
  title: 'About Cubical Golfer — How We Test & Editorial Policy',
  description: 'How Cubical Golfer tests golf gear — every product independently purchased, tested over 10+ real rounds by weekend golfers with 15+ years of playing experience.',
  canonical: 'https://www.cubicalgolfer.com/about/',
  ogImage: 'https://www.cubicalgolfer.com/images/og-image.jpg',
  ogType: 'website' as const,
  robots: 'index,follow',
  breadcrumbs: [
    { label: 'Home', href: '/' },
    { label: 'About', href: '/about/' },
  ],
};
const schemas = [breadcrumbSchema(meta.breadcrumbs), aboutPageSchema()];
---

<BaseLayout {meta} {schemas} activeNav="about">

  <header class="about-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">About</span>
    </nav>
    <div style="display:flex;align-items:center;gap:24px;margin-bottom:24px;flex-wrap:wrap">
      <img src="/images/cubicalgolfer-logo.jpg" alt="Cubical Golfer"
           width="80" height="80" style="border-radius:16px;box-shadow:0 4px 16px rgba(0,0,0,.2);flex-shrink:0" />
      <div>
        <h1 style="margin:0 0 4px">About Cubical Golfer</h1>
        <p style="margin:0 0 6px;font-size:16px;font-weight:600;color:rgba(255,255,255,.85)">Independent Golf Gear Reviews — by Weekend Golfers</p>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
          <span style="background:rgba(255,255,255,.15);border-radius:20px;padding:3px 12px;font-size:12px;font-weight:700;color:rgba(255,255,255,.9)">Low-Teens Handicap</span>
          <span style="background:rgba(255,255,255,.15);border-radius:20px;padding:3px 12px;font-size:12px;font-weight:700;color:rgba(255,255,255,.9)">15+ Years Playing</span>
          <span style="background:rgba(255,255,255,.15);border-radius:20px;padding:3px 12px;font-size:12px;font-weight:700;color:rgba(255,255,255,.9)">Chicagoland</span>
        </div>
      </div>
    </div>
    <p style="font-size:17px;line-height:1.7;max-width:680px">
      I started Cubical Golfer after a decade of wasting money on gear that disappointed,
      and spending too many lunch breaks reading reviews written by people who'd clearly
      never played a Saturday morning scramble.
    </p>
  </header>

  <div class="about-body">
    <div class="about-grid">

      <!-- LEFT COLUMN: Bio + Credentials -->
      <div>

        <h2>Our Story</h2>
        <p>
          The team plays seriously — between us we have been playing since our teens — club captain on my college golf team,
          playing to a low-teens handicap, getting in 35–45 rounds a year,
          mostly on public and semi-private courses across the Chicago area. By day I work
          in marketing technology. The cubicle is very real.
        </p>
        <p>
          The site was built because the gear review market is broken. Too many sites run
          the same manufacturer photos and Amazon descriptions reworded into "reviews."
          I wanted a place where recommendations came from someone who'd actually played
          twelve rounds with the rangefinder, lost three sleeves of the ball, and had a
          real opinion about whether it's worth the money.
        </p>
        <p>
          We've broken 80 exactly once — a 78 at a windy links-style course in Michigan.
          we still talk about it. Most of the time I'm a bogey golfer trying to stay
          out of the penalty areas and two-putt from inside 20 feet. Which means we review
          gear for golfers who play golf, not for tour pros.
        </p>

        <!-- Credentials block -->
        <div style="background:var(--cream-dark);border-radius:12px;padding:24px;margin-top:28px;border-left:4px solid var(--gold)">
          <h3 style="font-size:15px;font-weight:800;margin:0 0 16px;text-transform:uppercase;letter-spacing:.06em;color:var(--green)">Testing Standards</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px">
            <li style="font-size:14px;color:var(--body);display:flex;gap:10px"><span>⛳</span><span><strong>15+ years</strong> of playing experience, low-teens USGA handicap index</span></li>
            <li style="font-size:14px;color:var(--body);display:flex;gap:10px"><span>🏌️</span><span><strong>35–45 rounds per year</strong> across public and semi-private courses</span></li>
            
            <li style="font-size:14px;color:var(--body);display:flex;gap:10px"><span>💰</span><span>Every product <strong>independently purchased</strong> — no manufacturer loans, no sponsored reviews</span></li>
            <li style="font-size:14px;color:var(--body);display:flex;gap:10px"><span>🔁</span><span>Minimum <strong>10 full rounds of testing</strong> before any recommendation is published</span></li>
            <li style="font-size:14px;color:var(--body);display:flex;gap:10px"><span>📊</span><span><strong>{ARTICLES.length}+ guides</strong> published, all updated quarterly</span></li>
          </ul>
        </div>

        

      </div>

      <!-- RIGHT COLUMN: Testing process + Policy + Contact -->
      <div>
        <h2>How We Test Gear <a href="/how-we-test/" style="font-size:13px;font-weight:600;color:var(--gold);text-decoration:none;margin-left:8px">Full methodology →</a></h2>
        <div class="about-vals">
          <div class="about-val">
            <span class="vi">🏌️</span>
            <h4>Real Rounds, Not Demo Days</h4>
            <p>Every piece of gear is used over a minimum of 10 full rounds before I write about it. I buy the gear, take it to the course, and play with it through good rounds and bad ones. Real conditions, real pressure shots.</p>
          </div>
          <div class="about-val">
            <span class="vi">💰</span>
            <h4>My Own Money</h4>
            <p>All products are independently purchased. No freebies, no manufacturer loans, no review units that go back after the article is written. If I recommend it, I paid for it.</p>
          </div>
          <div class="about-val">
            <span class="vi">⛳</span>
            <h4>Written for Bogey Golfers</h4>
            <p>My target reader is a 12–22 handicapper with a real budget and limited practice time. I write for that person — not for scratch golfers, not for equipment collectors.</p>
          </div>
          <div class="about-val">
            <span class="vi">🔄</span>
            <h4>Updated Quarterly</h4>
            <p>Every guide is reviewed quarterly. Gear that no longer represents best value gets replaced. Prices are checked and updated. The dates on every article reflect when content was actually reviewed, not just published.</p>
          </div>
        </div>

        <!-- Editorial policy -->
        <div style="background:var(--cream-dark);border-radius:12px;padding:24px;margin-top:24px">
          <h3 style="font-size:15px;font-weight:800;margin:0 0 12px;color:var(--green);text-transform:uppercase;letter-spacing:.06em">Editorial Policy</h3>
          <p style="font-size:14px;line-height:1.7;color:var(--body);margin:0 0 12px">
            I earn affiliate commissions from some links on this site. If you click and buy,
            I may earn a small commission at no extra cost to you. This does <strong>not</strong>
            affect rankings or recommendations — I have turned down paid placements because
            the product wasn't genuinely the best option.
          </p>
          <p style="font-size:14px;line-height:1.7;color:var(--body);margin:0">
            No manufacturer has advance review of content before publication.
            No brand has ever paid to have a product ranked higher than it deserves.
            If I don't like a product, I say so. If something is genuinely the best,
            you'll know why — because it was tested over 12 rounds.
          </p>
        </div>

        <!-- Contact -->
        <div style="background:var(--green);border-radius:12px;padding:28px;margin-top:20px;color:#fff">
          <h3 style="font-size:16px;font-weight:800;margin:0 0 8px;color:#fff">Get in Touch</h3>
          <p style="font-size:13px;line-height:1.65;margin:0 0 16px;color:rgba(255,255,255,.75)">
            Questions about a review, a correction, or a partnership inquiry?
            We read every email and respond within 2 business days.
          </p>
          <a
            href="mailto:hello@cubicalgolfer.com"
            style="display:inline-flex;align-items:center;gap:8px;padding:11px 22px;background:var(--gold);color:var(--text);border-radius:6px;font-size:14px;font-weight:700;text-decoration:none;"
          >
            ✉️ hello@cubicalgolfer.com
          </a>
        </div>

      </div>
    </div>
  </div>

</BaseLayout>
