---
// src/pages/gear-quiz/index.astro — Interactive gear recommendation quiz
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumbSchema } from '../../lib/schema';

const meta = {
  title: 'Golf Gear Quiz — Find Your Perfect Gear in 30 Seconds',
  description: 'Answer 4 quick questions and get personalized golf gear recommendations based on your handicap, budget, and game. Built by the Cubical Golfer team.',
  canonical: 'https://www.cubicalgolfer.com/gear-quiz/',
  ogImage: 'https://www.cubicalgolfer.com/images/og-image.jpg',
  ogType: 'website' as const,
  robots: 'index, follow',
  breadcrumbs: [
    { label: 'Home', href: '/' },
    { label: 'Gear Quiz', href: '/gear-quiz/' },
  ],
};
const schemas = [breadcrumbSchema(meta.breadcrumbs)];
---

<BaseLayout {meta} {schemas} activeNav="gear-quiz">

  <header class="cat-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">Gear Quiz</span>
    </nav>
    <h1>🎯 What Gear Should You Buy Next?</h1>
    <p class="cat-subhead">4 questions. 30 seconds. Personalized recommendations from a team of desk jockeys who test golf gear between meetings.</p>
  </header>

  <div id="quiz-container" style="max-width:680px;margin:0 auto;padding:0 var(--page-px) 60px;">
    <div id="quiz-progress" style="margin-bottom:32px;">
      <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
        <span id="progress-label" style="font-size:13px;font-weight:600;color:var(--muted);">Question 1 of 4</span>
        <span id="progress-pct" style="font-size:13px;font-weight:600;color:var(--green);">25%</span>
      </div>
      <div style="background:var(--cream-dark);border-radius:20px;height:8px;overflow:hidden;">
        <div id="progress-bar" style="background:var(--gold);height:100%;width:25%;border-radius:20px;transition:width .4s ease;"></div>
      </div>
    </div>

    <div id="quiz-questions">
      <div class="quiz-step" data-step="1" style="display:block;">
        <h2 style="font-family:'Playfair Display',serif;font-size:22px;color:var(--green);margin-bottom:6px;">What's your handicap range?</h2>
        <p style="font-size:14px;color:var(--muted);margin-bottom:20px;">No judgment — this helps us recommend the right level of gear.</p>
        <div class="quiz-options">
          <button class="quiz-btn" data-key="handicap" data-value="beginner">🏌️ Beginner (25+)</button>
          <button class="quiz-btn" data-key="handicap" data-value="mid">⛳ Mid Handicap (15–25)</button>
          <button class="quiz-btn" data-key="handicap" data-value="low">🎯 Low Handicap (5–15)</button>
          <button class="quiz-btn" data-key="handicap" data-value="scratch">🏆 Scratch or Better (&lt;5)</button>
        </div>
      </div>

      <div class="quiz-step" data-step="2" style="display:none;">
        <h2 style="font-family:'Playfair Display',serif;font-size:22px;color:var(--green);margin-bottom:6px;">How often do you play?</h2>
        <p style="font-size:14px;color:var(--muted);margin-bottom:20px;">This helps us calibrate value-for-money recommendations.</p>
        <div class="quiz-options">
          <button class="quiz-btn" data-key="frequency" data-value="monthly">📅 Monthly</button>
          <button class="quiz-btn" data-key="frequency" data-value="2-3x">🗓️ 2–3x per month</button>
          <button class="quiz-btn" data-key="frequency" data-value="weekly">📆 Weekly</button>
          <button class="quiz-btn" data-key="frequency" data-value="2+weekly">🔥 2+ per week</button>
        </div>
      </div>

      <div class="quiz-step" data-step="3" style="display:none;">
        <h2 style="font-family:'Playfair Display',serif;font-size:22px;color:var(--green);margin-bottom:6px;">What's your budget for one piece of gear?</h2>
        <p style="font-size:14px;color:var(--muted);margin-bottom:20px;">We'll only recommend gear that fits your price range.</p>
        <div class="quiz-options">
          <button class="quiz-btn" data-key="budget" data-value="under50">💵 Under $50</button>
          <button class="quiz-btn" data-key="budget" data-value="50-150">💰 $50–$150</button>
          <button class="quiz-btn" data-key="budget" data-value="150-300">💎 $150–$300</button>
          <button class="quiz-btn" data-key="budget" data-value="300+">🏅 $300+</button>
        </div>
      </div>

      <div class="quiz-step" data-step="4" style="display:none;">
        <h2 style="font-family:'Playfair Display',serif;font-size:22px;color:var(--green);margin-bottom:6px;">What do you struggle with most?</h2>
        <p style="font-size:14px;color:var(--muted);margin-bottom:20px;">Pick the one area where you lose the most strokes.</p>
        <div class="quiz-options">
          <button class="quiz-btn" data-key="struggle" data-value="distance">🚀 Distance off the tee</button>
          <button class="quiz-btn" data-key="struggle" data-value="accuracy">🎯 Accuracy (slices, hooks)</button>
          <button class="quiz-btn" data-key="struggle" data-value="shortgame">⛳ Short game (chipping & putting)</button>
          <button class="quiz-btn" data-key="struggle" data-value="management">🧠 Course management</button>
        </div>
      </div>
    </div>

    <div id="quiz-results" style="display:none;">
      <div style="text-align:center;margin-bottom:32px;">
        <span style="font-size:48px;">🎉</span>
        <h2 style="font-family:'Playfair Display',serif;font-size:26px;color:var(--green);margin:12px 0 6px;">Your Personalized Gear Plan</h2>
        <p style="font-size:14px;color:var(--muted);">Based on your answers, here's where to start — curated by the Cubical Golfer team.</p>
      </div>
      <div id="results-cards" style="display:flex;flex-direction:column;gap:16px;"></div>
      <div style="text-align:center;margin-top:32px;">
        <button id="retake-btn" style="background:none;border:2px solid var(--green);color:var(--green);padding:12px 28px;border-radius:8px;font-size:14px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;">← Retake Quiz</button>
        <a href="/gear-reviews/" style="display:inline-block;margin-left:12px;background:var(--green);color:#fff;padding:12px 28px;border-radius:8px;font-size:14px;font-weight:700;text-decoration:none;">Browse All Gear →</a>
      </div>
    </div>
  </div>

  <style>
    .quiz-options { display: flex; flex-direction: column; gap: 10px; }
    .quiz-btn { display: flex; align-items: center; gap: 12px; width: 100%; padding: 16px 20px; border-radius: 10px; border: 2px solid var(--border); background: #fff; font-size: 15px; font-weight: 600; color: var(--text); cursor: pointer; transition: all .2s ease; text-align: left; font-family: 'DM Sans', sans-serif; }
    .quiz-btn:hover { border-color: var(--green); background: #f0f7f2; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(0,0,0,.06); }
    .quiz-btn.selected { border-color: var(--green); background: var(--green); color: #fff; }
    .result-card { background: #fff; border: 1px solid var(--border); border-radius: 12px; padding: 24px; display: flex; gap: 16px; align-items: flex-start; transition: box-shadow .2s; }
    .result-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,.08); }
    .result-num { flex-shrink: 0; width: 36px; height: 36px; border-radius: 50%; background: var(--green); color: var(--gold); font-weight: 800; font-size: 16px; display: flex; align-items: center; justify-content: center; }
    .result-body h3 { font-size: 17px; font-weight: 700; color: var(--green); margin: 0 0 6px; }
    .result-body p { font-size: 14px; line-height: 1.6; color: var(--body); margin: 0 0 10px; }
    .result-link { display: inline-block; font-size: 13px; font-weight: 700; color: var(--green); text-decoration: none; padding: 6px 14px; border: 2px solid var(--green); border-radius: 6px; transition: all .15s; }
    .result-link:hover { background: var(--green); color: #fff; }
    @media (max-width: 640px) { .result-card { flex-direction: column; } }
  </style>

  <script is:inline>
    (function(){var answers={},step=1;var R={'beginner-distance':[{title:'Best Beginner Golf Set Under $500',desc:'A complete set with a forgiving driver is the fastest way to add distance when starting out.',,product:'Callaway Strata — ~$350',buyUrl:'https://www.amazon.com/s?k=callaway-strata&crid=NX1FUJPIBPHI&sprefix=callaway-strata%2Caps%2C237&linkCode=ll2&tag=cubicalgolfer-20&linkId=f8eee3914245b8609f8a6c2f47dc6e7f&language=en_US&ref_=as_li_ss_tl',tag:'STARTER KIT'},{title:'Best Forgiving Drivers 2026',desc:'A game-improvement driver with a large sweet spot adds 10-15 yards vs a hand-me-down.',,product:'Callaway Paradym Ai Smoke Max',buyUrl:'https://www.amazon.com/s?k=callaway-paradym-ai-smoke-max&crid=92H1TORWBRWG&sprefix=callaway-paradym-ai-smoke-max%2Caps%2C273&linkCode=ll2&tag=cubicalgolfer-20&linkId=d31411ba8352b4d9f7296f9db3a8a1cc&language=en_US&ref_=as_li_ss_tl',tag:'DISTANCE'},{title:'Best Golf Balls for 90 MPH Swing Speed',desc:'The right compression ball matched to your speed adds free yards off the tee.',,product:'Callaway Chrome Soft — ~$48/dz',buyUrl:'https://www.amazon.com/s?k=callaway-chrome-soft&crid=QIR72QBZ6WKH&sprefix=callaway-chev-dry%2Caps%2C236&linkCode=ll2&tag=cubicalgolfer-20&linkId=f149acca562ed2c5be4885a11bef7119&language=en_US&ref_=as_li_ss_tl',tag:'BALL FIT'}],'beginner-accuracy':[{title:'How to Fix Your Slice Permanently',desc:'Fix your grip first — this single change corrects 70% of rightward misses.',,product:'Alignment Sticks — ~$12',buyUrl:'https://www.amazon.com/s?k=alignment-sticks&linkCode=ll2&tag=cubicalgolfer-20&linkId=20a38f5eb8ee11b58ceb9bf4c530ad56&language=en_US&ref_=as_li_ss_tl',tag:'FIX #1'},{title:'Best Golf Training Aids 2026',desc:'Alignment sticks ($12) and a putting mirror ($25) fix the two most common beginner errors.',,product:'Eyeline Speed Trap — ~$40',buyUrl:'https://www.amazon.com/s?k=eyeline-speed-trap&crid=3QQIO1QEIP9GU&sprefix=eyeline-speed-trap%2Caps%2C212&linkCode=ll2&tag=cubicalgolfer-20&linkId=9cd5b323332a89a7372967c87716a78f&language=en_US&ref_=as_li_ss_tl',tag:'TRAINING'},{title:'15-Minute Morning Practice Routine',desc:'Fifteen minutes before work, 3x per week, builds more muscle memory than weekend range balls.',url:'/golf-practice-routine-before-work/',tag:'PRACTICE'}],'beginner-shortgame':[{title:'How to Improve Your Putting',desc:'65% of all strokes happen inside 100 yards. A putting mirror and 10 min daily drops scores fast.',url:'/how-to-improve-putting/',tag:'PUTTING'},{title:'Best Golf Putters 2026',desc:'A quality mallet putter with alignment aids helps beginners aim correctly from day one.',,product:'Odyssey White Hot OG — ~$200',buyUrl:'https://www.amazon.com/s?k=odyssey-white-hot-og&crid=16YH6OZ4FJA4I&sprefix=odyssey-white-hot-og%2Caps%2C228&linkCode=ll2&tag=cubicalgolfer-20&linkId=3d89d732d7ee894fc9bfdf10993f57f2&language=en_US&ref_=as_li_ss_tl',tag:'PUTTER'},{title:'7 Practice Drills at Home (15 Min)',desc:'Gate putting, clock drill, and one-handed chips — drills you can do on carpet.',,product:'Putting Mirror — ~$25',buyUrl:'https://www.amazon.com/s?k=putting-mirror&crid=1DNI4IB9OQQKB&sprefix=%2Caps%2C231&linkCode=ll2&tag=cubicalgolfer-20&linkId=d4587e07ee894decaa218a2e18b12259&language=en_US&ref_=as_li_ss_tl',tag:'DRILLS'}],'beginner-management':[{title:'How to Break 90: Weekend Roadmap',desc:'Eliminate blow-up holes and aim center of every green. The math is simple.',,product:'Garmin S62 — ~$400',buyUrl:'https://www.amazon.com/dp/B083BJSYZ9?th=1&linkCode=ll2&tag=cubicalgolfer-20&linkId=e72a18832542c8be1be00a9e4e7c02cf&language=en_US&ref_=as_li_ss_tl',tag:'SCORING'},{title:'Golf for Beginners — Complete Guide',desc:'Grip, stance, etiquette, and the rules that matter. Play confidently from round one.',url:'/golf-for-beginners/',tag:'START HERE'},{title:'Best Golf GPS Watches 2026',desc:'Exact yardages eliminate guessing — the #1 cause of bad club selection.',,product:'Garmin S62 — ~$400',buyUrl:'https://www.amazon.com/dp/B083BJSYZ9?th=1&linkCode=ll2&tag=cubicalgolfer-20&linkId=e72a18832542c8be1be00a9e4e7c02cf&language=en_US&ref_=as_li_ss_tl',tag:'GPS'}],'mid-distance':[{title:'Best Forgiving Drivers 2026',desc:'The right driver adds 8-12 yards. Callaway Paradym Ai Smoke Max won for forgiveness.',url:'/best-golf-drivers-forgiveness/',tag:'DRIVER'},{title:'Best Golf Balls for 90 MPH Swing Speed',desc:'Stop playing a Pro V1 at 90 mph. A Srixon Q-Star Tour ($35/dz) compresses better.',,product:'Callaway Chrome Soft — ~$48/dz',buyUrl:'https://www.amazon.com/s?k=callaway-chrome-soft&crid=QIR72QBZ6WKH&sprefix=callaway-chev-dry%2Caps%2C236&linkCode=ll2&tag=cubicalgolfer-20&linkId=f149acca562ed2c5be4885a11bef7119&language=en_US&ref_=as_li_ss_tl',tag:'BALL FIT'},{title:'Best Golf Launch Monitors 2026',desc:'A launch monitor replaces guesswork with data. The Garmin R10 ($549) is the best entry point.',,product:'Garmin R10 — ~$499',buyUrl:'https://www.amazon.com/s?k=garmin-approach-r10&crid=AWZ8FFFKGC2J&sprefix=garmin-approach-r10%2Caps%2C221&linkCode=ll2&tag=cubicalgolfer-20&linkId=46ccb5b66ca58f69d53706151a8b29d5&language=en_US&ref_=as_li_ss_tl',tag:'DATA'}],'mid-accuracy':[{title:'How to Fix Your Slice Permanently',desc:'Strengthen your grip and feel the clubface close through impact — specific drills inside.',,product:'Alignment Sticks — ~$12',buyUrl:'https://www.amazon.com/s?k=alignment-sticks&linkCode=ll2&tag=cubicalgolfer-20&linkId=20a38f5eb8ee11b58ceb9bf4c530ad56&language=en_US&ref_=as_li_ss_tl',tag:'FIX'},{title:'Best Golf Irons 2026',desc:'Game-improvement irons with wider soles keep your misses on the green.',,product:'Ping G430 Irons — ~$899',buyUrl:'https://www.amazon.com/s?k=ping-g430-irons&crid=26DOLJQXUKNCK&sprefix=ping-g-le3-irons%2Caps%2C281&linkCode=ll2&tag=cubicalgolfer-20&linkId=0b6addcf8c874447523eb837b6e5b3f2&language=en_US&ref_=as_li_ss_tl',tag:'IRONS'},{title:'Best Golf Rangefinders 2026',desc:'Knowing exact yardage eliminates 2-3 bad club selections per round.',,product:'Bushnell Tour V6 Shift',buyUrl:'https://bushnell.pxf.io/DWWLOa',tag:'RANGEFINDER'}],'mid-shortgame':[{title:'How to Stop 3-Putting',desc:'Three-putting is a distance control problem. Lag putt to within 3 feet and they disappear.',,product:'Putting Mirror — ~$25',buyUrl:'https://www.amazon.com/s?k=putting-mirror&crid=1DNI4IB9OQQKB&sprefix=%2Caps%2C231&linkCode=ll2&tag=cubicalgolfer-20&linkId=d4587e07ee894decaa218a2e18b12259&language=en_US&ref_=as_li_ss_tl',tag:'PUTTING'},{title:'Best Golf Putters 2026',desc:'Upgrading from a starter-set putter saves 1-3 putts per round.',,product:'Odyssey White Hot OG — ~$200',buyUrl:'https://www.amazon.com/s?k=odyssey-white-hot-og&crid=16YH6OZ4FJA4I&sprefix=odyssey-white-hot-og%2Caps%2C228&linkCode=ll2&tag=cubicalgolfer-20&linkId=3d89d732d7ee894fc9bfdf10993f57f2&language=en_US&ref_=as_li_ss_tl',tag:'PUTTER'},{title:'15-Minute Morning Practice Routine',desc:'Gate putting + towel chipping before work — our testers dropped 1.8 strokes in 8 weeks.',url:'/golf-practice-routine-before-work/',tag:'ROUTINE'}],'mid-management':[{title:'Best Golf Rangefinders 2026',desc:'Course management starts with knowing your numbers. Eliminate guessing on every approach.',,product:'Bushnell Tour V6 Shift',buyUrl:'https://bushnell.pxf.io/DWWLOa',tag:'RANGEFINDER'},{title:'Best Golf GPS Watches 2026',desc:'Front/middle/back of every green plus hazard distances — all on your wrist.',,product:'Garmin S62 — ~$400',buyUrl:'https://www.amazon.com/dp/B083BJSYZ9?th=1&linkCode=ll2&tag=cubicalgolfer-20&linkId=e72a18832542c8be1be00a9e4e7c02cf&language=en_US&ref_=as_li_ss_tl',tag:'GPS WATCH'},{title:'How to Break 90: Weekend Roadmap',desc:'Stop chasing pins. Aim center-green and eliminate triples.',url:'/how-to-break-90/',tag:'STRATEGY'}],'low-distance':[{title:'Best Golf Launch Monitors 2026',desc:'Optimize launch angle and spin rate with real data.',,product:'Garmin R10 — ~$499',buyUrl:'https://www.amazon.com/s?k=garmin-approach-r10&crid=AWZ8FFFKGC2J&sprefix=garmin-approach-r10%2Caps%