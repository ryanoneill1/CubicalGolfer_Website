---
// src/pages/gear-quiz/index.astro — Interactive gear recommendation quiz
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumbSchema } from '../../lib/schema';

const meta = {
  title: 'Golf Gear Quiz — Find Your Perfect Gear in 30 Seconds',
  description: 'Answer 4 quick questions and get personalized golf gear recommendations based on your handicap, budget, and game. Built by the Cubical Golfer team.',
  canonical: 'https://www.cubicalgolfer.com/gear-quiz/',
  ogImage: 'https://www.cubicalgolfer.com/images/og-image.jpg',
  ogType: 'website' as const,
  robots: 'index, follow',
  breadcrumbs: [
    { label: 'Home', href: '/' },
    { label: 'Gear Quiz', href: '/gear-quiz/' },
  ],
};
const schemas = [breadcrumbSchema(meta.breadcrumbs)];
---

<BaseLayout {meta} {schemas} activeNav="gear-quiz">

  <header class="cat-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep" aria-hidden="true">›</span>
      <span aria-current="page">Gear Quiz</span>
    </nav>
    <h1>🎯 What Gear Should You Buy Next?</h1>
    <p class="cat-subhead">4 questions. 30 seconds. Personalized recommendations from a team of desk jockeys who test golf gear between meetings.</p>
  </header>

  <div id="quiz-container" style="max-width:680px;margin:0 auto;padding:0 var(--page-px) 60px;">
    <div id="quiz-progress" style="margin-bottom:32px;">
      <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
        <span id="progress-label" style="font-size:13px;font-weight:600;color:var(--muted);">Question 1 of 4</span>
        <span id="progress-pct" style="font-size:13px;font-weight:600;color:var(--green);">25%</span>
      </div>
      <div style="background:var(--cream-dark);border-radius:20px;height:8px;overflow:hidden;">
        <div id="progress-bar" style="background:var(--gold);height:100%;width:25%;border-radius:20px;transition:width .4s ease;"></div>
      </div>
    </div>

    <div id="quiz-questions">
      <div class="quiz-step" data-step="1" style="display:block;">
        <h2 style="font-family:'Playfair Display',serif;font-size:22px;color:var(--green);margin-bottom:6px;">What's your handicap range?</h2>
        <p style="font-size:14px;color:var(--muted);margin-bottom:20px;">No judgment — this helps us recommend the right level of gear.</p>
        <div class="quiz-options">
          <button class="quiz-btn" data-key="handicap" data-value="beginner">🏌️ Beginner (25+)</button>
          <button class="quiz-btn" data-key="handicap" data-value="mid">⛳ Mid Handicap (15–25)</button>
          <button class="quiz-btn" data-key="handicap" data-value="low">🎯 Low Handicap (5–15)</button>
          <button class="quiz-btn" data-key="handicap" data-value="scratch">🏆 Scratch or Better (&lt;5)</button>
        </div>
      </div>

      <div class="quiz-step" data-step="2" style="display:none;">
        <h2 style="font-family:'Playfair Display',serif;font-size:22px;color:var(--green);margin-bottom:6px;">How often do you play?</h2>
        <p style="font-size:14px;color:var(--muted);margin-bottom:20px;">This helps us calibrate value-for-money recommendations.</p>
        <div class="quiz-options">
          <button class="quiz-btn" data-key="frequency" data-value="monthly">📅 Monthly</button>
          <button class="quiz-btn" data-key="frequency" data-value="2-3x">🗓️ 2–3x per month</button>
          <button class="quiz-btn" data-key="frequency" data-value="weekly">📆 Weekly</button>
          <button class="quiz-btn" data-key="frequency" data-value="2+weekly">🔥 2+ per week</button>
        </div>
      </div>

      <div class="quiz-step" data-step="3" style="display:none;">
        <h2 style="font-family:'Playfair Display',serif;font-size:22px;color:var(--green);margin-bottom:6px;">What's your budget for one piece of gear?</h2>
        <p style="font-size:14px;color:var(--muted);margin-bottom:20px;">We'll only recommend gear that fits your price range.</p>
        <div class="quiz-options">
          <button class="quiz-btn" data-key="budget" data-value="under50">💵 Under $50</button>
          <button class="quiz-btn" data-key="budget" data-value="50-150">💰 $50–$150</button>
          <button class="quiz-btn" data-key="budget" data-value="150-300">💎 $150–$300</button>
          <button class="quiz-btn" data-key="budget" data-value="300+">🏅 $300+</button>
        </div>
      </div>

      <div class="quiz-step" data-step="4" style="display:none;">
        <h2 style="font-family:'Playfair Display',serif;font-size:22px;color:var(--green);margin-bottom:6px;">What do you struggle with most?</h2>
        <p style="font-size:14px;color:var(--muted);margin-bottom:20px;">Pick the one area where you lose the most strokes.</p>
        <div class="quiz-options">
          <button class="quiz-btn" data-key="struggle" data-value="distance">🚀 Distance off the tee</button>
          <button class="quiz-btn" data-key="struggle" data-value="accuracy">🎯 Accuracy (slices, hooks)</button>
          <button class="quiz-btn" data-key="struggle" data-value="shortgame">⛳ Short game (chipping & putting)</button>
          <button class="quiz-btn" data-key="struggle" data-value="management">🧠 Course management</button>
        </div>
      </div>
    </div>

    <div id="quiz-results" style="display:none;">
      <div style="text-align:center;margin-bottom:32px;">
        <span style="font-size:48px;">🎉</span>
        <h2 style="font-family:'Playfair Display',serif;font-size:26px;color:var(--green);margin:12px 0 6px;">Your Personalized Gear Plan</h2>
        <p style="font-size:14px;color:var(--muted);">Based on your answers, here's where to start — curated by the Cubical Golfer team.</p>
      </div>
      <div id="results-cards" style="display:flex;flex-direction:column;gap:16px;"></div>
      <div style="text-align:center;margin-top:32px;">
        <button id="retake-btn" style="background:none;border:2px solid var(--green);color:var(--green);padding:12px 28px;border-radius:8px;font-size:14px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;">← Retake Quiz</button>
        <a href="/gear-reviews/" style="display:inline-block;margin-left:12px;background:var(--green);color:#fff;padding:12px 28px;border-radius:8px;font-size:14px;font-weight:700;text-decoration:none;">Browse All Gear →</a>
      </div>
    </div>
  </div>

  <style>
    .quiz-options { display: flex; flex-direction: column; gap: 10px; }
    .quiz-btn { display: flex; align-items: center; gap: 12px; width: 100%; padding: 16px 20px; border-radius: 10px; border: 2px solid var(--border); background: #fff; font-size: 15px; font-weight: 600; color: var(--text); cursor: pointer; transition: all .2s ease; text-align: left; font-family: 'DM Sans', sans-serif; }
    .quiz-btn:hover { border-color: var(--green); background: #f0f7f2; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(0,0,0,.06); }
    .quiz-btn.selected { border-color: var(--green); background: var(--green); color: #fff; }
    .result-card { background: #fff; border: 1px solid var(--border); border-radius: 12px; padding: 24px; display: flex; gap: 16px; align-items: flex-start; transition: box-shadow .2s; }
    .result-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,.08); }
    .result-num { flex-shrink: 0; width: 36px; height: 36px; border-radius: 50%; background: var(--green); color: var(--gold); font-weight: 800; font-size: 16px; display: flex; align-items: center; justify-content: center; }
    .result-body h3 { font-size: 17px; font-weight: 700; color: var(--green); margin: 0 0 6px; }
    .result-body p { font-size: 14px; line-height: 1.6; color: var(--body); margin: 0 0 10px; }
    .result-link { display: inline-block; font-size: 13px; font-weight: 700; color: var(--green); text-decoration: none; padding: 6px 14px; border: 2px solid var(--green); border-radius: 6px; transition: all .15s; }
    .result-link:hover { background: var(--green); color: #fff; }
    @media (max-width: 640px) { .result-card { flex-direction: column; } }
  </style>

  <script is:inline>
    (function(){var answers={},step=1;var R={'beginner-distance':[{title:'Best Beginner Golf Set Under $500',desc:'A complete set with a forgiving driver is the fastest way to add distance when starting out.',url:'/best-beginner-golf-set-under-500/',tag:'STARTER KIT'},{title:'Best Forgiving Drivers 2026',desc:'A game-improvement driver with a large sweet spot adds 10-15 yards vs a hand-me-down.',url:'/best-golf-drivers-forgiveness/',tag:'DISTANCE'},{title:'Best Golf Balls for 90 MPH Swing Speed',desc:'The right compression ball matched to your speed adds free yards off the tee.',url:'/best-golf-balls-90-mph-swing-speed/',tag:'BALL FIT'}],'beginner-accuracy':[{title:'How to Fix Your Slice Permanently',desc:'Fix your grip first — this single change corrects 70% of rightward misses.',url:'/how-to-fix-your-slice/',tag:'FIX #1'},{title:'Best Golf Training Aids 2026',desc:'Alignment sticks ($12) and a putting mirror ($25) fix the two most common beginner errors.',url:'/best-golf-training-aids/',tag:'TRAINING'},{title:'15-Minute Morning Practice Routine',desc:'Fifteen minutes before work, 3x per week, builds more muscle memory than weekend range balls.',url:'/golf-practice-routine-before-work/',tag:'PRACTICE'}],'beginner-shortgame':[{title:'How to Improve Your Putting',desc:'65% of all strokes happen inside 100 yards. A putting mirror and 10 min daily drops scores fast.',url:'/how-to-improve-putting/',tag:'PUTTING'},{title:'Best Golf Putters 2026',desc:'A quality mallet putter with alignment aids helps beginners aim correctly from day one.',url:'/best-golf-putters-2026/',tag:'PUTTER'},{title:'7 Practice Drills at Home (15 Min)',desc:'Gate putting, clock drill, and one-handed chips — drills you can do on carpet.',url:'/golf-practice-drills-at-home/',tag:'DRILLS'}],'beginner-management':[{title:'How to Break 90: Weekend Roadmap',desc:'Eliminate blow-up holes and aim center of every green. The math is simple.',url:'/how-to-break-90/',tag:'SCORING'},{title:'Golf for Beginners — Complete Guide',desc:'Grip, stance, etiquette, and the rules that matter. Play confidently from round one.',url:'/golf-for-beginners/',tag:'START HERE'},{title:'Best Golf GPS Watches 2026',desc:'Exact yardages eliminate guessing — the #1 cause of bad club selection.',url:'/best-golf-gps-watches/',tag:'GPS'}],'mid-distance':[{title:'Best Forgiving Drivers 2026',desc:'The right driver adds 8-12 yards. Callaway Paradym Ai Smoke Max won for forgiveness.',url:'/best-golf-drivers-forgiveness/',tag:'DRIVER'},{title:'Best Golf Balls for 90 MPH Swing Speed',desc:'Stop playing a Pro V1 at 90 mph. A Srixon Q-Star Tour ($35/dz) compresses better.',url:'/best-golf-balls-90-mph-swing-speed/',tag:'BALL FIT'},{title:'Best Golf Launch Monitors 2026',desc:'A launch monitor replaces guesswork with data. The Garmin R10 ($549) is the best entry point.',url:'/best-golf-launch-monitors-2026/',tag:'DATA'}],'mid-accuracy':[{title:'How to Fix Your Slice Permanently',desc:'Strengthen your grip and feel the clubface close through impact — specific drills inside.',url:'/how-to-fix-your-slice/',tag:'FIX'},{title:'Best Golf Irons 2026',desc:'Game-improvement irons with wider soles keep your misses on the green.',url:'/best-golf-irons-2026/',tag:'IRONS'},{title:'Best Golf Rangefinders 2026',desc:'Knowing exact yardage eliminates 2-3 bad club selections per round.',url:'/best-golf-rangefinders-2026/',tag:'RANGEFINDER'}],'mid-shortgame':[{title:'How to Stop 3-Putting',desc:'Three-putting is a distance control problem. Lag putt to within 3 feet and they disappear.',url:'/how-to-stop-3-putting/',tag:'PUTTING'},{title:'Best Golf Putters 2026',desc:'Upgrading from a starter-set putter saves 1-3 putts per round.',url:'/best-golf-putters-2026/',tag:'PUTTER'},{title:'15-Minute Morning Practice Routine',desc:'Gate putting + towel chipping before work — our testers dropped 1.8 strokes in 8 weeks.',url:'/golf-practice-routine-before-work/',tag:'ROUTINE'}],'mid-management':[{title:'Best Golf Rangefinders 2026',desc:'Course management starts with knowing your numbers. Eliminate guessing on every approach.',url:'/best-golf-rangefinders-2026/',tag:'RANGEFINDER'},{title:'Best Golf GPS Watches 2026',desc:'Front/middle/back of every green plus hazard distances — all on your wrist.',url:'/best-golf-gps-watches/',tag:'GPS WATCH'},{title:'How to Break 90: Weekend Roadmap',desc:'Stop chasing pins. Aim center-green and eliminate triples.',url:'/how-to-break-90/',tag:'STRATEGY'}],'low-distance':[{title:'Best Golf Launch Monitors 2026',desc:'Optimize launch angle and spin rate with real data.',url:'/best-golf-launch-monitors-2026/',tag:'LAUNCH MON'},{title:'Best Forgiving Drivers 2026',desc:'Even low handicappers benefit from forgiveness on off-center hits.',url:'/best-golf-drivers-forgiveness/',tag:'DRIVER'},{title:'Best Golf Balls 2026',desc:'Ball selection matters at your speed. Compression and spin matched to your game.',url:'/best-golf-balls-2026/',tag:'BALL'}],'low-accuracy':[{title:'Best Golf Irons 2026',desc:'Players irons with the right shaft flex sharpen dispersion.',url:'/best-golf-irons-2026/',tag:'IRONS'},{title:'Best Golf Swing Analyzers 2026',desc:'Sensor-based analysis catches patterns your eye misses.',url:'/best-golf-swing-analyzers/',tag:'ANALYZER'},{title:'Best Golf Rangefinders 2026',desc:'Precise yardage + slope = the right club every time.',url:'/best-golf-rangefinders-2026/',tag:'RANGEFINDER'}],'low-shortgame':[{title:'Best Golf Putters 2026',desc:'Putter fitting matters at your level. Lie angle and insert affect make percentage.',url:'/best-golf-putters-2026/',tag:'PUTTER'},{title:'How to Stop 3-Putting',desc:'Speed control drills for the 25-40 foot range.',url:'/how-to-stop-3-putting/',tag:'LAG SPEED'},{title:'Best Golf Training Aids 2026',desc:'Pressure putting trainers for deliberate practice.',url:'/best-golf-training-aids/',tag:'TRAINING'}],'low-management':[{title:'Best Golf GPS Watches 2026',desc:'The Garmin S62 Virtual Caddie suggests clubs based on your strokes-gained data.',url:'/best-golf-gps-watches/',tag:'GPS WATCH'},{title:'Best Golf Rangefinders 2026',desc:'Laser precision + slope for every approach shot.',url:'/best-golf-rangefinders-2026/',tag:'RANGEFINDER'},{title:'Best Golf Apps 2026',desc:'Shot tracking reveals where you actually lose strokes.',url:'/best-golf-apps/',tag:'APPS'}],'scratch-distance':[{title:'Best Golf Launch Monitors 2026',desc:'Optimize launch conditions with spin axis, apex, and descent angle.',url:'/best-golf-launch-monitors-2026/',tag:'LAUNCH MON'},{title:'Trackman 4 vs Foresight GCQuad',desc:'The two systems every tour pro uses — compared.',url:'/trackman-vs-foresight-gcquad/',tag:'COMPARISON'},{title:'Best Forgiving Drivers 2026',desc:'Even scratch golfers miss the center. The right driver holds ball speed.',url:'/best-golf-drivers-forgiveness/',tag:'DRIVER'}],'scratch-accuracy':[{title:'Best Golf Irons 2026',desc:'Iron fitting with shaft optimization is the biggest accuracy lever.',url:'/best-golf-irons-2026/',tag:'IRONS'},{title:'Best Golf Swing Analyzers 2026',desc:'Sensor-based analysis catches patterns your eye misses.',url:'/best-golf-swing-analyzers/',tag:'ANALYZER'},{title:'Best Golf Launch Monitors 2026',desc:'Indoor practice with real data feedback.',url:'/best-golf-launch-monitors-2026/',tag:'DATA'}],'scratch-shortgame':[{title:'Best Golf Putters 2026',desc:'MOI and face insert technology separate makes from misses on critical putts.',url:'/best-golf-putters-2026/',tag:'PUTTER'},{title:'Best Golf Balls 2026',desc:'Greenside spin control — our data shows which balls check and hold.',url:'/best-golf-balls-2026/',tag:'BALL'},{title:'Best Golf Training Aids 2026',desc:'Targeted pressure putting trainers for competitive practice.',url:'/best-golf-training-aids/',tag:'TRAINING'}],'scratch-management':[{title:'Best Golf GPS Watches 2026',desc:'Virtual Caddie suggests the statistically optimal play.',url:'/best-golf-gps-watches/',tag:'GPS WATCH'},{title:'Best Golf Rangefinders 2026',desc:'Sub-yard accuracy + slope + jolt confirmation.',url:'/best-golf-rangefinders-2026/',tag:'RANGEFINDER'},{title:'Best Golf Apps 2026',desc:'Strokes-gained analysis by shot type and hole type.',url:'/best-golf-apps/',tag:'ANALYTICS'}]};document.querySelectorAll('.quiz-btn').forEach(function(b){b.addEventListener('click',function(){var k=this.getAttribute('data-key'),v=this.getAttribute('data-value');answers[k]=v;this.parentElement.querySelectorAll('.quiz-btn').forEach(function(x){x.classList.remove('selected')});this.classList.add('selected');setTimeout(function(){if(step<4){document.querySelector('[data-step="'+step+'"]').style.display='none';step++;document.querySelector('[data-step="'+step+'"]').style.display='block';document.getElementById('progress-label').textContent='Question '+step+' of 4';document.getElementById('progress-pct').textContent=(step*25)+'%';document.getElementById('progress-bar').style.width=(step*25)+'%'}else{showResults()}},300)})});function showResults(){document.getElementById('quiz-questions').style.display='none';document.getElementById('quiz-progress').style.display='none';document.getElementById('quiz-results').style.display='block';var k=answers.handicap+'-'+answers.struggle,recs=R[k]||R['mid-accuracy'],h='';recs.forEach(function(r,i){h+='<div class="result-card"><div class="result-num">'+(i+1)+'</div><div class="result-body"><span style="font-size:11px;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:.08em;">'+r.tag+'</span><h3>'+r.title+'</h3><p>'+r.desc+'</p><a href="'+r.url+'" class="result-link">Read the Full Guide →</a></div></div>'});document.getElementById('results-cards').innerHTML=h}document.getElementById('retake-btn').addEventListener('click',function(){step=1;answers={};document.getElementById('quiz-results').style.display='none';document.getElementById('quiz-questions').style.display='block';document.getElementById('quiz-progress').style.display='block';document.querySelectorAll('.quiz-step').forEach(function(s){s.style.display='none'});document.querySelector('[data-step="1"]').style.display='block';document.querySelectorAll('.quiz-btn').forEach(function(b){b.classList.remove('selected')});document.getElementById('progress-label').textContent='Question 1 of 4';document.getElementById('progress-pct').textContent='25%';document.getElementById('progress-bar').style.width='25%'})})();
  </script>

</BaseLayout>
