---
/**
 * AuthorByline.astro — EEAT author attribution with per-article testing data.
 * Appears below H1, above article body.
 */
import { AUTHOR_PROFILE } from '../data/author';

interface Props {
  name?: string;
  handicap?: string;
  roundsTested?: number;
  lastTested?: string;
  courseTested?: string;
  photoUrl?: string;
}

const {
  name = AUTHOR_PROFILE.name,
  handicap = AUTHOR_PROFILE.handicapLabel,
  roundsTested,
  lastTested,
  courseTested,
  photoUrl = AUTHOR_PROFILE.photoPath,
} = Astro.props;

const initials = name.split(' ').map(w => w[0]).join('').toUpperCase();
---

<div class="ab">
  <div class="ab__photo">
    {photoUrl ? (
      <img src={photoUrl} alt={name} width="40" height="40" loading="eager" decoding="async" />
    ) : (
      <span class="ab__initials">{initials}</span>
    )}
  </div>
  <div class="ab__text">
    <p class="ab__name">By {name} · <span class="ab__hcap">{handicap}</span></p>
    <p class="ab__meta">
      {roundsTested && <span>Tested {roundsTested} rounds</span>}
      {roundsTested && lastTested && <span> · </span>}
      {lastTested && <span>Last on-course: {lastTested}</span>}
      {courseTested && <span class="ab__course"> · 📍 {courseTested}</span>}
    </p>
  </div>
  <a href="/how-we-test/" class="ab__link">How we test →</a>
</div>

<style>
.ab {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 0;
  border-bottom: 1px solid var(--border, #D8D3C8);
  margin-bottom: 20px;
  flex-wrap: wrap;
}

.ab__photo {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: var(--green, #1E3A28);
  display: flex;
  align-items: center;
  justify-content: center;
}
.ab__photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.ab__initials {
  color: var(--gold, #C8A84B);
  font-size: 14px;
  font-weight: 700;
}

.ab__text { flex: 1; min-width: 180px; }

.ab__name {
  font-size: 14px;
  font-weight: 600;
  color: var(--text, #1A2B1F);
  margin: 0 0 2px;
}
.ab__hcap { font-weight: 400; color: var(--muted, #556B5C); }

.ab__meta {
  font-size: 12px;
  color: var(--muted, #556B5C);
  margin: 0;
  line-height: 1.4;
}
.ab__course { white-space: nowrap; }

.ab__link {
  font-size: 12px;
  font-weight: 600;
  color: var(--green, #1E3A28);
  text-decoration: underline;
  text-underline-offset: 2px;
  flex-shrink: 0;
}
.ab__link:hover { color: var(--gold, #C8A84B); }

@media (max-width: 480px) {
  .ab { gap: 10px; }
  .ab__link { width: 100%; text-align: left; padding-left: 52px; }
}
</style>
