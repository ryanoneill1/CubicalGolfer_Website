---
/**
 * AffiliateCTA.astro
 * Prominent "Buy Now" / "Check Price" CTA block.
 */

interface Props {
  url: string;
  price: string;
  name: string;
  retailer: string;
  label?: string;
  size?: 'sm' | 'md' | 'lg';
  variant?: 'primary' | 'secondary' | 'urgent';
  disclosure?: boolean;
  dateChecked?: string;
  isWinner?: boolean;
}

const {
  url,
  price,
  name,
  retailer,
  label,
  size = 'md',
  variant = 'primary',
  disclosure = false,
  dateChecked = '',
  isWinner = false,
} = Astro.props;

const btnText = `${price} at ${retailer} — Check Today's Price →`;
const dateLabel = dateChecked
  ? `Free shipping · Price last checked ${new Date(dateChecked + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}`
  : `Free shipping · Prices may vary`;
---

<div class:list={['aff-cta', `aff-cta--${size}`, `aff-cta--${variant}`]}>
  {isWinner && (
    <span class="aff-cta__winner-badge">💰 Lowest price we've seen</span>
  )}
  <a
    href={url}
    class="aff-cta__btn"
    target="_blank"
    rel="nofollow noopener sponsored"
    aria-label={`Check price for ${name} at ${retailer}`}
  >
    <span class="aff-cta__btn-text">{btnText}</span>
  </a>
  <p class="aff-cta__meta">{dateLabel}</p>
  {disclosure && (
    <p class="aff-cta__disclosure">
      ⚖️ <em>Affiliate link — we earn a small commission at no extra cost to you.</em>
    </p>
  )}
</div>

<style>
.aff-cta {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin: 20px 0;
  max-width: var(--prose-w, 720px);
}
.aff-cta__winner-badge {
  display: inline-block;
  align-self: flex-start;
  background: #f0f7f2;
  color: var(--green, #1E3A28);
  font-size: 12px;
  font-weight: 700;
  padding: 4px 12px;
  border-radius: 20px;
  border: 1px solid #b8dfc5;
  margin-bottom: 2px;
}

/* Button */
.aff-cta__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16px 32px;
  border-radius: 10px;
  text-decoration: none;
  font-weight: 800;
  min-width: 220px;
  text-align: center;
  transition: transform .15s ease, box-shadow .15s ease, background .15s ease;
}
.aff-cta__btn:hover {
  transform: scale(1.02);
  box-shadow: 0 6px 20px rgba(0,0,0,.15);
}
.aff-cta__btn-text { font-size: 15px; font-weight: 800; line-height: 1.3; }

/* Meta line */
.aff-cta__meta {
  font-size: 12px;
  color: var(--muted, #556B5C);
  margin: 0;
  font-weight: 500;
}

/* Variants */
.aff-cta--primary .aff-cta__btn {
  background: var(--gold, #C9A84C);
  color: #1a1a1a;
}
.aff-cta--primary .aff-cta__btn:hover { background: var(--gold-dark, #a8892e); }

.aff-cta--secondary .aff-cta__btn {
  background: var(--green, #1E3A28);
  color: #fff;
}
.aff-cta--secondary .aff-cta__btn:hover { background: #152c1e; }

.aff-cta--urgent .aff-cta__btn {
  background: #d63b2f;
  color: #fff;
}
.aff-cta--urgent .aff-cta__btn:hover { background: #b32d22; }

/* Sizes */
.aff-cta--sm .aff-cta__btn      { padding: 12px 22px; min-width: 180px; }
.aff-cta--sm .aff-cta__btn-text { font-size: 13px; }

.aff-cta--lg .aff-cta__btn      { padding: 20px 40px; min-width: 260px; }
.aff-cta--lg .aff-cta__btn-text { font-size: 17px; }

/* Disclosure */
.aff-cta__disclosure {
  font-size: 11px;
  color: var(--muted, #888);
  margin: 0;
}

@media (max-width: 480px) {
  .aff-cta__btn { width: 100%; padding: 16px 20px; }
}
</style>
