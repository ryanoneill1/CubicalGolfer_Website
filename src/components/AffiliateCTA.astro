---
/**
 * AffiliateCTA.astro
 * Prominent "Buy Now" / "Check Price" CTA block.
 * Use above the fold, mid-content, and at the bottom of each product section.
 *
 * Props:
 *   url        — Affiliate URL (required)
 *   price      — Price string e.g. "~$329"
 *   name       — Product name for aria-label
 *   retailer   — e.g. "Amazon", "Bushnell"
 *   label      — Custom button text (default: "Check Price")
 *   size       — "sm" | "md" | "lg" (default: "md")
 *   variant    — "primary" | "secondary" | "urgent" (default: "primary")
 *   disclosure — Show affiliate disclosure inline (default: false)
 */

interface Props {
  url: string;
  price: string;
  name: string;
  retailer: string;
  label?: string;
  size?: 'sm' | 'md' | 'lg';
  variant?: 'primary' | 'secondary' | 'urgent';
  disclosure?: boolean;
}

const {
  url,
  price,
  name,
  retailer,
  label = 'Buy Now',
  size = 'md',
  variant = 'primary',
  disclosure = false,
} = Astro.props;
---

<div class:list={['aff-cta', `aff-cta--${size}`, `aff-cta--${variant}`]}>
  <div class="aff-cta__inner">
    <div class="aff-cta__price">{price}</div>
    <a
      href={url}
      class="aff-cta__btn"
      target="_blank"
      rel="nofollow noopener sponsored"
      aria-label={`${label} — ${name} at ${retailer}`}
    >
      <span class="aff-cta__btn-text">{label} →</span>
      <span class="aff-cta__btn-sub">at {retailer} · Free shipping</span>
    </a>
  </div>
  {disclosure && (
    <p class="aff-cta__disclosure">
      ⚖️ <em>Affiliate link — we earn a small commission at no extra cost to you. Prices change frequently — click to see the current price.</em>
    </p>
  )}
</div>

<style>
.aff-cta {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin: 20px 0;
}
.aff-cta__inner {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.aff-cta__price {
  font-size: 28px;
  font-weight: 900;
  color: var(--green, #1E3A28);
  white-space: nowrap;
}

/* Button base */
.aff-cta__btn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 14px 28px;
  border-radius: 10px;
  text-decoration: none;
  font-weight: 800;
  transition: transform .15s, box-shadow .15s;
  min-width: 200px;
  text-align: center;
}
.aff-cta__btn:hover { transform: scale(1.03); box-shadow: 0 4px 16px rgba(0,0,0,.18); }
.aff-cta__btn-text { font-size: 15px; font-weight: 800; line-height: 1.2; }
.aff-cta__btn-sub  { font-size: 11px; font-weight: 500; opacity: .75; margin-top: 2px; }

/* Variants */
.aff-cta--primary .aff-cta__btn {
  background: var(--gold, #C9A84C);
  color: #1a1a1a;
}
.aff-cta--primary .aff-cta__btn:hover { background: var(--gold-dark, #a8892e); }

.aff-cta--secondary .aff-cta__btn {
  background: var(--green, #1E3A28);
  color: #fff;
}
.aff-cta--secondary .aff-cta__btn:hover { background: #152c1e; }

.aff-cta--urgent .aff-cta__btn {
  background: #d63b2f;
  color: #fff;
  animation: pulse-cta 2.5s ease-in-out infinite;
}
.aff-cta--urgent .aff-cta__btn:hover { background: #b32d22; animation: none; }
@keyframes pulse-cta {
  0%, 100% { box-shadow: 0 0 0 0 rgba(214,59,47,.4); }
  50%       { box-shadow: 0 0 0 8px rgba(214,59,47,.0); }
}

/* Sizes */
.aff-cta--sm .aff-cta__price    { font-size: 20px; }
.aff-cta--sm .aff-cta__btn      { padding: 10px 20px; min-width: 160px; }
.aff-cta--sm .aff-cta__btn-text { font-size: 13px; }

.aff-cta--lg .aff-cta__price    { font-size: 36px; }
.aff-cta--lg .aff-cta__btn      { padding: 18px 36px; min-width: 240px; font-size: 17px; }

/* Disclosure */
.aff-cta__disclosure {
  font-size: 11px;
  color: var(--muted, #888);
  margin: 0;
}

@media (max-width: 480px) {
  .aff-cta__inner { flex-direction: column; align-items: flex-start; }
  .aff-cta__btn   { width: 100%; }
}
</style>
