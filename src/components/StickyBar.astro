---
/**
 * StickyBar.astro — Sticky bottom CTA bar.
 * Appears after 40% scroll, hides near footer, dismissable.
 * Already wired to all buying guides via [...slug].astro template.
 */

interface Props {
  name: string;
  price: string;
  url: string;
  retailer: string;
  badge?: string;
}

const { name, price, url, retailer, badge = 'BEST PICK' } = Astro.props;

if (!url) return;
---

<div class="sb" id="sticky-bar" aria-label="Top product quick access" role="complementary">
  <div class="sb__inner">
    <div class="sb__left">
      <span class="sb__badge">{badge}</span>
      <span class="sb__name">{name}</span>
    </div>
    <div class="sb__right">
      <span class="sb__price">{price}</span>
      <a
        href={url}
        class="sb__btn"
        target="_blank"
        rel="nofollow noopener sponsored"
        aria-label={`Check price for ${name} at ${retailer}`}
      >
        Check Price →
      </a>
      <button class="sb__close" id="sticky-bar-close" aria-label="Dismiss" type="button">✕</button>
    </div>
  </div>
</div>

<script>
  const bar = document.getElementById('sticky-bar');
  const closeBtn = document.getElementById('sticky-bar-close');

  if (bar) {
    const KEY = 'sb_dismissed';
    const wasDismissed = sessionStorage.getItem(KEY) === '1';

    if (wasDismissed) {
      bar.remove();
    } else {
      const onScroll = () => {
        const scrollY = window.scrollY;
        const docH = document.body.scrollHeight;
        const winH = window.innerHeight;
        const threshold = docH * 0.4;
        const nearFooter = scrollY + winH > docH - 300;
        const bannerOpen = document.body.classList.contains('has-bottom-banner');

        if (scrollY > threshold && !nearFooter && !bannerOpen) {
          bar.classList.add('sb--visible');
        } else {
          bar.classList.remove('sb--visible');
        }
      };

      window.addEventListener('scroll', onScroll, { passive: true });

      if (closeBtn) {
        closeBtn.addEventListener('click', () => {
          bar.classList.remove('sb--visible');
          bar.style.display = 'none';
          sessionStorage.setItem(KEY, '1');
        });
      }
    }
  }
</script>

<style>
.sb {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: var(--green, #1E3A28);
  color: #fff;
  transform: translateY(100%);
  transition: transform .3s ease;
  box-shadow: 0 -4px 20px rgba(0,0,0,.25);
}
.sb--visible { transform: translateY(0); }

.sb__inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 12px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.sb__left {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
}

.sb__badge {
  background: var(--gold, #C9A84C);
  color: #1a1a1a;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: .08em;
  text-transform: uppercase;
  padding: 3px 10px;
  border-radius: 20px;
  white-space: nowrap;
  flex-shrink: 0;
}

.sb__name {
  font-size: 14px;
  font-weight: 600;
  color: rgba(255,255,255,.9);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sb__right {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-shrink: 0;
}

.sb__price {
  font-size: 18px;
  font-weight: 800;
  color: var(--gold, #C9A84C);
  white-space: nowrap;
}

.sb__btn {
  background: var(--gold, #C9A84C);
  color: #1a1a1a;
  font-size: 13px;
  font-weight: 800;
  padding: 10px 20px;
  border-radius: 8px;
  text-decoration: none;
  white-space: nowrap;
  transition: background .15s, transform .1s;
}
.sb__btn:hover {
  background: var(--gold-dark, #a8892e);
  transform: translateY(-1px);
}

.sb__close {
  background: none;
  border: none;
  color: rgba(255,255,255,.62);
  font-size: 16px;
  cursor: pointer;
  padding: 8px;
  line-height: 1;
  border-radius: 50%;
  transition: color .15s, background .15s;
}
.sb__close:hover {
  color: #fff;
  background: rgba(255,255,255,.1);
}

/* ── Mobile: larger touch targets ── */
@media (max-width: 640px) {
  .sb__inner {
    padding: 10px 14px;
    gap: 10px;
  }
  .sb__name {
    font-size: 12px;
    max-width: 120px;
  }
  .sb__price { font-size: 15px; }
  .sb__btn {
    padding: 14px 18px;
    font-size: 13px;
    min-height: 48px;
    display: flex;
    align-items: center;
  }
  .sb__badge { font-size: 9px; padding: 2px 8px; }
}
</style>
