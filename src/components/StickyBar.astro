---
/**
 * StickyBar.astro
 * Sticky "Check Price" bar that appears after scrolling 400px.
 * Highest-converting CTA placement on affiliate pages.
 * Only renders on buying guides with a top product.
 *
 * Props:
 *   name      — Top product name
 *   price     — Price string
 *   url       — Affiliate URL
 *   retailer  — Retailer name
 *   badge     — Short badge text e.g. "BEST OVERALL"
 */

interface Props {
  name: string;
  price: string;
  url: string;
  retailer: string;
  badge?: string;
}

const { name, price, url, retailer, badge = 'BEST PICK' } = Astro.props;

if (!url) return;
---

<div class="sticky-bar" id="sticky-bar" aria-label="Top product quick access" role="complementary">
  <div class="sticky-bar__inner">
    <div class="sticky-bar__label">
      <span class="sticky-bar__badge">{badge}</span>
      <span class="sticky-bar__name">{name}</span>
    </div>
    <div class="sticky-bar__right">
      <span class="sticky-bar__price">{price}</span>
      <a
        href={url}
        class="sticky-bar__btn"
        target="_blank"
        rel="nofollow noopener sponsored"
        aria-label={`Buy ${name} at ${retailer} — see current price`}
      >
        Buy Now →
      </a>
    </div>
  </div>
</div>

<script>
  const bar = document.getElementById('sticky-bar');
  if (bar) {
    // Show after scrolling 400px, hide near footer
    const onScroll = () => {
      const scrollY = window.scrollY;
      const docH = document.body.scrollHeight;
      const winH = window.innerHeight;
      const nearFooter = scrollY + winH > docH - 300;
      if (scrollY > 400 && !nearFooter) {
        bar.classList.add('sticky-bar--visible');
      } else {
        bar.classList.remove('sticky-bar--visible');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>

<style>
.sticky-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: var(--green, #1E3A28);
  color: #fff;
  transform: translateY(100%);
  transition: transform .3s ease;
  box-shadow: 0 -4px 20px rgba(0,0,0,.25);
}
.sticky-bar--visible {
  transform: translateY(0);
}
.sticky-bar__inner {
  max-width: 900px;
  margin: 0 auto;
  padding: 12px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
}
.sticky-bar__label {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}
.sticky-bar__badge {
  background: var(--gold, #C9A84C);
  color: #1a1a1a;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: .08em;
  text-transform: uppercase;
  padding: 3px 10px;
  border-radius: 20px;
  white-space: nowrap;
}
.sticky-bar__name {
  font-size: 14px;
  font-weight: 600;
  color: rgba(255,255,255,.9);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 220px;
}
.sticky-bar__right {
  display: flex;
  align-items: center;
  gap: 14px;
}
.sticky-bar__price {
  font-size: 18px;
  font-weight: 800;
  color: var(--gold, #C9A84C);
  white-space: nowrap;
}
.sticky-bar__btn {
  background: var(--gold, #C9A84C);
  color: #1a1a1a;
  font-size: 13px;
  font-weight: 800;
  padding: 10px 20px;
  border-radius: 8px;
  text-decoration: none;
  white-space: nowrap;
  transition: background .15s, transform .15s;
}
.sticky-bar__btn:hover {
  background: var(--gold-dark, #a8892e);
  transform: scale(1.03);
}
@media (max-width: 480px) {
  .sticky-bar__name { max-width: 140px; font-size: 12px; }
  .sticky-bar__price { font-size: 15px; }
  .sticky-bar__btn { padding: 8px 14px; font-size: 12px; }
}
</style>
