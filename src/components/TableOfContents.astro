---
/**
 * TableOfContents.astro — Jump navigation for long articles.
 * Desktop: sticky sidebar card. Mobile: collapsible accordion.
 */

interface TocItem {
  label: string;
  anchor: string;
  indent?: boolean;
}

interface Props {
  items: TocItem[];
  heading?: string;
}

const { items, heading = 'In this guide' } = Astro.props;

if (!items || items.length < 3) return;
---

<!-- Mobile: collapsible accordion -->
<details class="toc-mobile" id="toc-mobile">
  <summary class="toc-mobile__toggle">Jump to section ▼</summary>
  <nav class="toc-mobile__nav" aria-label="Table of contents">
    <ul class="toc__list">
      {items.map(item => (
        <li class={item.indent ? 'toc__item toc__item--sub' : 'toc__item'}>
          <a href={`#${item.anchor}`} class="toc__link" data-toc-anchor={item.anchor}>{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</details>

<!-- Desktop: sticky sidebar -->
<aside class="toc-desktop" id="toc-desktop" aria-label="Table of contents">
  <p class="toc-desktop__heading">{heading}</p>
  <nav>
    <ul class="toc__list">
      {items.map(item => (
        <li class={item.indent ? 'toc__item toc__item--sub' : 'toc__item'}>
          <a href={`#${item.anchor}`} class="toc__link" data-toc-anchor={item.anchor}>{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<script>
  // Mobile: collapse after tapping a link
  const mobile = document.getElementById('toc-mobile');
  if (mobile) {
    mobile.querySelectorAll('.toc__link').forEach(link => {
      link.addEventListener('click', () => {
        setTimeout(() => { (mobile as HTMLDetailsElement).open = false; }, 100);
      });
    });
  }

  // Desktop: highlight active section on scroll
  const desktop = document.getElementById('toc-desktop');
  if (desktop) {
    const links = desktop.querySelectorAll('.toc__link');
    const anchors: string[] = [];
    links.forEach(l => anchors.push((l as HTMLElement).dataset.tocAnchor || ''));

    const observer = new IntersectionObserver(entries => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          links.forEach(l => {
            const a = (l as HTMLElement).dataset.tocAnchor;
            l.classList.toggle('toc__link--active', a === id);
          });
        }
      }
    }, { rootMargin: '-80px 0px -70% 0px' });

    anchors.forEach(id => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  }
</script>

<style>
/* ── Shared list styles ─────────────────────────────── */
.toc__list {
  list-style: none;
  margin: 0;
  padding: 0;
}
.toc__item { margin-bottom: 2px; }
.toc__item--sub { padding-left: 16px; }

.toc__link {
  display: block;
  padding: 5px 12px;
  font-size: 13px;
  color: var(--muted, #556B5C);
  text-decoration: none;
  border-left: 2px solid transparent;
  border-radius: 0 4px 4px 0;
  transition: color 0.15s, border-color 0.15s, background 0.15s;
  line-height: 1.4;
}
.toc__link:hover {
  color: var(--green, #1E3A28);
  background: rgba(30, 58, 40, 0.04);
}
.toc__link--active {
  color: var(--green, #1E3A28);
  font-weight: 600;
  border-left-color: var(--gold, #C8A84B);
  background: rgba(30, 58, 40, 0.04);
}

/* ── Mobile accordion ───────────────────────────────── */
.toc-mobile {
  display: none;
  margin: 16px 0 24px;
  border: 1px solid var(--border, #D8D3C8);
  border-radius: var(--r1, 6px);
  background: var(--white, #fff);
  overflow: hidden;
}
.toc-mobile__toggle {
  display: block;
  padding: 12px 16px;
  font-size: 14px;
  font-weight: 600;
  color: var(--green, #1E3A28);
  cursor: pointer;
}
.toc-mobile__nav { padding: 0 8px 12px; }

/* ── Desktop sticky sidebar ─────────────────────────── */
.toc-desktop {
  display: none;
  position: sticky;
  top: 80px;
  max-height: calc(100vh - 100px);
  overflow-y: auto;
  padding: 16px 0 16px 8px;
  border-left: 1px solid var(--border, #D8D3C8);
}
.toc-desktop__heading {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted, #556B5C);
  margin: 0 0 10px 12px;
}

/* ── Responsive ─────────────────────────────────────── */
@media (max-width: 1023px) {
  .toc-mobile { display: block; }
  .toc-desktop { display: none !important; }
}
@media (min-width: 1024px) {
  .toc-mobile { display: none !important; }
  .toc-desktop { display: block; }
}
</style>
