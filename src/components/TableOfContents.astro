---
/**
 * TableOfContents.astro — Jump navigation for long articles.
 * Desktop: solid card below hero. Mobile: collapsible accordion.
 */

interface TocItem {
  label: string;
  anchor: string;
  indent?: boolean;
}

interface Props {
  items: TocItem[];
  heading?: string;
}

const { items, heading = 'In this guide' } = Astro.props;

if (!items || items.length < 3) return;
---

<div class="toc-card" id="toc-mobile">
  <details class="toc-details">
    <summary class="toc-header">
      <span class="toc-title">{heading}</span>
      <span class="toc-count">{items.length} sections</span>
    </summary>
    <nav class="toc-nav" aria-label="Table of contents">
      <ol class="toc-list">
        {items.map((item, i) => (
          <li class={item.indent ? 'toc-item toc-item--sub' : 'toc-item'}>
            <a href={`#${item.anchor}`} class="toc-link" data-toc-anchor={item.anchor}>
              <span class="toc-num">{i + 1}</span>
              {item.label}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  </details>
</div>

<script>
  const card = document.getElementById('toc-mobile');
  if (card) {
    const details = card.querySelector('details');
    card.querySelectorAll('.toc-link').forEach(link => {
      link.addEventListener('click', () => {
        if (details && window.innerWidth < 1024) {
          setTimeout(() => { (details as HTMLDetailsElement).open = false; }, 100);
        }
      });
    });
  }
</script>

<style>
.toc-card {
  background: var(--white, #fff);
  border: 1.5px solid var(--border, #D8D3C8);
  border-radius: var(--r2, 12px);
  margin: 20px 0 28px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.toc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
  background: var(--green, #1E3A28);
  cursor: pointer;
  list-style: none;
}
.toc-header::-webkit-details-marker { display: none; }

.toc-title {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gold, #C8A84B);
}

.toc-count {
  font-size: 11px;
  color: rgba(255,255,255,0.62);
}

.toc-nav {
  padding: 8px 12px 12px;
}

.toc-list {
  list-style: none;
  margin: 0;
  padding: 0;
  counter-reset: none;
}

.toc-item {
  margin: 0;
}
.toc-item--sub { padding-left: 20px; }

.toc-link {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 10px;
  font-size: 14px;
  font-weight: 500;
  color: var(--body, #2D3F32);
  text-decoration: none;
  border-radius: var(--r1, 6px);
  transition: background 0.15s, color 0.15s;
  line-height: 1.35;
}
.toc-link:hover {
  background: var(--cream, #F4F1EA);
  color: var(--green, #1E3A28);
}

.toc-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--cream, #F4F1EA);
  color: var(--green, #1E3A28);
  font-size: 11px;
  font-weight: 700;
  flex-shrink: 0;
}

/* Desktop: open by default */
@media (min-width: 768px) {
  .toc-details { }
  .toc-details[open] .toc-header { border-bottom: 1px solid var(--border, #D8D3C8); }
  .toc-nav { padding: 10px 16px 16px; }
  .toc-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 12px;
  }
}

/* Mobile: collapsed by default */
@media (max-width: 767px) {
  .toc-card { margin: 16px 0 20px; }
  .toc-link { font-size: 13px; padding: 7px 8px; }
  .toc-num { width: 20px; height: 20px; font-size: 10px; }
}
</style>
