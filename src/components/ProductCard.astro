---
/**
 * ProductCard.astro
 * Reusable affiliate product card with image, badge, CTA button.
 *
 * Props:
 *   name        — Product name
 *   badge       — Optional badge text (e.g. "BEST OVERALL")
 *   price       — Display price string (e.g. "~$329")
 *   retailer    — Retailer name (e.g. "Amazon", "Bushnell")
 *   url         — Affiliate URL
 *   label       — Button label (e.g. "Check Price on Amazon")
 *   imgSrc      — Optional real product image URL
 *   imgAlt      — Alt text for product image
 *   description — Short product description (1–2 sentences)
 *   emoji       — Fallback emoji if no image (default: "🏌️")
 *   winner      — Highlight as top pick (default: false)
 */

interface Props {
  name: string;
  badge?: string;
  price: string;
  retailer: string;
  url: string;
  label?: string;
  imgSrc?: string;
  imgAlt?: string;
  description?: string;
  emoji?: string;
  winner?: boolean;
}

const {
  name,
  badge,
  price,
  retailer,
  url,
  label = `Check Price at ${retailer}`,
  imgSrc,
  imgAlt,
  description,
  emoji = '🏌️',
  winner = false,
} = Astro.props;

const badgeClass = badge?.toLowerCase().replace(/\s+/g, '-') ?? '';
---

<div class:list={['product-card', { 'product-card--winner': winner }]}>

  {badge && (
    <div class="product-card__badge">
      {winner && <span class="product-card__crown" aria-hidden="true">🏆</span>}
      {badge}
    </div>
  )}

  <div class="product-card__img-wrap">
    {imgSrc ? (
      <img
        src={imgSrc}
        alt={imgAlt ?? name}
        width="280"
        height="200"
        loading="lazy"
        decoding="async"
        class="product-card__img"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
      />
      <div class="product-card__img-fallback" aria-hidden="true" style="display:none">
        <span style="font-size:56px">{emoji}</span>
      </div>
    ) : (
      <div class="product-card__img-fallback" aria-hidden="true">
        <span style="font-size:56px">{emoji}</span>
      </div>
    )}
  </div>

  <div class="product-card__body">
    <h3 class="product-card__name">{name}</h3>
    {description && <p class="product-card__desc">{description}</p>}
    <div class="product-card__price">{price}</div>
  </div>

  <a
    href={url}
    class:list={['product-card__cta', { 'product-card__cta--winner': winner }]}
    target="_blank"
    rel="nofollow noopener sponsored"
    aria-label={`${label} — ${name}`}
  >
    <span class="product-card__cta-text">{label} →</span>
    <span class="product-card__cta-badge">at {retailer}</span>
  </a>

</div>

<style>
.product-card {
  background: var(--cream-dark, #f5f0e8);
  border: 1px solid var(--border, #d6cdb8);
  border-radius: 12px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow .2s ease, transform .2s ease;
}
.product-card:hover {
  box-shadow: 0 6px 24px rgba(0,0,0,.12);
  transform: translateY(-2px);
}
.product-card--winner {
  border: 2px solid var(--green, #1E3A28);
  box-shadow: 0 4px 16px rgba(30,58,40,.15);
}

/* Badge */
.product-card__badge {
  background: var(--green, #1E3A28);
  color: #fff;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: .06em;
  text-transform: uppercase;
  padding: 6px 14px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.product-card--winner .product-card__badge {
  background: var(--gold, #C9A84C);
  color: #1a1a1a;
}
.product-card__crown { font-size: 13px; }

/* Image */
.product-card__img-wrap {
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 160px;
  padding: 16px;
}
.product-card__img {
  max-width: 100%;
  max-height: 160px;
  object-fit: contain;
  border-radius: 6px;
}
.product-card__img-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 120px;
}

/* Body */
.product-card__body {
  padding: 16px 20px 8px;
  flex: 1;
}
.product-card__name {
  font-size: 15px;
  font-weight: 700;
  color: var(--text, #1a1a1a);
  margin: 0 0 8px;
  line-height: 1.3;
}
.product-card__desc {
  font-size: 13px;
  color: var(--muted, #666);
  line-height: 1.5;
  margin: 0 0 10px;
}
.product-card__price {
  font-size: 22px;
  font-weight: 800;
  color: var(--green, #1E3A28);
  margin-bottom: 4px;
}

/* CTA Button */
.product-card__cta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  margin: 12px 16px 16px;
  padding: 13px 20px;
  background: var(--gold, #C9A84C);
  color: #1a1a1a;
  border-radius: 8px;
  text-decoration: none;
  font-weight: 800;
  font-size: 14px;
  transition: background .15s, transform .15s;
  text-align: center;
}
.product-card__cta:hover {
  background: var(--gold-dark, #a8892e);
  transform: scale(1.02);
}
.product-card__cta--winner {
  background: var(--green, #1E3A28);
  color: #fff;
}
.product-card__cta--winner:hover { background: #152c1e; }
.product-card__cta-text { font-size: 14px; font-weight: 800; }
.product-card__cta-badge { font-size: 11px; font-weight: 500; opacity: .75; }
</style>
