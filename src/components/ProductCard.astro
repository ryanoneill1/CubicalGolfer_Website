---
/**
 * ProductCard.astro — ENHANCED
 * Reusable affiliate product card with 3 CTA placements:
 *   1. Clickable product image
 *   2. Inline text link on product name
 *   3. Primary button CTA
 *
 * VALIDATION: will NOT render if url or imgSrc is missing.
 */

interface Props {
  name: string;
  url: string;
  price: string;
  retailer: string;
  label?: string;
  imgSrc?: string;
  imgAlt?: string;
  badge?: string;
  benefits?: string[];
  description?: string;
  emoji?: string;
  winner?: boolean;
  verdict?: string;
  whoFor?: string;
}

const {
  name, url, price, retailer,
  label = 'Check Today\'s Price',
  imgSrc, imgAlt, badge, benefits, description,
  emoji = '🏌️', winner = false,
  verdict, whoFor,
} = Astro.props;

// VALIDATION: skip render if required affiliate fields missing
if (!url || !imgSrc) return;
---

<div class:list={["product-card", { "product-card--winner": winner }]}>

  {badge && (
    <div class="product-card__badge">
      {winner && <span class="product-card__crown" aria-hidden="true">🏆</span>}
      {badge}
    </div>
  )}

  <!-- CTA 1: Clickable product image -->
  <a href={url} target="_blank" rel="nofollow noopener sponsored"
     class="product-card__img-link" aria-label={`View ${name} on ${retailer}`} tabindex="-1">
    <div class="product-card__img-wrap">
      <img src={imgSrc} alt={imgAlt ?? name} width="280" height="200"
           loading="lazy" decoding="async" class="product-card__img"
           onerror="this.src='/images/products/placeholder.webp'" />
      <div class="product-card__img-fallback" aria-hidden="true" style="display:none">
        <span style="font-size:56px">{emoji}</span>
      </div>
    </div>
  </a>

  <div class="product-card__body">
    <!-- CTA 2: Inline text link on product name -->
    <h3 class="product-card__name">
      <a href={url} target="_blank" rel="nofollow noopener sponsored"
         class="product-card__name-link">{name}</a>
    </h3>

    {verdict && (
      <p class="product-card__verdict">
        <span style="color:var(--gold);font-weight:800;margin-right:4px;">★</span>
        {verdict}
      </p>
    )}

    {description && <p class="product-card__desc">{description}</p>}

    {whoFor && (
      <p class="product-card__who-for">
        <strong style="font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--green);">Who it's for:</strong>
        {' '}{whoFor}
      </p>
    )}

    {benefits && benefits.length > 0 && (
      <ul class="product-card__benefits">
        {benefits.map((b: string) => <li>{b}</li>)}
      </ul>
    )}

    <div class="product-card__price">{price}</div>
    <p class="product-card__price-note">Prices change — click to see current price</p>
  </div>

  <!-- CTA 3: Primary button -->
  <a href={url} class:list={["product-card__cta", { "product-card__cta--winner": winner }]}
     target="_blank" rel="nofollow noopener sponsored"
     aria-label={`Check today's price for ${name} on ${retailer}`}>
    <span class="product-card__cta-text">Check Today's Price →</span>
    <span class="product-card__cta-badge">at {retailer} · Free shipping</span>
  </a>

</div>

<style>
.product-card {
  background: var(--cream-dark, #f5f0e8);
  border: 1px solid var(--border, #d6cdb8);
  border-radius: 12px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow .2s ease, transform .2s ease;
}
.product-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,.12); transform: translateY(-2px); }
.product-card--winner { border: 2px solid var(--green, #1E3A28); box-shadow: 0 4px 16px rgba(30,58,40,.15); }
.product-card__badge {
  background: var(--green, #1E3A28); color: #fff;
  font-size: 11px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase;
  padding: 6px 14px; display: flex; align-items: center; gap: 6px;
}
.product-card--winner .product-card__badge { background: var(--gold, #C9A84C); color: #1a1a1a; }
.product-card__crown { font-size: 13px; }
.product-card__img-link { display: block; }
.product-card__img-wrap {
  background: #fff; display: flex; align-items: center; justify-content: center;
  min-height: 160px; padding: 16px;
}
.product-card__img { max-width: 100%; max-height: 160px; object-fit: contain; border-radius: 6px; }
.product-card__img-fallback { display: flex; align-items: center; justify-content: center; width: 100%; min-height: 120px; }
.product-card__body { padding: 16px 20px 8px; flex: 1; }
.product-card__name { font-size: 15px; font-weight: 700; color: var(--text, #1a1a1a); margin: 0 0 8px; line-height: 1.3; }
.product-card__name-link { color: inherit; text-decoration: none; }
.product-card__name-link:hover { text-decoration: underline; color: var(--green); }
.product-card__verdict { font-size: 13px; color: var(--body, #333); line-height: 1.5; margin: 0 0 8px; font-style: italic; }
.product-card__who-for { font-size: 12px; color: var(--muted, #666); line-height: 1.5; margin: 0 0 10px; }
.product-card__desc { font-size: 13px; color: var(--muted, #666); line-height: 1.5; margin: 0 0 10px; }
.product-card__benefits { list-style: none; padding: 0; margin: 0 0 12px; }
.product-card__benefits li {
  font-size: 12px; color: var(--body, #333); padding: 3px 0 3px 18px;
  position: relative; line-height: 1.4;
}
.product-card__benefits li::before { content: "✓"; position: absolute; left: 0; color: var(--green, #1E3A28); font-weight: 700; }
.product-card__price { font-size: 22px; font-weight: 800; color: var(--green, #1E3A28); margin-bottom: 2px; }
.product-card__price-note { font-size: 10px; color: var(--muted, #888); margin: 0 0 4px; font-style: italic; }
.product-card__cta {
  display: flex; flex-direction: column; align-items: center; gap: 2px;
  margin: 12px 16px 16px; padding: 13px 20px;
  background: var(--gold, #C9A84C); color: #1a1a1a;
  border-radius: 8px; text-decoration: none; font-weight: 800; font-size: 14px;
  transition: background .15s, transform .15s; text-align: center;
}
.product-card__cta:hover { background: var(--gold-dark, #a8892e); transform: scale(1.02); }
.product-card__cta--winner { background: var(--green, #1E3A28); color: #fff; }
.product-card__cta--winner:hover { background: #152c1e; }
.product-card__cta-text { font-size: 14px; font-weight: 800; }
.product-card__cta-badge { font-size: 11px; font-weight: 500; opacity: .75; }
</style>
