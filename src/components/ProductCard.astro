---
/**
 * ProductCard.astro
 *
 * LAYOUT CONTRACT (enforced by CSS):
 *   • All cards in a row are equal height (CSS Grid align-items: stretch)
 *   • Image zone: fixed 220px — all images same area regardless of content
 *   • Product name: min 2 lines reserved — names align across cards
 *   • Benefits: flex-grow fills remaining space — prices always at same Y
 *   • Price + disclaimer: pinned above CTA
 *   • CTA: always at very bottom, full-width
 *
 * IMAGE: WebP 400×400 from /public/images/products/{productId}.webp
 * FALLBACK: Styled placeholder tile with category emoji if image fails
 */

interface Props {
  name:         string;
  url:          string;
  price:        string;
  retailer:     string;
  label?:       string;
  imgSrc?:      string;
  imgAlt?:      string;
  badge?:       string;
  benefits?:    string[];
  description?: string;
  emoji?:       string;
  winner?:      boolean;
  productId?:   string;
}

const {
  name, url, price, retailer,
  label = `Check Price at ${retailer}`,
  imgSrc: imgSrcProp,
  imgAlt,
  badge, benefits, description,
  emoji = '🏌️',
  winner = false,
  productId,
} = Astro.props;

const rawImg = imgSrcProp || (productId ? `/images/products/${productId}.webp` : null);
const resolvedImg = rawImg ?? null;

if (!url) return;
---

<div class:list={["product-card", { "product-card--winner": winner }]}>

  {badge && (
    <div class="product-card__badge">
      {badge}
    </div>
  )}

  <!-- Fixed-height image zone: 220px regardless of image content -->
  <a href={url} target="_blank" rel="nofollow noopener sponsored"
     class="product-card__img-link" aria-label={`View ${name} on ${retailer}`} tabindex="-1">
    <div class="product-card__img-wrap">
      {resolvedImg ? (
        <img
          src={resolvedImg}
          alt={imgAlt ?? `${name} product image`}
          width="400"
          height="400"
          loading="lazy"
          decoding="async"
          class="product-card__img"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
      ) : null}
      <div class="product-card__img-fallback"
           aria-hidden="true"
           style={resolvedImg ? "display:none" : ""}>
        <div class="product-card__img-placeholder">
          <span class="product-card__img-emoji">{emoji}</span>
          <span class="product-card__img-label">Photo coming soon</span>
        </div>
      </div>
    </div>
  </a>

  <!-- Body: flex column, benefits grow to push price to bottom -->
  <div class="product-card__body">
    <h3 class="product-card__name">
      <a href={url} target="_blank" rel="nofollow noopener sponsored"
         class="product-card__name-link">{name}</a>
    </h3>

    {description && <p class="product-card__desc">{description}</p>}

    <div class="product-card__benefits-wrap">
      {benefits && benefits.length > 0 && (
        <ul class="product-card__benefits" aria-label={`Key features of ${name}`}>
          {benefits.map((b: string) => <li>{b}</li>)}
        </ul>
      )}
    </div>

    <!-- Price always at the bottom of body, above CTA -->
    <div class="product-card__price-block">
      <div class="product-card__price">{price}</div>
      <p class="product-card__price-note">Prices change — click to see current price</p>
    </div>
  </div>

  <a href={url}
     class="product-card__cta"
     target="_blank" rel="nofollow noopener sponsored"
     aria-label={`${label} — ${name}`}>
    <span class="product-card__cta-text">{label} →</span>
    <span class="product-card__cta-badge">at {retailer}</span>
  </a>

</div>

<style>
/* ── Card shell ────────────────────────────────────────────── */
.product-card {
  background: var(--cream-dark);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow .2s ease, transform .2s ease;
  height: 100%;  /* fills grid row so all sibling cards stretch to equal height */
}
.product-card:hover {
  box-shadow: 0 6px 24px rgba(0,0,0,.12);
  transform: translateY(-2px);
}
/* Winner gets a green border — same thickness as all other cards */
/* All cards use identical border — no winner highlight */

/* ── Badge ─────────────────────────────────────────────────── */
.product-card__badge {
  background: var(--green);
  color: #fff;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: .06em;
  text-transform: uppercase;
  padding: 7px 14px;
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}

/* ── Image zone: FIXED 220px so all cards align ────────────── */
.product-card__img-link { display: block; flex-shrink: 0; }
.product-card__img-wrap {
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 220px;       /* FIXED — never grows or shrinks */
  padding: 16px;
  overflow: hidden;
}
.product-card__img {
  max-width: 100%;
  max-height: 188px;   /* 220px - 32px padding */
  width: auto;
  height: auto;
  object-fit: contain;
  filter: drop-shadow(0 2px 8px rgba(0,0,0,.10));
}
.product-card__img-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}
.product-card__img-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  background: var(--green-tint, #f0f7f2);
  border-radius: 8px;
  padding: 24px 20px;
  width: 100%;
  height: 100%;
  justify-content: center;
}
.product-card__img-emoji { font-size: 48px; line-height: 1; }
.product-card__img-label { font-size: 11px; color: var(--muted); font-style: italic; }

/* ── Body: flex column, benefits fill space ────────────────── */
.product-card__body {
  padding: 16px 18px 0;
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* Product name: reserved min-height so names align across cards */
.product-card__name {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
  margin: 0 0 10px;
  line-height: 1.35;
  min-height: 2.7em;   /* reserves 2 lines — short & long names align */
  display: flex;
  align-items: flex-start;
}
.product-card__name-link {
  color: inherit;
  text-decoration: none;
}
.product-card__name-link:hover { text-decoration: underline; color: var(--green); }

.product-card__desc {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.5;
  margin: 0 0 10px;
}

/* Benefits grow to fill space — pushes price block to bottom */
.product-card__benefits-wrap {
  flex: 1;
}
.product-card__benefits {
  list-style: none;
  padding: 0;
  margin: 0 0 12px;
}
.product-card__benefits li {
  font-size: 12px;
  color: var(--body);
  padding: 3px 0 3px 18px;
  position: relative;
  line-height: 1.45;
}
.product-card__benefits li::before {
  content: "✓";
  position: absolute;
  left: 0;
  color: var(--green);
  font-weight: 700;
}

/* Price block: pinned at bottom of body, above CTA */
.product-card__price-block {
  padding-top: 4px;
  margin-top: auto;   /* always pushed to bottom of flex body */
}
.product-card__price {
  font-size: 22px;
  font-weight: 800;
  color: var(--green);
  margin-bottom: 2px;
}
.product-card__price-note {
  font-size: 10px;
  color: var(--muted);
  margin: 0 0 14px;
  font-style: italic;
}

/* ── CTA: always at very bottom ────────────────────────────── */
.product-card__cta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  margin: 0 16px 16px;
  padding: 13px 20px;
  background: var(--gold);
  color: #1a1a1a;
  border-radius: 8px;
  text-decoration: none;
  font-weight: 800;
  font-size: 14px;
  transition: background .15s, transform .15s;
  text-align: center;
  flex-shrink: 0;
}
.product-card__cta:hover { background: var(--gold-dark); transform: scale(1.02); }
.product-card__cta-text { font-size: 14px; font-weight: 800; }
.product-card__cta-badge { font-size: 11px; font-weight: 500; opacity: .75; }
</style>
