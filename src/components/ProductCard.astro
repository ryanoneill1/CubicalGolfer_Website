---
/**
 * ProductCard.astro
 *
 * Renders a single affiliate product card with three CTAs:
 *   1. Clickable product image
 *   2. Inline product name link
 *   3. Primary button
 *
 * IMAGE FORMAT: WebP  (400×400 px)
 * Path: /public/images/products/{productId}.webp
 *
 * FALLBACK: If the .webp file is missing or fails to load,
 *           the card shows a coloured emoji tile instead.
 *           No broken image icons — ever.
 *
 * TO REPLACE A PRODUCT IMAGE:
 *   Upload a new {productId}.webp to /public/images/products/ in GitHub.
 *   No code changes needed.
 */

interface Props {
  name:        string;
  url:         string;
  price:       string;
  retailer:    string;
  label?:      string;
  imgSrc?:     string;   // explicit path override (optional)
  imgAlt?:     string;
  badge?:      string;
  benefits?:   string[];
  description?: string;
  emoji?:      string;
  winner?:     boolean;
  productId?:  string;   // drives automatic WebP lookup via image-map
}

const {
  name, url, price, retailer,
  label = `Check Price at ${retailer}`,
  imgSrc: imgSrcProp,
  imgAlt,
  badge, benefits, description,
  emoji = '🏌️',
  winner = false,
  productId,
} = Astro.props;

// Resolve image: explicit prop wins, else derive from productId
const resolvedImg = imgSrcProp || (productId ? `/images/products/${productId}.webp` : null);

if (!url) return;
---

<div class:list={["product-card", { "product-card--winner": winner }]}>

  {badge && (
    <div class="product-card__badge">
      {winner && <span class="product-card__crown" aria-hidden="true">🏆</span>}
      {badge}
    </div>
  )}

  <!-- Image — WebP with emoji fallback if file missing -->
  <a href={url} target="_blank" rel="nofollow noopener sponsored"
     class="product-card__img-link" aria-label={`View ${name} on ${retailer}`} tabindex="-1">
    <div class="product-card__img-wrap">
      {resolvedImg && (
        <img
          src={resolvedImg}
          alt={imgAlt ?? `${name} product image`}
          width="400"
          height="400"
          loading="lazy"
          decoding="async"
          class="product-card__img"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
      )}
      <div class="product-card__img-fallback"
           aria-hidden="true"
           style={resolvedImg ? "display:none" : ""}>
        <span>{emoji}</span>
      </div>
    </div>
  </a>

  <div class="product-card__body">
    <h3 class="product-card__name">
      <a href={url} target="_blank" rel="nofollow noopener sponsored"
         class="product-card__name-link">{name}</a>
    </h3>

    {description && <p class="product-card__desc">{description}</p>}

    {benefits && benefits.length > 0 && (
      <ul class="product-card__benefits" aria-label={`Key features of ${name}`}>
        {benefits.map((b: string) => <li>{b}</li>)}
      </ul>
    )}

    <div class="product-card__price">{price}</div>
    <p class="product-card__price-note">Prices change — click to see current price</p>
  </div>

  <a href={url}
     class:list={["product-card__cta", { "product-card__cta--winner": winner }]}
     target="_blank" rel="nofollow noopener sponsored"
     aria-label={`${label} — ${name}`}>
    <span class="product-card__cta-text">{label} →</span>
    <span class="product-card__cta-badge">at {retailer}</span>
  </a>

</div>

<style>
.product-card {
  background: var(--cream-dark);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow .2s ease, transform .2s ease;
}
.product-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,.12); transform: translateY(-2px); }
.product-card--winner { border: 1px solid var(--green); box-shadow: 0 4px 20px rgba(30,58,40,.20); }

.product-card__badge {
  background: var(--green); color: #fff;
  font-size: 11px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase;
  padding: 6px 14px; display: flex; align-items: center; gap: 6px;
}
.product-card__crown { font-size: 13px; }

.product-card__img-link { display: block; }
.product-card__img-wrap {
  background: #fff;
  display: flex; align-items: center; justify-content: center;
  min-height: 180px; padding: 12px;
}
.product-card__img {
  max-width: 100%; max-height: 200px; width: auto; height: auto;
  object-fit: contain;
  /* Subtle shadow makes product photos pop off white background */
  filter: drop-shadow(0 2px 8px rgba(0,0,0,.10));
}
.product-card__img-fallback {
  display: flex; align-items: center; justify-content: center;
  width: 100%; min-height: 140px; font-size: 56px;
}

.product-card__body { padding: 16px 20px 8px; flex: 1; }
.product-card__name { font-size: 15px; font-weight: 700; color: var(--text); margin: 0 0 8px; line-height: 1.3; }
.product-card__name-link { color: inherit; text-decoration: none; }
.product-card__name-link:hover { text-decoration: underline; color: var(--green); }
.product-card__desc { font-size: 13px; color: var(--muted); line-height: 1.5; margin: 0 0 10px; }
.product-card__benefits { list-style: none; padding: 0; margin: 0 0 12px; }
.product-card__benefits li {
  font-size: 12px; color: var(--body); padding: 3px 0 3px 18px;
  position: relative; line-height: 1.4;
}
.product-card__benefits li::before { content: "✓"; position: absolute; left: 0; color: var(--green); font-weight: 700; }
.product-card__price { font-size: 22px; font-weight: 800; color: var(--green); margin-bottom: 2px; }
.product-card__price-note { font-size: 10px; color: var(--muted); margin: 0 0 4px; font-style: italic; }

.product-card__cta {
  display: flex; flex-direction: column; align-items: center; gap: 2px;
  margin: 12px 16px 16px; padding: 13px 20px;
  background: var(--gold); color: #1a1a1a;
  border-radius: 8px; text-decoration: none; font-weight: 800; font-size: 14px;
  transition: background .15s, transform .15s; text-align: center;
}
.product-card__cta:hover { background: var(--gold-dark); transform: scale(1.02); }
.product-card__cta-text { font-size: 14px; font-weight: 800; }
.product-card__cta-badge { font-size: 11px; font-weight: 500; opacity: .75; }
</style>
