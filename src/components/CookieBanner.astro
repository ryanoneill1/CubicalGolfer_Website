---
/**
 * PrivacyNotice.astro (replaces CookieBanner.astro)
 *
 * This site uses genuinely cookieless analytics:
 *   - Plausible Analytics: no cookies, no personal data, GDPR-compliant by design
 *   - Cloudflare Web Analytics: no cookies, no cross-site tracking
 *
 * Since no cookies are set and no personal data is collected, the ePrivacy
 * Directive (Article 5(3)) does not require consent. A consent banner that
 * says "we use cookies" when we don't is misleading and arguably a GDPR
 * Art. 13 violation (inaccurate privacy notice).
 *
 * This component shows a one-time informational notice — not a consent gate.
 * No "Accept/Decline" because there's nothing to consent to.
 *
 * If cookies or personal-data tracking are ever added (e.g. GA4, Facebook
 * Pixel), this MUST be converted back to a real consent gate that blocks
 * those scripts until consent is given.
 */
---
<div id="privacy-notice" class="privacy-notice" hidden>
  <div class="privacy-notice__inner">
    <p>
      This site uses <strong>cookieless analytics</strong> (Plausible + Cloudflare) that collect
      no personal data. Affiliate links earn us a commission at no cost to you.
      <a href="/privacy-policy/">Privacy policy</a>.
    </p>
    <button id="privacy-dismiss" class="privacy-notice__btn">Got it</button>
  </div>
</div>
<style>
  .privacy-notice {
    position: fixed; bottom: 0; left: 0; right: 0;
    background: var(--green); color: #fff;
    padding: 12px clamp(1.5rem, 5vw, 4rem);
    z-index: 1000;
    box-shadow: 0 -4px 12px rgba(0,0,0,.18);
    transform: translateY(100%); transition: transform .4s ease;
  }
  .privacy-notice.visible { transform: translateY(0); }
  .privacy-notice__inner {
    max-width: 1200px; margin: 0 auto;
    display: flex; gap: 16px; align-items: center;
    flex-wrap: wrap;
  }
  .privacy-notice p { flex: 1; min-width: 280px; font-size: 13px; line-height: 1.5; margin: 0; }
  .privacy-notice a { color: var(--gold); text-decoration: underline; }
  .privacy-notice strong { color: #fff; font-weight: 700; }
  .privacy-notice__btn {
    padding: 8px 20px; border: 1px solid rgba(255,255,255,.3); border-radius: 6px;
    background: transparent; color: #fff;
    font-weight: 700; font-size: 13px; cursor: pointer;
  }
  .privacy-notice__btn:hover { border-color: #fff; background: rgba(255,255,255,.1); }
</style>
<script is:inline>
  (function() {
    var KEY = 'cg-privacy-noticed';
    if (localStorage.getItem(KEY)) return;
    var notice = document.getElementById('privacy-notice');
    if (!notice) return;
    notice.removeAttribute('hidden');
    document.body.classList.add('has-bottom-banner');
    setTimeout(function() { notice.classList.add('visible'); }, 800);
    document.getElementById('privacy-dismiss').addEventListener('click', function() {
      localStorage.setItem(KEY, '1');
      notice.classList.remove('visible');
      document.body.classList.remove('has-bottom-banner');
    });
  })();
</script>
