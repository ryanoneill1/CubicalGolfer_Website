---
/**
 * ProductCTA.astro — "Quick Pick" above-the-fold affiliate CTA.
 * Highest-converting element on affiliate review sites.
 * Renders after the intro paragraph, before the first H2.
 *
 * All new props (imageUrl, why, bestFor) are optional —
 * existing pages that don't pass them still render correctly.
 */

interface Props {
  productName: string;
  amazonUrl: string;
  amazonPrice: string;
  altUrl?: string;
  altLabel?: string;
  rating?: number;
  badge?: string;
  imageUrl?: string;
  why?: string;
  bestFor?: string;
}

const {
  productName,
  amazonUrl,
  amazonPrice,
  altUrl,
  altLabel,
  rating,
  badge,
  imageUrl,
  why,
  bestFor,
} = Astro.props;

const fullStars = rating ? Math.floor(rating) : 0;
const halfStar = rating ? (rating % 1 >= 0.5) : false;
const emptyStars = rating ? (5 - fullStars - (halfStar ? 1 : 0)) : 0;
---

<aside class="qp" role="complementary" aria-label={`Top pick: ${productName}`}>
  <div class="qp__inner">
    {imageUrl && (
      <div class="qp__img-wrap">
        <img src={imageUrl} alt={productName} width="80" height="80" loading="eager" decoding="async" />
      </div>
    )}
    <div class="qp__content">
      {badge && <span class="qp__badge">{badge}</span>}
      <p class="qp__name">{productName}</p>
      {rating && (
        <div class="qp__stars" aria-label={`${rating} out of 5 stars`}>
          {'★'.repeat(fullStars)}{halfStar ? '½' : ''}{'☆'.repeat(emptyStars)}
          <span class="qp__stars-num">{rating.toFixed(1)}</span>
        </div>
      )}
      {bestFor && <p class="qp__best-for">Best for: {bestFor}</p>}
      {why && <p class="qp__why">{why}</p>}
    </div>
    <div class="qp__actions">
      <a
        href={amazonUrl}
        class="qp__cta"
        target="_blank"
        rel="nofollow noopener sponsored"
        aria-label={`Check price for ${productName}`}
      >
        <span class="qp__cta-price">{amazonPrice}</span>
        <span class="qp__cta-text">Check Price on Amazon →</span>
      </a>
      {altUrl && altLabel && (
        <a
          href={altUrl}
          class="qp__alt"
          target="_blank"
          rel="nofollow noopener sponsored"
        >
          See at {altLabel} →
        </a>
      )}
    </div>
  </div>
  <p class="qp__disclosure">
    🛒 Independently purchased · Commission earned if you buy · Never influences our ranking
  </p>
</aside>

<style>
.qp {
  margin: 20px 0 28px;
  border-left: 4px solid var(--green-mid, #264D33);
  border-radius: var(--r2, 12px);
  background: linear-gradient(135deg, #f0f7f2 0%, var(--cream, #F4F1EA) 100%);
  box-shadow: var(--s1, 0 2px 8px rgba(0,0,0,.06));
  overflow: hidden;
}

.qp__inner {
  display: flex;
  align-items: flex-start;
  gap: 18px;
  padding: 22px 24px 14px;
  flex-wrap: wrap;
}

/* ── Product image ─────────────────────────────────────────── */
.qp__img-wrap {
  flex-shrink: 0;
  width: 80px;
  height: 80px;
  border-radius: var(--r1, 6px);
  overflow: hidden;
  background: var(--white, #fff);
  border: 1px solid var(--border, #D8D3C8);
}
.qp__img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

/* ── Content column ────────────────────────────────────────── */
.qp__content {
  flex: 1;
  min-width: 180px;
}

.qp__badge {
  display: inline-block;
  background: var(--green, #1E3A28);
  color: var(--gold, #C8A84B);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 4px 12px;
  border-radius: 20px;
  margin-bottom: 8px;
}

.qp__name {
  font-family: var(--font-display, 'Playfair Display', serif);
  font-size: 19px;
  font-weight: 700;
  color: var(--green, #1E3A28);
  margin: 0 0 4px;
  line-height: 1.3;
}

.qp__stars {
  font-size: 15px;
  color: var(--gold, #C8A84B);
  letter-spacing: 1.5px;
  margin-bottom: 6px;
}
.qp__stars-num {
  font-size: 13px;
  font-weight: 700;
  color: var(--muted, #556B5C);
  letter-spacing: 0;
  margin-left: 4px;
}

.qp__best-for {
  font-size: 13px;
  color: var(--muted, #556B5C);
  margin: 0 0 4px;
  line-height: 1.4;
}

.qp__why {
  font-size: 14px;
  font-style: italic;
  color: var(--body, #2D3F32);
  margin: 0;
  line-height: 1.5;
}

/* ── Actions column ────────────────────────────────────────── */
.qp__actions {
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex-shrink: 0;
}

.qp__cta {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--gold, #C8A84B);
  color: var(--text, #1A2B1F);
  padding: 12px 20px;
  border-radius: var(--r1, 6px);
  text-decoration: none;
  font-weight: 700;
  transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
  white-space: nowrap;
}
.qp__cta:hover {
  background: var(--gold-dark, #A8882A);
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(0,0,0,.12);
}
.qp__cta-price { font-size: 20px; font-weight: 800; }
.qp__cta-text  { font-size: 14px; font-weight: 700; }

.qp__alt {
  display: block;
  text-align: center;
  color: var(--green, #1E3A28);
  font-size: 13px;
  font-weight: 700;
  text-decoration: none;
  padding: 8px 16px;
  border: 2px solid var(--green, #1E3A28);
  border-radius: var(--r1, 6px);
  transition: background 0.15s;
}
.qp__alt:hover { background: rgba(30, 58, 40, 0.06); }

/* ── Disclosure ────────────────────────────────────────────── */
.qp__disclosure {
  font-size: 11px;
  color: var(--muted, #556B5C);
  margin: 0;
  padding: 0 24px 12px;
  text-align: center;
}

/* ── Mobile ────────────────────────────────────────────────── */
@media (max-width: 640px) {
  .qp__inner {
    flex-direction: column;
    align-items: stretch;
    gap: 14px;
    padding: 18px 18px 12px;
  }
  .qp__img-wrap {
    width: 64px;
    height: 64px;
  }
  .qp__name { font-size: 17px; }
  .qp__cta {
    justify-content: center;
    padding: 14px 16px;
  }
  .qp__alt { text-align: center; }
  .qp__disclosure { padding: 0 18px 10px; }
}
</style>
