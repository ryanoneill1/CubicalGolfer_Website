---
/**
 * ProductCTA.astro
 * Above-the-fold affiliate CTA card.
 * Designed to be placed within the first 200 words of any review or buying guide.
 * Matches the site's green/gold editorial palette.
 *
 * Props:
 *   productName  — Product display name
 *   amazonUrl    — Primary affiliate URL (Amazon or other)
 *   amazonPrice  — Price string e.g. "$169"
 *   altUrl       — Optional secondary retailer URL
 *   altLabel     — Secondary retailer name e.g. "Golf Galaxy"
 *   rating       — 1-5 star rating (optional)
 *   badge        — Badge text e.g. "Best Value", "Editor's Pick" (optional)
 */

interface Props {
  productName: string;
  amazonUrl: string;
  amazonPrice: string;
  altUrl?: string;
  altLabel?: string;
  rating?: number;
  badge?: string;
}

const {
  productName,
  amazonUrl,
  amazonPrice,
  altUrl,
  altLabel,
  rating,
  badge,
} = Astro.props;

// Generate star display
const fullStars = rating ? Math.floor(rating) : 0;
const halfStar = rating ? (rating % 1 >= 0.5) : false;
const emptyStars = rating ? (5 - fullStars - (halfStar ? 1 : 0)) : 0;
---

<aside class="product-cta" role="complementary" aria-label={`Top pick: ${productName}`}>
  <div class="product-cta__inner">
    <div class="product-cta__content">
      {badge && (
        <span class="product-cta__badge">{badge}</span>
      )}
      <p class="product-cta__name">{productName}</p>
      {rating && (
        <div class="product-cta__rating" aria-label={`${rating} out of 5 stars`}>
          {'★'.repeat(fullStars)}{halfStar ? '½' : ''}{'☆'.repeat(emptyStars)}
          <span class="product-cta__rating-num">{rating.toFixed(1)}</span>
        </div>
      )}
    </div>
    <div class="product-cta__actions">
      <a
        href={amazonUrl}
        class="product-cta__btn-primary"
        target="_blank"
        rel="nofollow noopener sponsored"
        aria-label={`Check price for ${productName}`}
      >
        <span class="product-cta__price">{amazonPrice}</span>
        <span class="product-cta__btn-text">Check Price on Amazon →</span>
      </a>
      {altUrl && altLabel && (
        <a
          href={altUrl}
          class="product-cta__btn-alt"
          target="_blank"
          rel="nofollow noopener sponsored"
          aria-label={`See ${productName} at ${altLabel}`}
        >
          See at {altLabel} →
        </a>
      )}
    </div>
  </div>
  <p class="product-cta__disclosure">
    We may earn a commission. Prices accurate at time of publish.
  </p>
</aside>

<style>
.product-cta {
  margin: 20px 0 28px;
  border: 2px solid var(--green, #1E3A28);
  border-radius: var(--r2, 12px);
  background: linear-gradient(135deg, #f0f7f2 0%, var(--cream, #F4F1EA) 100%);
  overflow: hidden;
}

.product-cta__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  padding: 20px 24px 16px;
  flex-wrap: wrap;
}

.product-cta__content {
  flex: 1;
  min-width: 180px;
}

.product-cta__badge {
  display: inline-block;
  background: var(--green, #1E3A28);
  color: var(--gold, #C8A84B);
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 4px 12px;
  border-radius: 20px;
  margin-bottom: 8px;
}

.product-cta__name {
  font-family: 'Playfair Display', serif;
  font-size: 19px;
  font-weight: 700;
  color: var(--green, #1E3A28);
  margin: 0 0 4px;
  line-height: 1.3;
}

.product-cta__rating {
  font-size: 16px;
  color: var(--gold, #C8A84B);
  letter-spacing: 2px;
}

.product-cta__rating-num {
  font-size: 13px;
  font-weight: 700;
  color: var(--muted, #556B5C);
  letter-spacing: 0;
  margin-left: 6px;
}

.product-cta__actions {
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex-shrink: 0;
}

.product-cta__btn-primary {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--gold, #C8A84B);
  color: var(--text, #1A2B1F);
  padding: 12px 20px;
  border-radius: var(--r1, 6px);
  text-decoration: none;
  font-weight: 700;
  transition: background 0.15s, transform 0.1s;
  white-space: nowrap;
}

.product-cta__btn-primary:hover {
  background: var(--gold-dark, #A8882A);
  transform: translateY(-1px);
}

.product-cta__price {
  font-size: 20px;
  font-weight: 800;
}

.product-cta__btn-text {
  font-size: 14px;
  font-weight: 700;
}

.product-cta__btn-alt {
  display: block;
  text-align: center;
  color: var(--green, #1E3A28);
  font-size: 13px;
  font-weight: 700;
  text-decoration: none;
  padding: 8px 16px;
  border: 2px solid var(--green, #1E3A28);
  border-radius: var(--r1, 6px);
  transition: background 0.15s;
}

.product-cta__btn-alt:hover {
  background: rgba(30, 58, 40, 0.06);
}

.product-cta__disclosure {
  font-size: 11px;
  color: var(--muted, #556B5C);
  margin: 0;
  padding: 0 24px 12px;
  text-align: right;
}

@media (max-width: 480px) {
  .product-cta__inner {
    flex-direction: column;
    align-items: stretch;
    gap: 14px;
    padding: 16px 18px 12px;
  }

  .product-cta__name {
    font-size: 17px;
  }

  .product-cta__btn-primary {
    justify-content: center;
    padding: 14px 16px;
  }

  .product-cta__btn-alt {
    text-align: center;
  }

  .product-cta__disclosure {
    text-align: center;
    padding: 0 18px 10px;
  }
}
</style>
