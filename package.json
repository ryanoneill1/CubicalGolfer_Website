{
  "name": "cubicalgolfer",
  "version": "2.0.0",
  "description": "CubicalGolfer.com — Programmatic SEO Golf Media Engine",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "validate": "tsx scripts/validate-affiliate-keys.ts",
    "build": "npm run validate && astro build && node scripts/stamp-build.js",
    "preview": "astro preview",
    "check": "astro check",
    "generate": "node src/lib/generators.js",
    "build:prod": "astro build && node --input-type=module < scripts/stamp-build.js"
  },
  "dependencies": {
    "astro": "^4.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  }
}
